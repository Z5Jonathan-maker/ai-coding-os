#!/usr/bin/env bash
# cc-langfuse-up — one-shot installer for self-hosted Langfuse + the
# pdhoolia/langfuse-claude-code-plugin observability layer.
#
# Same pattern as cc-tailscale-qr / cc-sudoers-install: agent stages
# the wrapper, user runs it once. Idempotent.
#
# What it does:
#   1. Clones langfuse/langfuse → ~/code/research/langfuse (if missing)
#   2. Clones pdhoolia/langfuse-claude-code-plugin → ~/code/research/langfuse-claude-code-plugin
#   3. Brings up self-hosted Langfuse (postgres + langfuse-web) on :3000
#   4. Waits for healthcheck
#   5. Opens the Langfuse UI in your default browser
#   6. Prints next steps (slash commands you must paste in Claude Code)
#
# After completion:
#   - Open http://localhost:3000 → create account + project
#   - Copy public_key + secret_key
#   - 1P: create item "Langfuse" with public_key, secret_key fields
#   - In Claude Code, paste:
#       /plugin marketplace add pdhoolia/langfuse-claude-code-plugin
#       /plugin install langfuse-tracing@langfuse-claude-code-plugin
#       /reload-plugins
#   - Add to ~/.zprofile (cc-langfuse-env handles this if you prefer):
#       export CC_LANGFUSE_BASE_URL=http://localhost:3000
#       export CC_LANGFUSE_PUBLIC_KEY=$(op read 'op://Personal/Langfuse/public_key')
#       export CC_LANGFUSE_SECRET_KEY=$(op read 'op://Personal/Langfuse/secret_key')
#       export CC_LANGFUSE_TRACE_DEFAULT=true
set -euo pipefail

RESEARCH="$HOME/code/research"
LF_REPO="$RESEARCH/langfuse"
PLUGIN_REPO="$RESEARCH/langfuse-claude-code-plugin"
LF_PORT="${LF_PORT:-3000}"

mkdir -p "$RESEARCH"

hdr()  { printf '\n\033[1m== %s ==\033[0m\n' "$*"; }
ok()   { printf '  \033[32m✓\033[0m %s\n' "$*"; }
warn() { printf '  \033[33m○\033[0m %s\n' "$*"; }
fail() { printf '  \033[31m✗\033[0m %s\n' "$*" >&2; }

hdr "1. clone langfuse + plugin"
if [ -d "$LF_REPO/.git" ]; then
  ok "$LF_REPO already exists; pulling"
  ( cd "$LF_REPO" && git pull --ff-only )
else
  git clone --depth=1 https://github.com/langfuse/langfuse.git "$LF_REPO"
  ok "cloned langfuse"
fi
if [ -d "$PLUGIN_REPO/.git" ]; then
  ok "$PLUGIN_REPO already exists; pulling"
  ( cd "$PLUGIN_REPO" && git pull --ff-only )
else
  git clone --depth=1 https://github.com/pdhoolia/langfuse-claude-code-plugin.git "$PLUGIN_REPO"
  ok "cloned plugin"
fi

hdr "2. docker compose up -d (langfuse self-host)"
if docker ps --format '{{.Names}}' | grep -q langfuse-web; then
  ok "langfuse already running"
else
  ( cd "$LF_REPO" && docker compose up -d )
  ok "stack starting"
fi

hdr "3. healthcheck (waiting up to 90s for :${LF_PORT})"
for _ in $(seq 1 45); do
  if curl -fsS "http://127.0.0.1:${LF_PORT}/api/public/health" >/dev/null 2>&1 \
     || curl -fsS "http://127.0.0.1:${LF_PORT}/" >/dev/null 2>&1; then
    ok "langfuse responding on :${LF_PORT}"; break
  fi
  printf '.'; sleep 2
done
echo

hdr "4. open Langfuse UI"
open "http://127.0.0.1:${LF_PORT}"

hdr "5. NEXT STEPS (you do these)"
cat <<NEXT
  a) In the just-opened browser tab:
     - Sign up (local account, no email needed for self-hosted)
     - Create a project named "iMac god-mode"
     - Settings → API Keys → Create new API keys
     - Copy the public_key (pk-lf-...) and secret_key (sk-lf-...)

  b) Stash in 1Password:
     op item create --category="API Credential" --vault=Personal \\
       --title="Langfuse" \\
       public_key=pk-lf-... \\
       secret_key=sk-lf-...

  c) In any Claude Code session, paste:
     /plugin marketplace add pdhoolia/langfuse-claude-code-plugin
     /plugin install langfuse-tracing@langfuse-claude-code-plugin
     /reload-plugins

  d) Restart Claude Code so the env loads + plugin attaches.

  e) Verify with the /journey slash command in any session.

  Status:    docker compose ps  (in $LF_REPO)
  Logs:      docker compose logs -f
  Stop:      docker compose down
  Restart:   docker compose up -d
NEXT
