#!/usr/bin/env bash
set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/dotfiles}"
OUT_DIR="${1:-$DOTFILES/docs/media/cockpit}"
CSS="$DOTFILES/vscode/ai-cockpit/media/style.css"
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

command -v playwright >/dev/null 2>&1 || {
  printf 'missing playwright CLI\n' >&2
  exit 1
}

[ -f "$CSS" ] || {
  printf 'missing cockpit CSS: %s\n' "$CSS" >&2
  exit 1
}

mkdir -p "$OUT_DIR"

write_page() {
  local file="$1" title="$2" hero="$3" body="$4" cards="$5"
  local body_class="${6:-}"
  {
    cat <<HTML
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>${title}</title>
  <style>
    :root {
      --vscode-foreground: #d4d4d4;
      --vscode-descriptionForeground: #9ca3af;
      --vscode-sideBar-background: #181818;
      --vscode-editor-background: #1f1f1f;
      --vscode-panel-border: #333333;
      --vscode-sideBarSectionHeader-border: #333333;
      --vscode-button-background: #0e639c;
      --vscode-button-hoverBackground: #1177bb;
      --vscode-button-foreground: #ffffff;
      --vscode-button-border: transparent;
      --vscode-input-background: #252526;
      --vscode-input-foreground: #d4d4d4;
      --vscode-input-border: #3c3c3c;
      --vscode-focusBorder: #007fd4;
      --vscode-testing-iconPassed: #73c991;
      --vscode-testing-iconFailed: #f14c4c;
      --vscode-testing-iconQueued: #cca700;
      --vscode-textCodeBlock-background: #111111;
      --vscode-editor-foreground: #d4d4d4;
      --vscode-badge-foreground: #ffffff;
      --vscode-badge-background: #4d4d4d;
      --vscode-editor-font-family: "SF Mono", Menlo, monospace;
      --vscode-font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    body { max-width: 410px; margin: 0 auto; }
HTML
    cat "$CSS"
    cat <<HTML
    body.panel-mode { max-width: none; margin: 0; }
  </style>
</head>
<body${body_class:+ class="$body_class"}>
  <header>
    <div class="brand-lockup">
      <svg class="brand-mark" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect x="3.25" y="3.25" width="17.5" height="17.5" rx="4.25" stroke="#7AA2FF" stroke-width="1.5"/>
        <path d="M7.25 12C7.25 9.37665 9.37665 7.25 12 7.25C14.6234 7.25 16.75 9.37665 16.75 12C16.75 14.6234 14.6234 16.75 12 16.75C9.37665 16.75 7.25 14.6234 7.25 12Z" stroke="#9BE7C8" stroke-width="1.4"/>
        <path d="M12 5.75V8.75M12 15.25V18.25M5.75 12H8.75M15.25 12H18.25" stroke="#F8D66D" stroke-width="1.4" stroke-linecap="round"/>
        <path d="M10.35 12.05L11.45 13.15L13.9 10.7" stroke="#FFFFFF" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <div>
        <div class="eyebrow">AI-SYSTEM-V2</div>
        <h1>AI Cockpit</h1>
        <p class="brand-subtitle">Router control surface</p>
      </div>
    </div>
    <button class="icon-button" title="Refresh" aria-label="Refresh cockpit">
      <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20 12a8 8 0 0 1-13.7 5.7M4 12A8 8 0 0 1 17.7 6.3"/><path d="M17.7 3.5v2.8h-2.8M6.3 20.5v-2.8h2.8"/></svg>
    </button>
  </header>

  <section class="hero">
    <div class="status-dot degraded"></div>
    <div>
      <strong>${hero}</strong>
      <p>${body}</p>
    </div>
  </section>

  <button class="open-panel-button">
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16v14H4z"/><path d="M9 5v14"/><path d="M15 11l3 3-3 3"/></svg>
    <span>Open Full Cockpit</span>
  </button>

  <section class="composer">
    <div class="composer-head">
      <label for="prompt">Command</label>
      <span id="context">vscode/ai-cockpit/extension.js:209</span>
    </div>
    <textarea id="prompt" rows="5">Debug this repo and verify the safest next step.</textarea>
    <div class="chips"><button class="chip">git diff x</button><button class="chip">README.md x</button></div>
    <div class="runrow">
      <button class="primary command-button"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5.5v13l10-6.5-10-6.5Z"/></svg><span>Run</span></button>
      <button class="secondary command-button"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h5l2 3h9"/><path d="M4 17h5l2-3h9"/><path d="M17 7l3 3-3 3"/><path d="M17 11l3 3-3 3"/></svg><span>Preview Route</span></button>
    </div>
    <section class="control-deck" aria-label="Cockpit controls">
      <div class="control-group">
        <div class="control-label">Mode: Auto</div>
        <div class="modebar" role="group" aria-label="Mode">
          <button class="mode active" aria-pressed="true">Auto</button>
          <button class="mode" aria-pressed="false">Code</button>
          <button class="mode" aria-pressed="false">Browser</button>
          <button class="mode" aria-pressed="false">Extract</button>
          <button class="mode" aria-pressed="false">Route</button>
        </div>
      </div>
      <div class="control-group permission-control">
        <div class="control-label">Authority: Review</div>
        <div class="permissionbar" role="group" aria-label="Permission mode">
          <button class="permission" aria-pressed="false"><strong>Ask</strong><span>Confirm writes</span></button>
          <button class="permission active" aria-pressed="true"><strong>Review</strong><span>Guarded edits</span></button>
          <button class="permission" aria-pressed="false"><strong>Autopilot</strong><span>Safe loop</span></button>
        </div>
      </div>
    </section>
    <div class="toolrow">
      <button class="tool-button"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5Z"/><path d="M14 3v5h5"/></svg><span>File</span></button>
      <button class="tool-button"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 7h10M7 12h6M7 17h10"/><path d="M4 4v16M20 4v16"/></svg><span>Diff</span></button>
      <button class="tool-button"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 5h14v10H8l-3 3V5Z"/><path d="M9 9h6M9 12h4"/></svg><span>Review</span></button>
    </div>
    <label class="check"><input type="checkbox" checked> Include active file</label>
  </section>

  <section class="result-panel">
    <div class="panel-head">
      <h2>Work Stream</h2>
      <div class="result-actions" aria-label="Work stream actions">
        <button class="mini-button" title="Copy work stream" aria-label="Copy work stream">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 8h10v12H8z"/><path d="M6 16H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        </button>
        <button class="mini-button" title="Clear work stream" aria-label="Clear work stream">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16"/><path d="M10 11v6M14 11v6"/><path d="M6 7l1 14h10l1-14"/><path d="M9 7V4h6v3"/></svg>
        </button>
        <button class="mini-button stop-button" title="Stop current run" aria-label="Stop current run" disabled>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="7" y="7" width="10" height="10" rx="1"/></svg>
        </button>
        <button class="mini-button text-mini">Demo</button>
      </div>
    </div>
    <pre>You
Debug this repo and verify the safest next step.

Auto
Route selected: precision -> claude
Fallback: design/kimi -> cheap/deepseek

Working tree clean.
Product readiness: 14/14.
Next step: keep changes scoped, verify release gate, then ship.</pre>
  </section>

  <details open>
    <summary>Overview</summary>
    <section class="status-grid" aria-label="Live cockpit state">
      <button><span>Route</span><strong>Auto</strong></button>
      <button><span>Changes</span><strong>6 files</strong></button>
      <button><span>Context</span><strong>1%</strong></button>
      <button><span>Browser</span><strong>Shim</strong></button>
    </section>
  </details>

  <details>
    <summary>Context</summary>
    <section class="cards">
${cards}
    </section>
  </details>
</body>
</html>
HTML
  } >"$file"
}

card() {
  local title="$1" text="$2" button="${3:-View}"
  printf '    <article><h2>%s</h2><pre>%b</pre><button>%s</button></article>\n' "$title" "$text" "$button"
}

capture() {
  local name="$1" title="$2" hero="$3" body="$4" cards="$5" out="$6"
  local html="$tmp/$name.html"
  write_page "$html" "$title" "$hero" "$body" "$cards"
  playwright screenshot --channel chrome --viewport-size 480,1200 --full-page "file://$html" "$OUT_DIR/$out" >/dev/null
  printf 'captured %s\n' "$OUT_DIR/$out"
}

capture_panel() {
  local name="$1" title="$2" hero="$3" body="$4" cards="$5" out="$6"
  local html="$tmp/$name.html"
  write_page "$html" "$title" "$hero" "$body" "$cards" "panel-mode"
  playwright screenshot --channel chrome --viewport-size 1440,900 "file://$html" "$OUT_DIR/$out" >/dev/null
  printf 'captured %s\n' "$OUT_DIR/$out"
}

capture "readiness" "Product Readiness" "Ready with browser shim" \
  "Product gate is green. Browser automation is using the shim profile, not the official logged-in Chrome extension." \
  "$(card "Product Readiness" "Score: 14/14 checks (100%)\nStatus: product-ready" "View Gate")$(card "Disk" "Free: 25GB\nMinimum gate: 25GB\nStatus: PASS" "View Disk Report")$(card "First Run" "required_missing=0 optional_missing=0 personal_missing=0\nStatus: first-run-ready" "View Doctor")" \
  "01-readiness.png"

capture "first-run" "First Run Doctor" "First-run ready" \
  "Required tools are present. Optional lanes and local account services are named separately." \
  "$(card "Required Tools" "git OK\nzsh OK\nbrew OK\nnode OK\ncode OK\nrg OK" "View Doctor")$(card "AI Lane Tools" "codex OK\nclaude OK\nkimi OK\ndeepseek OK\nop OK" "View Doctor")$(card "Credentials" "API keys are not inspected.\nUse 1Password, TEL, or local env." "View Doctor")" \
  "02-first-run.png"

capture "route" "Route Receipt" "Deterministic route proof" \
  "The cockpit shows selected lane, fallback chain, latency, tokens, and cost status." \
  "$(card "Route" "Selected: precision -> claude\nFallback: precision/claude -> design/kimi -> cheap/deepseek\nHard floor: false" "View Receipt")$(card "Metrics" "Fallbacks: 21\nTokens logged: 490\nCost today: \$0.0000 / \$10.00" "View Metrics")$(card "Sessions" "Recent routed sessions and sticky state visible." "View Sessions")" \
  "03-route-receipt.png"

capture "browser" "Browser Proof" "Browser mode: shim" \
  "Mode is explicit. Shim is valid for proof and demos but not equivalent to logged-in Chrome control." \
  "$(card "Kimi" "Desktop: installed\nCLI: v1.41.0\nWebBridge: running=true\nmode=shim" "View Kimi Status")$(card "Browser Proof" "Browser mode: shim\nWebBridge: running=true extension_connected=true\nbounded page proof returned" "View Proof")$(card "Known Boundary" "Official extension requires user approval." "View Boundary")" \
  "04-browser-proof.png"

capture "composer" "Composer" "Auto-first execution" \
  "Auto, Code, Browser, Extract, and Route are intent modes. The router owns model choice and fallback." \
  "$(card "Route" "Circuits: design:closed | image:closed | tier3:closed\nFallback: router-owned" "View Receipt")$(card "File Changes" "files: 6\nadded: 126\nremoved: 91" "View Diff")$(card "Context Pressure" "Input estimate visible.\nDiff/context chips attached." "View Context")$(card "Last Result" "Explain Route\nSelected: auto -> router fallback chain" "Run")" \
  "05-composer.png"

capture_panel "full-panel" "Full Cockpit Panel" "Full-panel work surface" \
  "The full editor panel keeps the work stream large and puts the command composer below it." \
  "$(card "Route" "Selected: auto\nFallback: router-owned" "View Receipt")$(card "File Changes" "files: 6\nadded: 126\nremoved: 91" "View Diff")" \
  "06-full-panel.png"

if command -v sips >/dev/null 2>&1; then
  sips -s format gif "$OUT_DIR/05-composer.png" --out "$OUT_DIR/05-composer.gif" >/dev/null
  printf 'captured %s\n' "$OUT_DIR/05-composer.gif"
fi

capture "package" "Package Proof" "VSIX ready" \
  "The cockpit packages as a distributable VS Code extension." \
  "$(card "Package" "DONE Packaged: dist/ai-system-cockpit-0.1.0.vsix\n9 files, 16.57 KB" "View Package")$(card "License" "Apache-2.0\nRoot and VSIX package aligned." "View License")$(card "Release Gate" "cc-package-cockpit exits successfully." "Run Gate")" \
  "06-package.png"

printf '\nDone. Media written to %s\n' "$OUT_DIR"
