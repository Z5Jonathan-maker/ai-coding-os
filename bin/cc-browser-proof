#!/usr/bin/env bash
set -euo pipefail

url=""
session="proof-$(date +%s)"
json=0
max_chars="${CC_BROWSER_PROOF_MAX_CHARS:-8000}"
while (($#)); do
  case "$1" in
  --url)
    shift
    url="${1:-}"
    ;;
  --session)
    shift
    session="${1:-$session}"
    ;;
  --json) json=1 ;;
  --max-chars)
    shift
    max_chars="${1:-$max_chars}"
    ;;
  -h | --help)
    printf 'Usage: cc-browser-proof [--json] [--url URL] [--session NAME] [--max-chars N]\n'
    exit 0
    ;;
  *) url="$1" ;;
  esac
  shift
done

bridge="$HOME/.kimi-webbridge/bin/kimi-webbridge"
[ -x "$bridge" ] || bridge="/Applications/Kimi.app/Contents/Resources/resources/kimi-webbridge"
nonce="$(openssl rand -hex 8 2>/dev/null || date +%s)"
status="$([ -x "$bridge" ] && "$bridge" status 2>/dev/null || printf '{}')"
healthy="$(node -e 'try{const s=JSON.parse(process.argv[1]);process.stdout.write(s.running&&s.extension_connected?"1":"0")}catch{process.stdout.write("0")}' "$status")"

payload() {
  node - "$1" "$2" "$session" <<'NODE'
const [action, url, session] = process.argv.slice(2);
const args = action === 'navigate' ? { url, newTab: true, group_title: 'AI Proof' } : {};
process.stdout.write(JSON.stringify({ action, args, session }));
NODE
}

snap=""
nav=""
if [ "$healthy" = 1 ] && [ -n "$url" ]; then
  nav="$(curl -fsS -X POST http://127.0.0.1:10086/command -H 'Content-Type: application/json' -d "$(payload navigate "$url")" 2>/dev/null || true)"
  snap="$(curl -fsS -X POST http://127.0.0.1:10086/command -H 'Content-Type: application/json' -d "$(payload snapshot '')" 2>/dev/null || true)"
fi

if [ "$json" = 1 ]; then
  node - "$status" "$nav" "$snap" "$healthy" "$url" "$session" <<'NODE'
const [status, nav, snap, healthy, url, session] = process.argv.slice(2);
const parse = s => { try { return JSON.parse(s || '{}'); } catch { return {}; } };
const parsedStatus = parse(status);
const extensionVersion = parsedStatus.extension_version || "";
const mode = !parsedStatus.running ? "not-ready"
  : !parsedStatus.extension_connected ? "not-ready"
  : extensionVersion.startsWith("shim-") ? "shim"
  : extensionVersion ? "official-extension"
  : "unknown";
console.log(JSON.stringify({ healthy: healthy === '1', mode, url: url || null, session, status: parsedStatus, navigate: parse(nav), snapshot: parse(snap) }, null, 2));
NODE
  exit 0
fi

printf '# Browser Proof\n\n'
# shellcheck disable=SC2016
node -e 'try{const s=JSON.parse(process.argv[1]); const ev=s.extension_version||""; const mode=!s.running?"not-ready":!s.extension_connected?"not-ready":ev.startsWith("shim-")?"shim":ev?"official-extension":"unknown"; console.log(`Browser mode: ${mode}`); console.log(`WebBridge: running=${!!s.running} extension_connected=${!!s.extension_connected} port=${s.port||"unknown"} version=${s.version||"unknown"} extension_version=${ev||"unknown"}`)}catch{console.log("Browser mode: not-ready"); console.log("WebBridge: unavailable")}' "$status"
printf 'Session: %s\n' "$session"
if [ -z "$url" ]; then
  printf '\nNo URL supplied. Readiness proof only.\n'
  exit 0
fi
printf 'URL: %s\n\n' "$url"
printf '%s\n' "--- BROWSER_PROOF_CONTENT nonce=$nonce origin=$url ---"
node - "$snap" "$max_chars" <<'NODE'
const [raw, max] = process.argv.slice(2);
let out = '';
try {
  const s = JSON.parse(raw || '{}');
  out = s?.data?.tree || s?.tree || s?.data?.title || JSON.stringify(s);
} catch { out = raw || ''; }
const n = Number(max) || 8000;
console.log(out.length > n ? `${out.slice(0, n)}\n[truncated: ${n} of ${out.length} chars]` : (out || 'snapshot unavailable'));
NODE
printf '%s\n' "--- END_BROWSER_PROOF_CONTENT nonce=$nonce ---"
