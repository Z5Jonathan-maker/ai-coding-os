{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Read(//**)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Agent(*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "Shell(*)",
      "SearchWeb(*)",
      "FetchURL(*)",
      "AskUserQuestion(*)",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "EnterPlanMode(*)",
      "ExitPlanMode(*)",
      "SetTodoList(*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/)",
      "Bash(sudo rm -rf /)",
      "Bash(sudo rm -rf /*)",
      "Bash(> /dev/sda)",
      "Bash(dd if=* of=/dev/sda*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-resume.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/bootstrap-check.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/mcp-session-probe.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/tel-health.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/secret-paste-guard.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/loop-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/context-monitor.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/error-gate.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/isa-nyquist-gate.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/nonstop.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/no-ask-human.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/wired-up-stop.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-handover.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/wiki-writeback.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/mempalace-stop.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/skill-metrics.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/leonardofibonacci/.claude/scripts/status-line.sh"
  },
  "enabledPlugins": {
    "claude-video-vision@claude-video-vision": true
  },
  "extraKnownMarketplaces": {
    "claude-video-vision": {
      "source": {
        "source": "git",
        "url": "https://github.com/jordanrendric/claude-video-vision.git"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "excludeDynamicSystemPromptSections": true
}
