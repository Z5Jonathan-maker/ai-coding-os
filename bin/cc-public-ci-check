#!/usr/bin/env bash
set -u

ROOT="${DOTFILES:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
pass=0
fail=0

run() {
  local name="$1" tmp ok
  shift
  tmp="$(mktemp "${TMPDIR:-/tmp}/cc-public-ci.XXXXXX")"
  ok=0
  printf '\n## %s\n' "$name"
  if "$@" >"$tmp" 2>&1; then
    ok=1
  fi
  if [ "$ok" = 1 ]; then
    printf 'ok   %s\n' "$name"
    pass=$((pass + 1))
  else
    printf 'fail %s\n' "$name"
    sed 's/^/     /' "$tmp" | sed -n '1,80p'
    fail=$((fail + 1))
  fi
  rm -f "$tmp"
}

bash_syntax() {
  local bad=0 first
  while IFS= read -r file; do
    first="$(head -n1 "$file")"
    case "$first" in
    *bash*) bash -n "$file" || bad=1 ;;
    esac
  done < <(find -L bin -maxdepth 1 -type f -perm -111 -print | sort)
  return "$bad"
}

node_syntax() {
  local bad=0 first
  while IFS= read -r file; do
    first="$(head -n1 "$file")"
    case "$first" in
    *node*) node --check "$file" || bad=1 ;;
    esac
  done < <(find -L bin -maxdepth 1 -type f -perm -111 -print | sort)
  while IFS= read -r file; do
    node --check "$file" || bad=1
  done < <(find -L lib -type f -name '*.js' -print 2>/dev/null | sort)
  node --check vscode/ai-cockpit/extension.js || bad=1
  node --check vscode/ai-cockpit/media/main.js || bad=1
  node -e 'JSON.parse(require("fs").readFileSync("vscode/ai-cockpit/package.json", "utf8"))' || bad=1
  return "$bad"
}

cockpit_tests() {
  node --test vscode/ai-cockpit/test/*.test.js
}

issue_template_yaml() {
  ruby -e 'require "yaml"; Dir[".github/ISSUE_TEMPLATE/*.{yml,yaml}"].each { |f| YAML.load_file(f); puts "ok #{f}" }'
}

required_docs() {
  local missing=0
  for file in \
    README.md \
    CONTRIBUTING.md \
    SECURITY.md \
    LICENSE \
    docs/ARCHITECTURE.md \
    docs/EVALUATOR-QUICKSTART.md \
    docs/KNOWN-LIMITATIONS.md \
    docs/RELEASE-CHECKLIST.md \
    docs/RELEASE-NOTES.md \
    docs/RELEASE-MANIFEST.md \
    docs/ROADMAP.md; do
    if [ ! -s "$file" ]; then
      printf 'missing %s\n' "$file"
      missing=1
    fi
  done
  return "$missing"
}

command_registry_complete() {
  local missing=0 name bin_list doc_list dupes stale
  bin_list="$(mktemp "${TMPDIR:-/tmp}/cc-public-ci-bin.XXXXXX")"
  doc_list="$(mktemp "${TMPDIR:-/tmp}/cc-public-ci-doc.XXXXXX")"

  while IFS= read -r file; do
    name="$(basename "$file")"
    printf '%s\n' "$name" >>"$bin_list"
    if ! grep -Fq "\`$name\`" docs/COMMAND-REGISTRY.md; then
      printf 'missing registry entry: %s\n' "$name"
      missing=1
    fi
  done < <(find -L bin -maxdepth 1 -type f -perm -111 -print | sort)

  sort -u "$bin_list" -o "$bin_list"
  sed '/^## Retired/,$d' docs/COMMAND-REGISTRY.md |
    sed -n "s/^- \`\\([^\`]*\\)\`.*/\\1/p" |
    sort >"$doc_list"

  dupes="$(sed '/^## Retired/,$d' docs/COMMAND-REGISTRY.md |
    sed -n "s/^- \`\\([^\`]*\\)\`.*/\\1/p" |
    sort |
    uniq -d)"
  if [ -n "$dupes" ]; then
    printf 'duplicate active registry entries:\n%s\n' "$dupes"
    missing=1
  fi

  stale="$(comm -13 "$bin_list" "$doc_list")"
  if [ -n "$stale" ]; then
    printf 'stale active registry entries:\n%s\n' "$stale"
    missing=1
  fi

  rm -f "$bin_list" "$doc_list"
  return "$missing"
}

license_alignment() {
  grep -Fq 'Apache License' LICENSE &&
    grep -Fq '"license": "Apache-2.0"' vscode/ai-cockpit/package.json &&
    grep -Fq 'Apache License' vscode/ai-cockpit/LICENSE.md
}

media_artifacts() {
  local missing=0
  for file in \
    docs/media/cockpit/01-readiness.png \
    docs/media/cockpit/02-first-run.png \
    docs/media/cockpit/03-route-receipt.png \
    docs/media/cockpit/04-browser-proof.png \
    docs/media/cockpit/05-composer.png \
    docs/media/cockpit/05-composer.gif \
    docs/media/cockpit/06-full-panel.png \
    docs/media/cockpit/06-package.png \
    docs/media/cockpit/states/08-state-continuation.png \
    docs/media/cockpit/states/09-state-running.png \
    docs/media/cockpit/states/10-state-success.png \
    docs/media/cockpit/states/11-state-blocked.png \
    docs/media/cockpit/states/12-state-permissions.png \
    docs/media/cockpit/states/13-state-route-receipt.png \
    docs/media/cockpit/states/manifest.json \
    docs/media/cockpit/interaction/interaction-proof.png \
    docs/media/cockpit/interaction/manifest.json \
    docs/media/cockpit/replay/manifest.json \
    docs/media/cockpit/walkthrough/ai-coding-os-walkthrough.mp4 \
    docs/media/cockpit/walkthrough/manifest.json \
    docs/media/cockpit/visual-baseline.json; do
    if [ ! -s "$file" ]; then
      printf 'missing media artifact: %s\n' "$file"
      missing=1
    fi
  done
  return "$missing"
}

personal_path_leaks() {
  local bad=0 users_path user_name pattern tmp files links
  users_path="$(printf '/%s/' Users)"
  user_name="$(id -un 2>/dev/null || true)"
  pattern="${users_path}[A-Za-z0-9._-]+"
  [ -n "$user_name" ] && pattern="$pattern|$user_name"
  tmp="$(mktemp "${TMPDIR:-/tmp}/cc-public-ci-paths.XXXXXX")"
  files="$(mktemp "${TMPDIR:-/tmp}/cc-public-ci-files.XXXXXX")"
  links="$(mktemp "${TMPDIR:-/tmp}/cc-public-ci-links.XXXXXX")"
  git ls-files -z -- bin vscode docs .github README.md .ai >"$files"
  if xargs -0 rg -n "$pattern" <"$files" >"$tmp" 2>/dev/null; then
    cat "$tmp"
    bad=1
  fi
  git ls-files -s |
    awk '$1 == "120000" {print $4}' |
    while IFS= read -r file; do
      target="$(readlink "$file" 2>/dev/null || git cat-file -p ":$file")"
      printf '%s:%s\n' "$file" "$target"
    done >"$links"
  if rg -n "$pattern" "$links" >"$tmp" 2>/dev/null; then
    cat "$tmp"
    bad=1
  fi
  rm -f "$tmp" "$files" "$links"
  return "$bad"
}

local_noise_not_tracked() {
  local bad=0 file
  while IFS= read -r file; do
    case "$file" in
    claude/wiki/learnings/_INDEX.md | \
      claude/wiki/learnings/_COMPOUND_INDEX.md | \
      claude/wiki/learnings/_compound-index.json | \
      claude/wiki/learnings/*/_README.md | \
      claude/wiki/learnings/*/_manifest.json)
      ;;
    claude/wiki/learnings/*)
      printf 'local learning corpus tracked: %s\n' "$file"
      bad=1
      ;;
    audits/20*.md | \
      claude/audits/digest-*.md | \
      claude/audits/drift-*.md | \
      claude/audits/memory-health-*.md | \
      claude/audits/mcp-probe-*.md)
      printf 'dated local audit report tracked: %s\n' "$file"
      bad=1
      ;;
    esac
  done < <(git ls-files claude/wiki/learnings audits claude/audits)
  return "$bad"
}

source_size_budget() {
  local bad=0 lines
  lines="$(wc -l <bin/cc-design-handoff | tr -d ' ')"
  if [ "$lines" -gt 1550 ]; then
    printf 'bin/cc-design-handoff too large: %s lines (max 1550); extract a module instead\n' "$lines"
    bad=1
  fi
  return "$bad"
}

cd "$ROOT" || exit 1

printf '# Public CI Check\n\n'
printf 'Root: %s\n' "$ROOT"

run "Git whitespace" git diff --check
run "Bash syntax" bash_syntax
run "Node syntax and JSON" node_syntax
run "Cockpit mission tests" cockpit_tests
run "Cockpit webview smoke" "$ROOT/bin/cc-cockpit-webview-smoke"
run "Cockpit visual diff" "$ROOT/bin/cc-cockpit-visual-diff"
run "Issue template YAML" issue_template_yaml
run "Required public docs" required_docs
run "Command registry complete" command_registry_complete
run "Package portability" "$ROOT/bin/cc-portability-check"
run "Benchmark source integrity" "$ROOT/bin/cc-benchmark-source-check"
run "Creative asset kit" "$ROOT/bin/cc-asset-kit-check"
run "Frontend wedge" "$ROOT/bin/cc-frontend-wedge-check"
run "Taste benchmark" "$ROOT/bin/cc-taste-benchmark-check"
run "Frontend demo" "$ROOT/bin/cc-frontend-demo"
run "Lane extension guide" "$ROOT/bin/cc-lane-extension-check"
run "Router degradation replay" "$ROOT/bin/cc-router-degradation-check"
run "Browser replay live readiness" "$ROOT/bin/cc-browser-replay-live-check"
run "Cockpit walkthrough media" "$ROOT/bin/cc-cockpit-walkthrough-check"
run "Trust adversarial fixtures" "$ROOT/bin/cc-trust-adversarial-check"
run "TEL policy proof" "$ROOT/bin/cc-tel-policy-check"
run "License alignment" license_alignment
run "Launch media present" media_artifacts
run "No personal path leaks" personal_path_leaks
run "No local-only corpus noise" local_noise_not_tracked
run "Source size budget" source_size_budget

printf '\n## Summary\n\n'
printf 'passed=%s failed=%s\n' "$pass" "$fail"

[ "$fail" -eq 0 ]
