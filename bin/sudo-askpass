#!/bin/bash
# Universal askpass for sudo. Resolves macOS account password by:
#   1. Trying 1Password CLI (biometric-unlocked, no plaintext anywhere)
#   2. Falling back to an osascript GUI prompt if 1P isn't ready
# Wired into /etc/sudoers.d/00-askpass so plain `sudo` honors it
# without programs needing to pass -A explicitly.
set -euo pipefail

# Resolve `op` to an absolute path so we work under sudo's reset PATH and
# under non-login subshells (playwright, hooks, claude code). Brew prefix on
# Apple Silicon is /opt/homebrew; Intel is /usr/local.
OP_BIN=""
for cand in /opt/homebrew/bin/op /usr/local/bin/op "$HOME/local/bin/op"; do
  [ -x "$cand" ] && { OP_BIN="$cand"; break; }
done
[ -z "$OP_BIN" ] && command -v op >/dev/null 2>&1 && OP_BIN="$(command -v op)"

# Try 1Password — needs Settings → Developer → "Integrate with 1Password CLI" enabled,
# and an item named "macOS" with a "password" field in your Personal vault.
# If OP_SERVICE_ACCOUNT_TOKEN is set, op uses it instead of biometric and never
# prompts — that is the path for full headless autonomy.
if [ -n "$OP_BIN" ]; then
  if pw=$("$OP_BIN" read 'op://Personal/macOS/password' 2>/dev/null) && [ -n "$pw" ]; then
    printf '%s' "$pw"
    exit 0
  fi
fi

# Fallback: GUI dialog (Touch ID kicks in via pam_tid for the sudo itself,
# this only fires if both 1P and Touch ID are unavailable)
osascript -e 'Tell application "System Events" to display dialog "macOS password (sudo):" default answer "" with hidden answer with title "sudo"' \
  -e 'text returned of result' 2>/dev/null
