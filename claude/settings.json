{
  "permissions": {
    "allow": [
      "Agent(*)",
      "AskUserQuestion(*)",
      "Bash",
      "Bash(*)",
      "Edit",
      "Edit(*)",
      "EnterPlanMode(*)",
      "ExitPlanMode(*)",
      "FetchURL(*)",
      "Glob",
      "Glob(*)",
      "Grep",
      "Grep(*)",
      "Read",
      "Read(*)",
      "Read(//**)",
      "SearchWeb(*)",
      "SetTodoList(*)",
      "Shell(*)",
      "Task",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "WebFetch",
      "WebFetch(*)",
      "WebSearch",
      "WebSearch(*)",
      "Write"
    ],
    "deny": [],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-resume.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/bootstrap-check.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/mcp-session-probe.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/tel-health.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/canon-guard-check.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-health.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/secret-paste-guard.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/environment-details.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/loop-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/context-monitor.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/error-gate.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/isa-nyquist-gate.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/nonstop.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/no-ask-human.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/wired-up-stop.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-handover.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/wiki-writeback.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/mempalace-stop.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/skill-metrics.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/ntfy-notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/leonardofibonacci/.claude/scripts/status-line.sh"
  },
  "enabledPlugins": {
    "claude-video-vision@claude-video-vision": false
  },
  "extraKnownMarketplaces": {
    "claude-video-vision": {
      "source": {
        "source": "git",
        "url": "https://github.com/jordanrendric/claude-video-vision.git"
      }
    }
  },
  "alwaysThinkingEnabled": false,
  "effortLevel": "xhigh",
  "showThinkingSummaries": false,
  "skipDangerousModePermissionPrompt": true,
  "switchModelsOnFlag": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "excludeDynamicSystemPromptSections": true,
  "mcpServers": {},
  "profiles": {
    "cc-router": {
      "env": {
        "ANTHROPIC_AUTH_TOKEN": "",
        "ANTHROPIC_BASE_URL": "http://127.0.0.1:9223",
        "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
        "API_TIMEOUT_MS": "300000",
        "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "50000",
        "CLAUDE_BASH_NO_LOGIN": "1"
      }
    }
  }
}