#!/usr/bin/env bash
# cc-image — generate images via OpenAI GPT-Image-2 with runtime API
# key injection from 1Password. Same runtime-injection pattern as
# cc-mercury and cc-langfuse-env: agent never persists credentials,
# the wrapper reads them at invocation in the user's shell.
#
# Usage:
#   cc-image "a brutalist landing page hero, axonometric isometric, sage and ochre"
#   cc-image -o ~/Desktop/hero.png "<prompt>"
#   cc-image -s 1024x1536 "<prompt>"            # portrait
#   cc-image -s 1536x1024 "<prompt>"            # landscape (default 1024x1024)
#   cc-image -q high "<prompt>"                  # high|medium|low (default high)
#   cc-image -n 4 "<prompt>"                     # generate 4 variants
#   cc-image --transparent "<prompt>"            # transparent background
#   cc-image --no-open "<prompt>"                # don't auto-open in Preview
#
# 1P item layout (one-time setup):
#   op item create --category="API Credential" --vault=Personal \
#     --title="OpenAI" credential[concealed]=sk-...
# Then: op://Personal/OpenAI/credential
#
# Output is timestamped under ~/.claude/images/ unless -o is given.
# /design composes with this — generated assets land somewhere /design's
# mockups can <img src=...> them.
set -euo pipefail

OUTDIR="${CC_IMAGE_OUTDIR:-$HOME/.claude/images}"
SIZE="1024x1024"
QUALITY="high"
N=1
TRANSPARENT=""
OPEN_AFTER=1
OUT_PATH=""

while [ $# -gt 0 ]; do
  case "$1" in
    -o|--output) OUT_PATH="$2"; shift 2 ;;
    -s|--size)   SIZE="$2"; shift 2 ;;
    -q|--quality) QUALITY="$2"; shift 2 ;;
    -n|--count)  N="$2"; shift 2 ;;
    --transparent) TRANSPARENT='"background": "transparent",'; shift ;;
    --no-open)   OPEN_AFTER=0; shift ;;
    -h|--help)   sed -n '2,30p' "$0"; exit 0 ;;
    *) break ;;
  esac
done

PROMPT="${*:-}"
[ -z "$PROMPT" ] && { echo "cc-image: prompt required" >&2; sed -n '2,30p' "$0" >&2; exit 2; }

# Resolve OpenAI key from 1P at runtime (no agent-context credential write)
OP_BIN=""
for c in /opt/homebrew/bin/op /usr/local/bin/op; do
  [ -x "$c" ] && { OP_BIN="$c"; break; }
done
if [ -z "${OPENAI_API_KEY:-}" ] && [ -n "$OP_BIN" ]; then
  OPENAI_API_KEY=$("$OP_BIN" read 'op://Personal/OpenAI/credential' 2>/dev/null) || true
fi
[ -n "${OPENAI_API_KEY:-}" ] || { echo "cc-image: OPENAI_API_KEY not in env and 1P read failed (op://Personal/OpenAI/credential)" >&2; exit 1; }

mkdir -p "$OUTDIR"
ts=$(date +%Y%m%d-%H%M%S)
slug=$(printf '%s' "$PROMPT" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '-' | sed 's/--*/-/g' | cut -c1-50 | sed 's/^-//;s/-$//')

# Build request body
body=$(python3 -c "
import json, sys
print(json.dumps({
    'model': 'gpt-image-2',
    'prompt': sys.argv[1],
    'size': sys.argv[2],
    'quality': sys.argv[3],
    'n': int(sys.argv[4]),
}))
" "$PROMPT" "$SIZE" "$QUALITY" "$N")
# Inject transparent background if requested (gpt-image-2 supports it)
[ -n "$TRANSPARENT" ] && body=$(printf '%s' "$body" | python3 -c "
import json, sys
d = json.load(sys.stdin)
d['background'] = 'transparent'
print(json.dumps(d))
")

echo "→ generating ${N} image(s) via gpt-image-2 (${SIZE}, ${QUALITY})..." >&2
resp=$(curl -fsSL -X POST https://api.openai.com/v1/images/generations \
  -H "Authorization: Bearer ${OPENAI_API_KEY}" \
  -H "Content-Type: application/json" \
  -d "$body")

# Decode each base64 image into a PNG
saved=()
echo "$resp" | python3 -c "
import json, sys, base64, os, pathlib
d = json.load(sys.stdin)
out_dir, ts, slug = sys.argv[1], sys.argv[2], sys.argv[3]
n = len(d.get('data', []))
for i, img in enumerate(d['data']):
    b64 = img.get('b64_json')
    if not b64:
        # API returned URL instead — fetch it
        import urllib.request
        url = img['url']
        b64 = base64.b64encode(urllib.request.urlopen(url).read()).decode()
    suffix = f'-{i+1}' if n > 1 else ''
    path = pathlib.Path(out_dir) / f'{ts}-{slug}{suffix}.png'
    path.write_bytes(base64.b64decode(b64))
    print(path)
" "$OUTDIR" "$ts" "$slug" | while read -r p; do saved+=("$p"); echo "  ✓ $p" >&2; done

# If user gave -o, also save to that path (first image only)
if [ -n "$OUT_PATH" ] && [ -n "${saved[0]:-}" ]; then
  cp "${saved[0]}" "$OUT_PATH"
  echo "  ✓ also at $OUT_PATH" >&2
fi

# Open in Preview unless suppressed
if [ "$OPEN_AFTER" -eq 1 ]; then
  for f in "$OUTDIR/${ts}-${slug}"*.png; do [ -f "$f" ] && open "$f"; done
fi
