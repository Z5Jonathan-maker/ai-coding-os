#!/usr/bin/env node
/**
 * cc-lane — inspect the AI lane registry.
 */
'use strict';

const fs = require('fs');
const os = require('os');
const path = require('path');

const root = process.env.DOTFILES || path.resolve(__dirname, '..');
const registryPath = process.env.CC_LANE_REGISTRY || path.join(root, 'ai-lanes.json');
const registry = JSON.parse(fs.readFileSync(registryPath, 'utf8'));
const lanes = new Map((registry.lanes || []).map((lane) => [lane.id, lane]));

function usage() {
  console.log('usage: cc-lane list | route <capability> | show <lane-id> | support <lane-id> <capability> | capabilities');
}

function printLane(lane) {
  const fallbackText = lane.fallbacks?.length ? lane.fallbacks.join(', ') : 'none';
  console.log(`${lane.id} [${lane.status}]`);
  console.log(`  role: ${lane.role}`);
  console.log(`  capabilities: ${(lane.capabilities || []).join(', ')}`);
  console.log(`  fallbacks: ${fallbackText}`);
  console.log(`  health: ${lane.health?.kind || 'unknown'}`);
}

const [cmd, arg, second] = process.argv.slice(2);

if (!cmd || cmd === 'help' || cmd === '--help' || cmd === '-h') {
  usage();
  process.exit(cmd ? 0 : 1);
}

if (cmd === 'list') {
  for (const lane of registry.lanes || []) {
    console.log(`${lane.id}\t${lane.status}\t${lane.role}`);
  }
  process.exit(0);
}

if (cmd === 'capabilities') {
  for (const name of Object.keys(registry.capabilities || {}).sort()) {
    const route = registry.capabilities[name];
    const fallbackText = route.fallbacks?.length ? ` -> ${route.fallbacks.join(' -> ')}` : '';
    console.log(`${name}\t${route.primary}${fallbackText}`);
  }
  process.exit(0);
}

if (cmd === 'show') {
  const lane = lanes.get(arg);
  if (!lane) {
    console.error(`unknown lane: ${arg || ''}`);
    process.exit(1);
  }
  printLane(lane);
  process.exit(0);
}

if (cmd === 'support') {
  const lane = lanes.get(arg);
  if (!lane) {
    console.error(`unknown lane: ${arg || ''}`);
    process.exit(1);
  }
  const capability = String(second || '').trim();
  if (!capability) {
    console.error('missing capability');
    process.exit(1);
  }
  if ((lane.unsupported || []).includes(capability)) {
    console.log(`${lane.id}: unsupported ${capability}`);
    process.exit(3);
  }
  if ((lane.capabilities || []).includes(capability)) {
    console.log(`${lane.id}: supports ${capability}`);
    process.exit(0);
  }
  const route = registry.capabilities?.[capability];
  if (route?.primary === lane.id || (route?.fallbacks || []).includes(lane.id)) {
    console.log(`${lane.id}: route-listed fallback for ${capability}`);
    process.exit(0);
  }
  console.log(`${lane.id}: not declared for ${capability}`);
  process.exit(2);
}

if (cmd === 'route') {
  const route = registry.capabilities?.[arg];
  if (!route) {
    console.error(`unknown capability: ${arg || ''}`);
    process.exit(1);
  }
  const fallbackText = route.fallbacks?.length ? ` -> ${route.fallbacks.join(' -> ')}` : '';
  console.log(`${arg}: ${route.primary}${fallbackText}`);
  if (route.noFallbackReason) console.log(`no fallback: ${route.noFallbackReason}`);
  process.exit(0);
}

usage();
process.exit(1);
