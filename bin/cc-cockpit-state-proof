capture() {
  local slug="$1" title="$2" subtitle="$3" primary="$4" detail="$5" accent="$6"
  local html="$tmp/$slug.html"
  local out="$OUT_DIR/$slug.png"
  write_page "$html" "$slug" "$title" "$subtitle" "$primary" "$detail" "$accent"
  playwright screenshot --channel chrome --viewport-size 1440,900 "file://$html" "$out" >/dev/null
  printf 'captured %s\n' "$out"
}

capture 08-state-continuation "Continue AI cockpit polish" "The app opens where the work already is. The primary action is continuation, not configuration." "Continue work" "Current mission, last session, next best step, and verification confidence are visible before any prompt box." "rgba(126, 94, 255, .56)"
capture 09-state-running "Workspace is executing" "The user sees calm progress and current intent while routing, tool calls, and verification happen underneath." "Working" "Running state exposes momentum, not raw logs. Stop remains available, but the machinery stays secondary." "rgba(66, 215, 199, .5)"
capture 10-state-success "Ready to ship" "The successful end state is proof-backed: changed files, tests, review, and the next safe action are all resolved." "Verified" "Success reads like closure. The cockpit shows evidence and keeps the next action obvious." "rgba(80, 227, 164, .48)"
capture 11-state-blocked "Permission needed" "Blocked does not feel broken. It explains the boundary, the reason, and the safest decision the user can make." "Review required" "Trust gates, paid actions, destructive commands, and cross-user actions surface as calm permission decisions." "rgba(255, 95, 126, .5)"
capture 12-state-permissions "Authority is explicit" "Permission mode is understandable at a glance: ask, review, or autopilot with the boundary made visible." "Review mode" "The system does not hide autonomy. It hides routine mechanics while keeping authority legible." "rgba(255, 209, 102, .5)"
capture 13-state-route-receipt "Route is explainable" "Routing is available as proof, not as the main workflow. The user can inspect selected lane, fallback, and cost." "Receipt ready" "The product feels singular while retaining inspectable receipts for developers who need trust evidence." "rgba(159, 140, 255, .58)"

OUT_DIR="$OUT_DIR" node <<'NODE'
const fs = require('fs');
const path = require('path');
const dir = process.env.OUT_DIR;
const files = [
  '08-state-continuation.png',
  '09-state-running.png',
  '10-state-success.png',
  '11-state-blocked.png',
  '12-state-permissions.png',
  '13-state-route-receipt.png',
];
const artifacts = files.map((file) => {
  const full = path.join(dir, file);
  const stat = fs.statSync(full);
  if (stat.size < 10000) throw new Error(`${file} is too small to be a valid state screenshot`);
  return { file, bytes: stat.size };
});
fs.writeFileSync(path.join(dir, 'manifest.json'), `${JSON.stringify({
  schema: 'ai-coding-os.cockpit-state-proof.v1',
  generated_at: new Date().toISOString(),
  viewport: '1440x900',
  artifacts,
}, null, 2)}\n`);
console.log('Status: cockpit-state-proof-passed');
NODE
