#!/usr/bin/env bash
# cc-langfuse-env — runtime env injection for Langfuse keys, then exec
# the requested command. Delegates to the shared local loader so shell
# startup and ad hoc commands resolve secrets the same way.
#
# Usage:
#   cc-langfuse-env claude                    # start claude with langfuse env loaded
#   cc-langfuse-env env | grep CC_LANGFUSE    # inspect what got loaded
#   cc-langfuse-env <any command>             # any command with the env present
#
set -euo pipefail

if [ -f "$HOME/.langfuse.local" ]; then
  # shellcheck source=/dev/null
  source "$HOME/.langfuse.local"
fi

export CC_LANGFUSE_BASE_URL="${CC_LANGFUSE_BASE_URL:-http://127.0.0.1:3000}"
export CC_LANGFUSE_TRACE_DEFAULT="${CC_LANGFUSE_TRACE_DEFAULT:-true}"
export LANGFUSE_PUBLIC_KEY="${LANGFUSE_PUBLIC_KEY:-${CC_LANGFUSE_PUBLIC_KEY:-}}"
export LANGFUSE_SECRET_KEY="${LANGFUSE_SECRET_KEY:-${CC_LANGFUSE_SECRET_KEY:-}}"
export LANGFUSE_BASE_URL="${LANGFUSE_BASE_URL:-$CC_LANGFUSE_BASE_URL}"

[ -n "${CC_LANGFUSE_PUBLIC_KEY:-}" ] || echo "cc-langfuse-env: warn — Langfuse public key unavailable" >&2
[ -n "${CC_LANGFUSE_SECRET_KEY:-}" ] || echo "cc-langfuse-env: warn — Langfuse secret key unavailable" >&2

exec "$@"
