      display: grid;
      grid-template-columns: 1.2fr .8fr;
      gap: 18px;
    }
    .state-proof-panel {
      min-height: 184px;
      padding: 22px;
      border: 1px solid rgba(255,255,255,.09);
      border-radius: 24px;
      background: rgba(12,16,31,.58);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 24px 60px rgba(0,0,0,.22);
    }
    .state-proof-panel h2 { margin: 0 0 12px; font-size: 18px; }
