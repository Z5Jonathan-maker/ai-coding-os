#!/usr/bin/env bash
# Fetch the latest GitHub email verification code from Mail.app.
#
# Used by gh-auto-auth when GitHub's OAuth flow redirects to a
# "sudo email verification code" page (triggered by sensitive scopes
# like `user` or by GitHub's session-elevation policy).
#
# Polls until a fresh code arrives or timeout. Prints the 8-digit code
# on stdout, nothing on stderr. Exit 0 on success, non-zero otherwise.
#
# Usage:
#   gh-mail-code                # latest, no waiting
#   gh-mail-code --since-now    # wait up to 60s for a NEW email after now
#   gh-mail-code --timeout=120  # custom poll window
set -euo pipefail

SINCE_NOW=0
TIMEOUT=60
for arg in "$@"; do
  case "$arg" in
    --since-now) SINCE_NOW=1 ;;
    --timeout=*) TIMEOUT="${arg#--timeout=}" ;;
  esac
done

# Capture wall-clock so we can detect "newer than this" emails
START_TS=$(date +%s)

read_latest_code() {
  /usr/bin/osascript <<'APPLESCRIPT'
tell application "Mail"
  try
    set ghMsgs to (messages of inbox whose sender contains "noreply@github.com")
    if (count of ghMsgs) is 0 then return ""
    set m to item 1 of ghMsgs
    set body to content of m
    set ts to (date received of m) as string
    return ts & "|||" & body
  on error
    return ""
  end try
end tell
APPLESCRIPT
}

extract_code() {
  # GitHub verification codes are 6-8 contiguous digits, usually on their own line
  /usr/bin/grep -oE '\b[0-9]{6,8}\b' | head -1
}

elapsed=0
last_code=""
while [ "$elapsed" -lt "$TIMEOUT" ]; do
  out=$(read_latest_code)
  if [ -n "$out" ]; then
    msg_ts="${out%%|||*}"
    msg_body="${out#*|||}"
    msg_epoch=$(date -j -f "%A, %B %d, %Y at %l:%M:%S %p" "$msg_ts" +%s 2>/dev/null || echo 0)
    if [ "$SINCE_NOW" -eq 0 ] || [ "$msg_epoch" -ge "$START_TS" ]; then
      code=$(printf '%s\n' "$msg_body" | extract_code)
      if [ -n "$code" ] && [ "$code" != "$last_code" ]; then
        printf '%s\n' "$code"
        exit 0
      fi
      last_code="$code"
    fi
  fi
  sleep 3
  elapsed=$((elapsed + 3))
done

echo "timeout: no GitHub verification code found in $TIMEOUT s" >&2
exit 1
