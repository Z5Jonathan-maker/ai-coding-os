#!/usr/bin/env bash
# cc-prune — disk hygiene for ~/.claude/.
#
# A 24/7 box that never reboots will eventually fill the SSD with debug
# logs, project history, file snapshots, and old checkpoints — at which
# point Claude Code's auth state corrupts and everything stops. This
# prunes pre-emptively.
#
# Defaults (override via env):
#   CC_PRUNE_DEBUG_DAYS=14         keep last 14d of ~/.claude/debug/
#   CC_PRUNE_PROJECTS_DAYS=30      keep last 30d of project transcripts
#   CC_PRUNE_HISTORY_DAYS=14       keep last 14d of file-history snapshots
#   CC_PRUNE_CHECKPOINTS_KEEP=50   keep most-recent 50 checkpoints
#   CC_PRUNE_LOG_MAX_MB=50         truncate cc-loop.log if > N MB
#   CC_PRUNE_DRY_RUN=0             1 = print what would be removed
#
# Run via launchd (com.user.cc-prune.plist, daily) or manually.
set -u

CC_PRUNE_DEBUG_DAYS="${CC_PRUNE_DEBUG_DAYS:-14}"
CC_PRUNE_PROJECTS_DAYS="${CC_PRUNE_PROJECTS_DAYS:-30}"
CC_PRUNE_HISTORY_DAYS="${CC_PRUNE_HISTORY_DAYS:-14}"
CC_PRUNE_CHECKPOINTS_KEEP="${CC_PRUNE_CHECKPOINTS_KEEP:-50}"
CC_PRUNE_LOG_MAX_MB="${CC_PRUNE_LOG_MAX_MB:-50}"
CC_PRUNE_DRY_RUN="${CC_PRUNE_DRY_RUN:-0}"

CLAUDE_DIR="$HOME/.claude"
LOG_FILE="$CLAUDE_DIR/cc-prune.log"
mkdir -p "$CLAUDE_DIR"

log() {
  local line
  line="$(date '+%Y-%m-%d %H:%M:%S') $*"
  echo "$line" | tee -a "$LOG_FILE"
}

run() {
  if [ "$CC_PRUNE_DRY_RUN" = "1" ]; then
    log "[DRY-RUN] $*"
  else
    "$@"
  fi
}

human_size() {
  du -sh "$1" 2>/dev/null | awk '{print $1}'
}

prune_by_age() {
  local dir="$1" days="$2" pattern="$3"
  [ -d "$dir" ] || return
  local before
  before=$(human_size "$dir")
  local count
  count=$(find "$dir" -type f -name "$pattern" -mtime "+$days" 2>/dev/null | wc -l | tr -d ' ')
  if [ "$count" -gt 0 ]; then
    if [ "$CC_PRUNE_DRY_RUN" = "1" ]; then
      log "[DRY-RUN] would remove $count files older than ${days}d in $dir (was: $before)"
    else
      find "$dir" -type f -name "$pattern" -mtime "+$days" -delete 2>/dev/null
      local after
      after=$(human_size "$dir")
      log "pruned $count files >${days}d in $dir (${before} → ${after})"
    fi
  fi
  # Also remove empty subdirs to keep tree tidy
  [ "$CC_PRUNE_DRY_RUN" != "1" ] && find "$dir" -type d -empty -mindepth 1 -delete 2>/dev/null || true
}

prune_checkpoints() {
  local dir="$CLAUDE_DIR/checkpoints"
  [ -d "$dir" ] || return
  local total
  total=$(ls "$dir"/*.md 2>/dev/null | wc -l | tr -d ' ')
  [ "$total" -le "$CC_PRUNE_CHECKPOINTS_KEEP" ] && return
  local to_remove
  to_remove=$((total - CC_PRUNE_CHECKPOINTS_KEEP))
  if [ "$CC_PRUNE_DRY_RUN" = "1" ]; then
    log "[DRY-RUN] would remove $to_remove oldest checkpoints (keep $CC_PRUNE_CHECKPOINTS_KEEP of $total)"
  else
    ls -t "$dir"/*.md | tail -n "$to_remove" | xargs rm -f
    log "pruned $to_remove oldest checkpoints (kept $CC_PRUNE_CHECKPOINTS_KEEP)"
  fi
}

truncate_large_log() {
  local f="$1" max_mb="$2"
  [ -f "$f" ] || return
  local size_mb
  size_mb=$(du -m "$f" | awk '{print $1}')
  if [ "$size_mb" -gt "$max_mb" ]; then
    if [ "$CC_PRUNE_DRY_RUN" = "1" ]; then
      log "[DRY-RUN] would truncate $f (${size_mb}MB > ${max_mb}MB)"
    else
      # Keep last 10MB of content
      tail -c 10485760 "$f" >"$f.tmp" && mv "$f.tmp" "$f"
      log "truncated $f from ${size_mb}MB → ~10MB"
    fi
  fi
}

main() {
  log "cc-prune START dry_run=$CC_PRUNE_DRY_RUN"
  log "  before: ~/.claude = $(human_size "$CLAUDE_DIR")"

  prune_by_age "$CLAUDE_DIR/debug" "$CC_PRUNE_DEBUG_DAYS" '*.txt'
  prune_by_age "$CLAUDE_DIR/projects" "$CC_PRUNE_PROJECTS_DAYS" '*.jsonl'
  prune_by_age "$CLAUDE_DIR/file-history" "$CC_PRUNE_HISTORY_DAYS" '*'
  prune_checkpoints

  truncate_large_log "$CLAUDE_DIR/cc-loop.log" "$CC_PRUNE_LOG_MAX_MB"
  truncate_large_log "$CLAUDE_DIR/executor.log" "$CC_PRUNE_LOG_MAX_MB"
  truncate_large_log "$LOG_FILE" "$CC_PRUNE_LOG_MAX_MB"

  log "  after:  ~/.claude = $(human_size "$CLAUDE_DIR")"
  log "cc-prune DONE"
}

main "$@"
