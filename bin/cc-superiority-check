#!/usr/bin/env node
'use strict';

const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');

const root = process.env.DOTFILES || (() => {
  const res = spawnSync('git', ['rev-parse', '--show-toplevel'], { encoding: 'utf8' });
  return res.status === 0 ? res.stdout.trim() : process.cwd();
})();

const args = process.argv.slice(2);
const prove = args.includes('--prove');
const docPath = path.join(root, 'docs', 'SUPERIORITY-MATRIX.md');
const fixturesDir = path.join(root, 'fixtures', 'benchmarks');

const competitors = [
  'OpenHands',
  'Claude Code',
  'Cursor',
  'Cline',
  'OpenCode',
  'Kimi',
  'Codex',
  'Windsurf',
  'Devin',
  'Octagents',
  'Triple-router',
];

const requiredCommands = [
  'cc-demo-quick',
  'cc-benchmark-fixtures',
  'cc-benchmark-run',
  'cc-router-degradation-check',
  'cc-token-ledger',
  'cc-trust-gate',
  'cc-mission-ledger',
  'cc-creative-kernel-check',
  'cc-lane-extension-check',
  'cc-browser-replay-check',
  'cc-browser-replay-live-check',
  'cc-browser-visual-proof',
  'cc-cockpit-webview-smoke',
  'cc-cockpit-replay-bundle-check',
  'cc-cockpit-walkthrough-check',
  'cc-release-artifact-check',
  'cc-pr-quality-score',
  'cc-verify-product',
  'cc-ten-readiness',
];

const requiredDimensions = [
  'Routing/orchestration',
  'Output-quality benchmarks',
  'Trust and permissions',
  'Token and cost efficiency',
  'Persistent memory and continuation',
  'Browser/UI lane',
  'Cockpit product UX',
  'Creative direction kernel',
  'Daily-driver workflow',
  'Autonomous loops',
  'Extensibility',
  'Public evaluator experience',
  'Competitive clarity',
];

function fail(message) {
  console.error(`fail ${message}`);
  failures += 1;
}

function ok(message) {
  console.log(`ok   ${message}`);
  passes += 1;
}

function readJson(file) {
  return JSON.parse(fs.readFileSync(file, 'utf8'));
}

function countGradedFixtures() {
  if (!fs.existsSync(fixturesDir)) return 0;
  return fs.readdirSync(fixturesDir)
    .map((name) => path.join(fixturesDir, name, 'benchmark.json'))
    .filter((file) => fs.existsSync(file))
    .filter((file) => {
      const m = readJson(file);
      return Boolean(m.expectedPatch || m.scoreBefore || m.scoreAfter);
    }).length;
}

function run(command) {
  const started = Date.now();
  const res = spawnSync(command, {
    cwd: root,
    shell: true,
    encoding: 'utf8',
    env: { ...process.env, DOTFILES: root },
  });
  const output = `${res.stdout || ''}${res.stderr || ''}`;
  if (res.status === 0) {
    ok(`${command} (${Date.now() - started}ms)`);
  } else {
    fail(`${command} exited ${res.status}`);
    console.error(output.split('\n').slice(0, 60).map((line) => `     ${line}`).join('\n'));
  }
}

let passes = 0;
let failures = 0;

console.log('# Superiority Matrix Check\n');
console.log(`Root: ${root}`);
console.log(`Doc: ${docPath}\n`);

if (!fs.existsSync(docPath)) {
  fail('docs/SUPERIORITY-MATRIX.md exists');
} else {
  ok('docs/SUPERIORITY-MATRIX.md exists');
  const doc = fs.readFileSync(docPath, 'utf8');
  for (const competitor of competitors) {
    const pattern = new RegExp(competitor.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'i');
    pattern.test(doc) ? ok(`mentions ${competitor}`) : fail(`mentions ${competitor}`);
  }
  for (const command of requiredCommands) {
    doc.includes(command) ? ok(`mentions ${command}`) : fail(`mentions ${command}`);
  }
  for (const dimension of requiredDimensions) {
    doc.includes(dimension) ? ok(`covers ${dimension}`) : fail(`covers ${dimension}`);
  }
  doc.includes('Missing Proof') ? ok('tracks missing proof honestly') : fail('tracks missing proof honestly');
  doc.includes('Non-Negotiable Gaps') ? ok('declares non-negotiable gaps') : fail('declares non-negotiable gaps');
}

const graded = countGradedFixtures();
if (graded >= 3) ok(`graded benchmark fixtures >= 3 (${graded})`);
else fail(`graded benchmark fixtures >= 3 (${graded})`);

if (prove) {
  console.log('\n## Proof Commands\n');
  [
    'bin/cc-benchmark-run failing-test-repair',
    'bin/cc-benchmark-run refactor-cleanup',
    'bin/cc-benchmark-run long-context',
    'bin/cc-benchmark-run routing-pr-quality',
    'bin/cc-benchmark-run upstream-issue-replay',
    'bin/cc-router-degradation-check',
    'bin/cc-token-ledger --check',
    'bin/cc-trust-gate --check',
    'bin/cc-mission-ledger --check',
    'bin/cc-creative-kernel-check',
    'bin/cc-lane-extension-check',
    'bin/cc-browser-replay-check',
    'bin/cc-browser-replay-live-check',
    'bin/cc-browser-visual-proof --check',
    'bin/cc-cockpit-webview-smoke',
    'bin/cc-cockpit-replay-bundle-check',
    'bin/cc-cockpit-walkthrough-check',
    'bin/cc-release-artifact-check',
    'bin/cc-pr-quality-score --check',
  ].forEach(run);
}

console.log('\n## Summary\n');
console.log(`passed=${passes} failed=${failures}`);
console.log(failures ? 'Status: superiority-matrix-blocked' : 'Status: superiority-matrix-ready');
process.exit(failures ? 1 : 0);
