  actionPacket,
  activePhase,
  addCheckpointRecord,
  addMissionGitRecord,
  appendTimeline,
  artifactPath,
  completionStageFor,
  createPhaseCheckpoint,
  event,
  extractAsset,
  generateCreativeReference,
  has,
  loadMission,
  markComplete,
  missionDir,
  nextActionFor,
  now,
  path,
  phaseById,
  readJson,
  recordMissionGit,
  refreshProof,
  requestStageFor,
  reviewPassed,
  root,
  updateContextSummary,
  updateCostLedger,
  value,
  writeDeployReceipt,
  writeJson,
  writeStageArtifact,
});

if (has('check')) runDesignHandoffCheck({ root, run });
else if (subcommand === 'list') listMissions();
else if (subcommand === 'status') showStatus();
else if (subcommand === 'continue') continueMission();
else if (subcommand === 'approve') approvePhase();
else if (subcommand === 'execute') executeStage();
else createHandoff();
