<?xml version="1.0" encoding="UTF-8"?>
<!--
  Daily prune of ~/.claude/ at 04:30 local. Quick, idempotent, won't
  trip on a reboot. Install:
    cp ~/dotfiles/launchd/com.user.cc-prune.plist ~/Library/LaunchAgents/
    launchctl load -w ~/Library/LaunchAgents/com.user.cc-prune.plist
  Verify next-run time:
    launchctl list | grep com.user.cc-prune
  Logs:
    ~/.claude/cc-prune.log
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.user.cc-prune</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/leonardofibonacci/dotfiles/bin/cc-prune</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>4</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/leonardofibonacci/.claude/cc-prune.stdout</string>
  <key>StandardErrorPath</key>
  <string>/Users/leonardofibonacci/.claude/cc-prune.stderr</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>HOME</key>
    <string>/Users/leonardofibonacci</string>
  </dict>
</dict>
</plist>
