[user]
	name = Jonathan Cimadevilla
	email = z5jonathan@icloud.com
	signingkey = ~/.ssh/id_ed25519.pub
[init]
	defaultBranch = main
[pull]
	rebase = true
[push]
	autoSetupRemote = true
	default = simple
	followTags = true
[core]
	editor = code --wait
	excludesfile = /Users/leonardofibonacci/.gitignore_global
	pager = delta
	fsmonitor = true
	untrackedCache = true
[rebase]
	autosquash = true
	autostash = true
[fetch]
	prune = true
[diff]
	algorithm = histogram
	tool = difftastic
	colorMoved = plain
	colorMovedWS = allow-indentation-change
[merge]
	conflictstyle = zdiff3
	tool = vimdiff
[rerere]
	enabled = true
[color]
	ui = auto
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
	syntax-theme = Monokai Extended
[difftool "difftastic"]
	cmd = difft \"$LOCAL\" \"$REMOTE\"
[difftool]
	prompt = false
[column]
	ui = auto
[branch]
	sort = -committerdate
[tag]
	sort = version:refname
[alias]
	dft = difftool
	lg = log --oneline --graph --decorate -20
	lga = log --oneline --graph --decorate --all -30
	st = status
	co = checkout
	br = branch
	ci = commit
	amend = commit --amend --no-edit
	fixup = commit --fixup
	squash = commit --squash
	undo = reset --soft HEAD~1
	unstage = reset HEAD --
	last = log -1 HEAD
	aliases = config --get-regexp alias
	recent = branch --sort=-committerdate --format='%(committerdate:relative)%09%(refname:short)' -10
	bc = !git branch --merged | grep -v '\\*' | grep -v main | grep -v master | xargs -r git branch -d
[credential "https://github.com"]
	helper = 
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !gh auth git-credential
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
