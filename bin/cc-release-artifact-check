#!/usr/bin/env bash
set -euo pipefail

DOTFILES="${DOTFILES:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
version="${1:-v0.1.0-rc8}"
dist="$DOTFILES/dist"
bundle="$dist/ai-coding-os-${version}.tar.gz"
checksum="$bundle.sha256"
pass=0
fail=0

run() {
  local name="$1"
  shift
  printf '\n## %s\n' "$name"
  if "$@" >/tmp/cc-release-artifact-check.$$ 2>&1; then
    printf 'ok   %s\n' "$name"
    pass=$((pass + 1))
  else
    printf 'fail %s\n' "$name"
    sed 's/^/     /' /tmp/cc-release-artifact-check.$$ | sed -n '1,80p'
    fail=$((fail + 1))
  fi
  rm -f /tmp/cc-release-artifact-check.$$
}

bundle_exists() {
  [ -s "$bundle" ] && [ -s "$checksum" ]
}

checksum_valid() {
  cd "$dist"
  shasum -a 256 -c "$(basename "$checksum")"
}

bundle_contents() {
  local list
  list="$(tar -tzf "$bundle")"
  printf '%s\n' "$list" | grep -Fq "ai-coding-os-${version}/BUNDLE-README.md"
  printf '%s\n' "$list" | grep -Fq "ai-coding-os-${version}/ai-system-cockpit-0.1.0.vsix"
  printf '%s\n' "$list" | grep -Fq "ai-coding-os-${version}/docs/EVALUATOR-QUICKSTART.md"
  printf '%s\n' "$list" | grep -Fq "ai-coding-os-${version}/docs/CI.md"
  printf '%s\n' "$list" | grep -Fq "ai-coding-os-${version}/docs/RELEASE-MANIFEST-${version}.md"
  printf '%s\n' "$list" | grep -Fq "ai-coding-os-${version}/media/cockpit/01-readiness.png"
  printf '%s\n' "$list" | grep -Fq "ai-coding-os-${version}/media/cockpit/walkthrough/ai-coding-os-walkthrough.mp4"
  printf '%s\n' "$list" | grep -Fq "ai-coding-os-${version}/media/cockpit/walkthrough/manifest.json"
}

bundle_readme_contract() {
  tar -xOzf "$bundle" "ai-coding-os-${version}/BUNDLE-README.md" |
    grep -Fq 'Verification command in repo: `cc-evaluator-check`'
}

printf '# Release Artifact Check\n\n'
printf 'Root: %s\n' "$DOTFILES"
printf 'Version: %s\n' "$version"

cd "$DOTFILES" || exit 1

run "Build release bundle" "$DOTFILES/bin/cc-release-bundle" "$version"
run "Bundle and checksum exist" bundle_exists
run "Checksum validates" checksum_valid
run "Bundle contains evaluator assets" bundle_contents
run "Bundle README names verification command" bundle_readme_contract

printf '\n## Summary\n\n'
printf 'passed=%s failed=%s\n' "$pass" "$fail"
printf '%s\n' "$([ "$fail" -eq 0 ] && printf 'Status: release-artifact-ready' || printf 'Status: release-artifact-blocked')"

[ "$fail" -eq 0 ]
