#!/usr/bin/env bash
# Fetch the latest verification/OTP code from a Mail.app email matching a
# sender filter. Polls until a fresh code arrives or timeout.
#
# Used by any auth flow that emails OTP codes — GitHub, AWS, Cloudflare,
# Stripe, banks, etc. Mail.app must be running and signed in to the iCloud
# account that receives the codes.
#
# Usage:
#   mail-code <sender-substring> [--since-now] [--timeout=N] [--digits=MIN-MAX]
#
# Examples:
#   mail-code github.com                   # latest code from any github.com sender
#   mail-code github.com --since-now       # wait up to 60s for a NEW email
#   mail-code aws.amazon.com --timeout=120
#   mail-code stripe.com --digits=6        # exactly 6 digits
#   mail-code cloudflare.com --digits=6-8  # 6 to 8 digits
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "usage: mail-code <sender-substring> [--since-now] [--timeout=N] [--digits=MIN-MAX]" >&2
  exit 2
fi

SENDER="$1"; shift
SINCE_NOW=0
TIMEOUT=60
DIGITS_MIN=6
DIGITS_MAX=8
for arg in "$@"; do
  case "$arg" in
    --since-now) SINCE_NOW=1 ;;
    --timeout=*) TIMEOUT="${arg#--timeout=}" ;;
    --digits=*)
      spec="${arg#--digits=}"
      if [[ "$spec" == *-* ]]; then
        DIGITS_MIN="${spec%-*}"
        DIGITS_MAX="${spec#*-}"
      else
        DIGITS_MIN="$spec"
        DIGITS_MAX="$spec"
      fi
      ;;
  esac
done

START_TS=$(date +%s)

SCAN_LIMIT=10  # how many recent emails per sender to inspect for a code

# Returns N most recent matching messages, one per line: "epoch|||body"
read_recent() {
  local sender="$1" limit="$2"
  /usr/bin/osascript <<APPLESCRIPT
tell application "Mail"
  try
    set msgs to (messages of inbox whose sender contains "$sender")
    set total to (count of msgs)
    if total is 0 then return ""
    set scanN to $limit
    if total < scanN then set scanN to total
    set out to ""
    repeat with i from 1 to scanN
      set m to item i of msgs
      set out to out & ((date received of m) as string) & "|||" & (content of m) & "@@@END@@@"
    end repeat
    return out
  on error
    return ""
  end try
end tell
APPLESCRIPT
}

extract_code() {
  /usr/bin/grep -oE "\\b[0-9]{${DIGITS_MIN},${DIGITS_MAX}}\\b" | head -1
}

# Scan all-recent. Filter to "since-now" if set. Return first valid code.
scan_for_code() {
  local raw="$1" since_now="$2" start_ts="$3"
  IFS=$'\n' read -r -d '' -a msgs < <(printf '%s' "$raw" | tr '\f' '\n' | awk -v RS='@@@END@@@' '{print}' && printf '\0')
  for msg in "${msgs[@]}"; do
    [ -z "$msg" ] && continue
    local ts="${msg%%|||*}"
    local body="${msg#*|||}"
    local epoch
    epoch=$(date -j -f "%A, %B %d, %Y at %l:%M:%S %p" "$ts" +%s 2>/dev/null || echo 0)
    if [ "$since_now" -eq 1 ] && [ "$epoch" -lt "$start_ts" ]; then
      continue
    fi
    local code
    code=$(printf '%s\n' "$body" | extract_code)
    if [ -n "$code" ]; then
      printf '%s\n' "$code"
      return 0
    fi
  done
  return 1
}

# Fast path: non-poll mode — read once and bail
if [ "$SINCE_NOW" -eq 0 ]; then
  raw=$(read_recent "$SENDER" "$SCAN_LIMIT")
  if scan_for_code "$raw" 0 0; then exit 0; fi
  echo "no code found in $SCAN_LIMIT most recent emails from '$SENDER'" >&2
  exit 1
fi

# Poll path: --since-now, wait for a fresh email
elapsed=0
while [ "$elapsed" -lt "$TIMEOUT" ]; do
  raw=$(read_recent "$SENDER" "$SCAN_LIMIT")
  if scan_for_code "$raw" 1 "$START_TS"; then exit 0; fi
  sleep 3
  elapsed=$((elapsed + 3))
done

echo "timeout: no fresh code from sender '$SENDER' in ${TIMEOUT}s" >&2
exit 1
