#!/usr/bin/env bash
# shellcheck disable=SC2016
set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/dotfiles}"
version="${1:-v0.1.0-rc8}"
dist="$DOTFILES/dist"
bundle="$dist/ai-coding-os-${version}.tar.gz"
staging="$(mktemp -d "${TMPDIR:-/tmp}/cc-release-bundle.XXXXXX")"
root="$staging/ai-coding-os-${version}"

cleanup() {
  rm -rf "$staging"
}
trap cleanup EXIT

sha256() {
  shasum -a 256 "$1" | awk '{print $1}'
}

copy_required() {
  local src="$1" dst="$2"
  if [ ! -s "$src" ]; then
    printf 'missing required file: %s\n' "$src" >&2
    exit 1
  fi
  mkdir -p "$(dirname "$dst")"
  cp "$src" "$dst"
}

cd "$DOTFILES"
mkdir -p "$dist" "$root/docs" "$root/media/cockpit"

"$DOTFILES/bin/cc-package-cockpit" >/dev/null
CC_RELEASE_MANIFEST_OUT="$root/docs/RELEASE-MANIFEST-${version}.md" "$DOTFILES/bin/cc-release-manifest" "$version" >/dev/null

copy_required "$dist/ai-system-cockpit-0.1.0.vsix" "$root/ai-system-cockpit-0.1.0.vsix"
release_notes="$DOTFILES/docs/RELEASE-NOTES-${version}.md"
release_candidate="$DOTFILES/docs/RELEASE-CANDIDATE-${version}.md"
[ -s "$release_notes" ] || release_notes="$DOTFILES/docs/RELEASE-NOTES.md"
[ -s "$release_candidate" ] || release_candidate="$DOTFILES/docs/RELEASE-CANDIDATE.md"

copy_required "$release_notes" "$root/docs/RELEASE-NOTES.md"
copy_required "$release_candidate" "$root/docs/RELEASE-CANDIDATE.md"
copy_required "$DOTFILES/docs/EVALUATOR-QUICKSTART.md" "$root/docs/EVALUATOR-QUICKSTART.md"
copy_required "$DOTFILES/docs/CI.md" "$root/docs/CI.md"
copy_required "$DOTFILES/README.md" "$root/README.md"
copy_required "$DOTFILES/LICENSE" "$root/LICENSE"

while IFS= read -r media; do
  copy_required "$media" "$root/media/cockpit/$(basename "$media")"
done < <(find "$DOTFILES/docs/media/cockpit" -maxdepth 1 -type f \( -name '*.png' -o -name '*.gif' \) | sort)

{
  printf '# ai-coding-os-%s\n\n' "$version"
  printf 'Install artifact: `ai-system-cockpit-0.1.0.vsix`\n'
  printf 'Verification command in repo: `cc-evaluator-check`\n'
  printf 'Integrity manifest: `docs/RELEASE-MANIFEST-%s.md`\n' "$version"
} >"$root/BUNDLE-README.md"

tar -C "$staging" -czf "$bundle" "ai-coding-os-${version}"
(cd "$dist" && shasum -a 256 "$(basename "$bundle")" >"$(basename "$bundle").sha256")

printf 'Bundle: %s\n' "$bundle"
printf 'Bytes: %s\n' "$(wc -c <"$bundle" | tr -d ' ')"
printf 'SHA-256: %s\n' "$(sha256 "$bundle")"
printf 'Checksum file: %s\n' "$bundle.sha256"
