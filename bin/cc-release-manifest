#!/usr/bin/env bash
# shellcheck disable=SC2016
set -euo pipefail

DOTFILES="${DOTFILES:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
version="${1:-v0.1.0-rc8}"
out="${CC_RELEASE_MANIFEST_OUT:-$DOTFILES/docs/RELEASE-MANIFEST-${version}.md}"
package="$DOTFILES/dist/ai-system-cockpit-0.1.0.vsix"

sha256() {
  shasum -a 256 "$1" | awk '{print $1}'
}

bytes() {
  wc -c <"$1" | tr -d ' '
}

row() {
  local file="$1" rel
  rel="${file#"$DOTFILES"/}"
  printf '| `%s` | %s | `%s` |\n' "$rel" "$(bytes "$file")" "$(sha256 "$file")"
}

cd "$DOTFILES"

if [ ! -s "$package" ]; then
  "$DOTFILES/bin/cc-package-cockpit" >/dev/null
fi

mkdir -p "$(dirname "$out")"

{
  printf '# RELEASE-MANIFEST-%s.md\n\n' "$version"
  printf 'Generated: %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  printf 'Release: `%s`\n' "$version"

  printf '\n## Checks\n\n'
  printf '%s\n' '- `cc-public-ci-check`: portable public validation'
  printf '%s\n' '- `cc-release-check`: local machine release validation'

  printf '\n## Artifacts\n\n'
  printf '| Path | Bytes | SHA-256 |\n'
  printf '|---|---:|---|\n'
  row "$package"
  while IFS= read -r file; do
    row "$file"
  done < <(find "$DOTFILES/docs/media/cockpit" -type f \( -name '*.png' -o -name '*.gif' -o -name '*.mp4' -o -name 'manifest.json' \) | sort)

  printf '\n## Notes\n\n'
  printf '%s\n' '- The VSIX is generated under `dist/` by `cc-package-cockpit` and is not tracked.'
  printf '%s\n' '- Cockpit media is tracked under `docs/media/cockpit/` and regenerated by `cc-cockpit-capture`.'
  printf '%s\n' '- Browser mode remains documented separately in `docs/BROWSER-AUTOMATION-TRUTH-TABLE.md`.'
} >"$out"

printf 'Wrote %s\n' "$out"
