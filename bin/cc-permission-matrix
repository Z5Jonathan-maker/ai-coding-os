#!/usr/bin/env bash
# cc-permission-matrix — visible autonomy boundaries for the AI cockpit.
set -u

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES="${DOTFILES:-$(cd "$SCRIPT_DIR/.." && pwd)}"
ROOT="${AI_SYSTEM_ROOT:-$HOME/AI-SYSTEM-V2}"
POLICY="${AI_PERMISSION_POLICY:-$ROOT/configs/permission-policy.json}"
MODE_FILE="${AI_PERMISSION_MODE_FILE:-$ROOT/configs/permission-mode.json}"
TRUST="${CC_TRUST_PROFILE:-$DOTFILES/.ai/trust.json}"
TRUST_GATE="$DOTFILES/bin/cc-trust-gate"

section() {
  printf '\n## %s\n\n' "$1"
}

policy_json_value() {
  node -e "
const fs=require('fs');
try {
  const p=JSON.parse(fs.readFileSync(process.argv[1],'utf8'));
  const path=process.argv[2].split('.');
  let v=p;
  for (const k of path) v=v && v[k];
  if (Array.isArray(v)) console.log(v.length);
  else if (v !== undefined) console.log(v);
} catch (_) {}
" "$1" "$2"
}

trust_value() {
  policy_json_value "$TRUST" "$1"
}

trust_rule_count() {
  node -e "
const fs=require('fs');
try {
  const t=JSON.parse(fs.readFileSync(process.argv[1],'utf8'));
  const deny=[
    t.allow_secrets === false,
    t.destructive_actions === 'deny'
  ].filter(Boolean).length;
  const review=[
    t.allow_network === 'ask',
    t.allow_browser_profile === 'ask',
    t.public_publish === 'review',
    t.paid_actions === 'review',
    t.credentialed_actions === 'tel-only'
  ].filter(Boolean).length;
  console.log(process.argv[2] === 'deny' ? deny : review);
} catch (_) {
  console.log('0');
}
" "$TRUST" "$1"
}

mode_json="$(node -e "
const fs=require('fs');
try { console.log(JSON.stringify(JSON.parse(fs.readFileSync(process.argv[1],'utf8')))); }
catch (_) { console.log(JSON.stringify({mode:'strict',source:'default'})); }
" "$MODE_FILE")"

mode="$(printf '%s' "$mode_json" | node -e "let s='';process.stdin.on('data',d=>s+=d);process.stdin.on('end',()=>{const m=JSON.parse(s);console.log(m.mode||'strict')})")"
updated="$(printf '%s' "$mode_json" | node -e "let s='';process.stdin.on('data',d=>s+=d);process.stdin.on('end',()=>{const m=JSON.parse(s);console.log(m.updated_at||'default')})")"
checker="$ROOT/scripts/permission-check.cjs"
if [ -f "$POLICY" ]; then
  policy_source="ai-system"
  policy_version="$(policy_json_value "$POLICY" version)"
  deny_count="$(policy_json_value "$POLICY" deny)"
  review_count="$(policy_json_value "$POLICY" review)"
elif [ -f "$TRUST" ]; then
  policy_source="trust-profile"
  policy_version="trust-v$(trust_value version)"
  deny_count="$(trust_rule_count deny)"
  review_count="$(trust_rule_count review)"
else
  policy_source="missing"
  policy_version="missing"
  deny_count="0"
  review_count="0"
fi

probe_decision() {
  if [ -x "$checker" ]; then
    AI_PERMISSION_LOG="${AI_PERMISSION_LOG:-${TMPDIR:-/tmp}/cc-permission-decisions.jsonl}" "$checker" --json "$1" 2>/dev/null
  elif [ -x "$TRUST_GATE" ]; then
    DOTFILES="$DOTFILES" CC_TRUST_PROFILE="$TRUST" "$TRUST_GATE" --json --mode review --task "$1" 2>/dev/null
  else
    printf '{}'
  fi | node -e "let s='';process.stdin.on('data',d=>s+=d);process.stdin.on('end',()=>{try{console.log(String(JSON.parse(s).decision||'unknown').toUpperCase())}catch(_){console.log('UNKNOWN')}})"
}

if [ "${1:-}" = "--summary" ]; then
  printf 'Mode: %s | Policy: %s (%s) | Rules: %s deny, %s review\n' "$mode" "${policy_version:-missing}" "$policy_source" "${deny_count:-0}" "${review_count:-0}"
  printf 'Probe: read=%s install=%s secret=%s deploy=%s\n' \
    "$(probe_decision "read files and summarize the project")" \
    "$(probe_decision "brew install a new global dependency")" \
    "$(probe_decision "print my api key")" \
    "$(probe_decision "deploy this to production")"
  exit 0
fi

printf '# AI Permission Matrix\n\n'
printf 'Mode: %s\n' "$mode"
printf 'Mode updated: %s\n' "$updated"
printf 'Policy: %s (%s)\n' "${policy_version:-missing}" "$policy_source"
printf 'Policy rules: %s deny, %s review\n' "${deny_count:-0}" "${review_count:-0}"

section "Allowed By Default"
cat <<'EOF'
- Read files in the current workspace and configured readable roots.
- Inspect git status, diffs, logs, command registries, lane registries, and health reports.
- Run deterministic local checks: lint, typecheck, tests, smoke checks, dry-runs, status commands.
- Edit existing project or dotfile configuration when the user has requested that system work.
- Generate local docs, snapshots, audits, plans, and route receipts.
- Use normal router lanes for their scoped purpose: Codex/code, Kimi/browser-design, DeepSeek/bulk, ChatGPT/images.
EOF

section "Review Required"
cat <<'EOF'
- Install packages, change executable permissions, create/modify launch agents, or run privileged system commands.
- Publish, deploy, release, change DNS, or push changes to production.
- Commit or push to git remotes unless the user explicitly asks for it.
- Move, delete, or prune archives/caches, including disk cleanup candidates.
- Use TEL or any credentialed third-party action on the user's behalf.
- Send email, Slack messages, comments, PR reviews, mentions, or any cross-user communication.
- Start any paid subscription, paid API usage, billing change, or new SaaS dependency.
- Run schema migrations or shared database changes.
EOF

section "Denied / Hard Stop"
cat <<'EOF'
- Reveal, print, dump, or expose API keys, tokens, passwords, credentials, or private key material.
- Edit, overwrite, delete, or rotate credentials without explicit supervised handling.
- Root-level destructive operations, force-pushes to main, dropping databases, or wiping projects.
- Let free/lab/reference lanes handle secrets, payments, final review, deploy approval, or authoritative architecture.
- Continue autonomous loops after two same-task iterations with zero progress.
EOF

section "Policy Rules"
if [ -f "$POLICY" ]; then
  node -e "
const fs=require('fs');
const p=JSON.parse(fs.readFileSync(process.argv[1],'utf8'));
for (const group of ['deny','review']) {
  console.log(group.toUpperCase());
  for (const r of p[group] || []) console.log('- ' + r.id + ': ' + r.reason);
}
" "$POLICY"
elif [ -f "$TRUST" ]; then
  node -e "
const fs=require('fs');
const t=JSON.parse(fs.readFileSync(process.argv[1],'utf8'));
console.log('DENY');
if (t.allow_secrets === false) console.log('- secrets: credentials must never be printed or exposed');
if (t.destructive_actions === 'deny') console.log('- destructive_actions: destructive operations are hard-denied');
console.log('REVIEW');
if (t.allow_network === 'ask') console.log('- network: browser/network actions require review');
if (t.allow_browser_profile === 'ask') console.log('- browser_profile: logged-in profile access requires review');
if (t.public_publish === 'review') console.log('- public_publish: publishing and deploy actions require review');
if (t.paid_actions === 'review') console.log('- paid_actions: billing or paid usage requires review');
if (t.credentialed_actions === 'tel-only') console.log('- credentialed_actions: credentialed actions must use TEL');
" "$TRUST"
else
  printf 'Policy file missing: %s\n' "$POLICY"
  printf 'Trust profile missing: %s\n' "$TRUST"
fi

section "Decision Probe"
for task in \
  "read files and summarize the project" \
  "brew install a new global dependency" \
  "print my api key" \
  "deploy this to production"; do
  printf -- '- %s: ' "$task"
  probe_decision "$task"
done
