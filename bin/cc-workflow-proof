#!/usr/bin/env bash
set -euo pipefail

prompt="${*:-debug this repo and verify the safest next step}"
route_script="${AI_SYSTEM_ROUTE_SCRIPT:-${AI_SYSTEM_V2:-$HOME/AI-SYSTEM-V2}/scripts/intent-route.sh}"

printf '# Workflow Proof\n\n'

if [ "${CC_WORKFLOW_PROOF_SKIP_READINESS:-0}" = 1 ]; then
  printf "## Product Readiness\n\n\`\`\`text\nskipped by CC_WORKFLOW_PROOF_SKIP_READINESS=1\n\`\`\`\n\n"
else
  printf '## Product Readiness\n\n```text\n'
  cc-product-readiness | sed -n '1,28p'
  printf '```\n\n'
fi

printf '## Route Preview\n\n```text\n'
if [ -x "$route_script" ]; then
  "$route_script" --dry-run "$prompt" | sed -n '1,34p'
else
  printf 'route preview unavailable: missing %s\n' "$route_script"
fi
printf '```\n\n'

printf '## Repo Index\n\n'
cc-repo-index | sed -n '1,54p'

printf '\n## Repo Map\n\n```text\n'
cc-repo-map 18
printf '```\n\n'

printf '\n## Diff Review Surface\n\n```text\n'
if git rev-parse --show-toplevel >/dev/null 2>&1; then
  git diff --stat -- . | sed -n '1,40p'
else
  printf 'not inside a git repository\n'
fi
printf '```\n'
