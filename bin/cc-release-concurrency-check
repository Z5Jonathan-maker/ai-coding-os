#!/usr/bin/env bash
set -euo pipefail

DOTFILES="${DOTFILES:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
version="${1:-v0.1.0-rc8}"
dist="$DOTFILES/dist"
bundle="$dist/ai-coding-os-${version}.tar.gz"
checksum="$bundle.sha256"
log_dir="${CC_RELEASE_CONCURRENCY_LOG_DIR:-$(mktemp -d "${TMPDIR:-/tmp}/cc-release-concurrency.XXXXXX")}"
pass=0
fail=0

run_pair() {
  "$DOTFILES/bin/cc-release-artifact-check" "$version" >"$log_dir/a.log" 2>&1 &
  local a_pid=$!
  "$DOTFILES/bin/cc-release-artifact-check" "$version" >"$log_dir/b.log" 2>&1 &
  local b_pid=$!

  local a_status=0 b_status=0
  wait "$a_pid" || a_status=$?
  wait "$b_pid" || b_status=$?

  if [ "$a_status" -ne 0 ] || [ "$b_status" -ne 0 ]; then
    printf 'a_status=%s b_status=%s\n' "$a_status" "$b_status"
    printf '\n-- a.log --\n'
    sed -n '1,120p' "$log_dir/a.log"
    printf '\n-- b.log --\n'
    sed -n '1,120p' "$log_dir/b.log"
    return 1
  fi
}

final_artifact_valid() {
  [ -s "$bundle" ] && [ -s "$checksum" ]
  (cd "$dist" && shasum -a 256 -c "$(basename "$checksum")")
  tar -tzf "$bundle" >/dev/null
  tar -xOzf "$bundle" "ai-coding-os-${version}/BUNDLE-README.md" |
    grep -Fq 'Verification command in repo: `cc-evaluator-check`'
}

record() {
  local name="$1"
  shift
  printf '\n## %s\n' "$name"
  if "$@" >"$log_dir/$(printf '%s' "$name" | tr '[:upper:] /' '[:lower:]--' | tr -cd 'a-z0-9._-').log" 2>&1; then
    printf 'ok   %s\n' "$name"
    pass=$((pass + 1))
  else
    printf 'fail %s\n' "$name"
    sed 's/^/     /' "$log_dir/$(printf '%s' "$name" | tr '[:upper:] /' '[:lower:]--' | tr -cd 'a-z0-9._-').log" | sed -n '1,120p'
    fail=$((fail + 1))
  fi
}

printf '# Release Concurrency Check\n\n'
printf 'Root: %s\n' "$DOTFILES"
printf 'Version: %s\n' "$version"
printf 'Logs: %s\n' "$log_dir"

cd "$DOTFILES" || exit 1

record "Parallel release artifact checks" run_pair
record "Final artifact valid" final_artifact_valid

printf '\n## Summary\n\n'
printf 'passed=%s failed=%s\n' "$pass" "$fail"
printf '%s\n' "$([ "$fail" -eq 0 ] && printf 'Status: release-concurrency-ready' || printf 'Status: release-concurrency-blocked')"

[ "$fail" -eq 0 ]
