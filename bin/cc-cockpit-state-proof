#!/usr/bin/env bash
set -euo pipefail

DOTFILES="${DOTFILES:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
OUT_DIR="${1:-$DOTFILES/docs/media/cockpit/states}"
CSS="$DOTFILES/vscode/ai-cockpit/media/style.css"

usage() {
  cat <<'EOF'
cc-cockpit-state-proof — deterministic cockpit state screenshots

Usage:
  cc-cockpit-state-proof [OUT_DIR]
  cc-cockpit-state-proof --check

Generates deterministic screenshots for the core cockpit states:
continuation, running, success, blocked, permissions, and route receipt.
EOF
}

if [ "${1:-}" = "--check" ]; then
  command -v playwright >/dev/null 2>&1 || {
    printf 'missing playwright CLI\n'
    exit 1
  }
  [ -f "$CSS" ] || {
    printf 'missing cockpit CSS: %s\n' "$CSS"
    exit 1
  }
  printf 'Status: cockpit-state-proof-ready\n'
  exit 0
fi

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

command -v playwright >/dev/null 2>&1 || {
  printf 'missing playwright CLI\n' >&2
  exit 1
}

[ -f "$CSS" ] || {
  printf 'missing cockpit CSS: %s\n' "$CSS" >&2
  exit 1
}

tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT
mkdir -p "$OUT_DIR"

write_page() {
  local file="$1" state="$2" title="$3" subtitle="$4" primary="$5" detail="$6" accent="$7"
  {
    cat <<HTML
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>${title}</title>
  <style>
    :root {
      --vscode-foreground: #f2f3ff;
      --vscode-descriptionForeground: #a9abc0;
      --vscode-sideBar-background: #080b18;
      --vscode-editor-background: #101426;
      --vscode-panel-border: rgba(255,255,255,.1);
      --vscode-sideBarSectionHeader-border: rgba(255,255,255,.1);
      --vscode-button-background: #6e56ff;
      --vscode-button-hoverBackground: #806dff;
      --vscode-button-foreground: #ffffff;
      --vscode-button-border: rgba(255,255,255,.16);
      --vscode-input-background: rgba(255,255,255,.06);
      --vscode-input-foreground: #f2f3ff;
      --vscode-input-border: rgba(255,255,255,.12);
      --vscode-focusBorder: #9f8cff;
      --vscode-testing-iconPassed: #50e3a4;
      --vscode-testing-iconFailed: #ff5f7e;
      --vscode-testing-iconQueued: #ffd166;
      --vscode-textCodeBlock-background: rgba(0,0,0,.24);
      --vscode-editor-foreground: #f2f3ff;
      --vscode-badge-foreground: #ffffff;
      --vscode-badge-background: #6e56ff;
      --vscode-editor-font-family: "SF Mono", Menlo, monospace;
      --vscode-font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
HTML
    cat "$CSS"
    cat <<HTML
    *, *::before, *::after { animation: none !important; transition: none !important; }
    body {
      min-height: 900px;
      padding: 0;
      background:
        radial-gradient(circle at 68% 22%, ${accent} 0, transparent 28%),
        radial-gradient(circle at 30% 18%, rgba(110,86,255,.34), transparent 34%),
        linear-gradient(145deg, #070a16, #11172d 56%, #080b18);
    }
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(255,255,255,.045) 1px, transparent 1px),
        linear-gradient(180deg, rgba(255,255,255,.035) 1px, transparent 1px);
      background-size: 80px 80px;
      mask-image: radial-gradient(circle at 55% 28%, black, transparent 72%);
    }
    .state-proof-shell {
      width: min(1180px, calc(100vw - 96px));
      margin: 58px auto;
      display: grid;
      grid-template-columns: 238px minmax(0, 1fr);
      gap: 34px;
    }
    .state-proof-rail {
      min-height: 760px;
      padding: 24px;
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 24px;
      background: rgba(8,11,24,.62);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 30px 80px rgba(0,0,0,.34);
      backdrop-filter: blur(18px);
    }
    .state-proof-brand { display: flex; align-items: center; gap: 12px; margin-bottom: 42px; }
    .state-proof-logo {
      width: 36px;
      height: 36px;
      border-radius: 12px;
      background: linear-gradient(145deg, #6e56ff, #42d7c7);
      box-shadow: 0 0 30px rgba(110,86,255,.5);
    }
    .state-proof-brand strong { display:block; font-size: 14px; }
    .state-proof-brand span { display:block; color: var(--vscode-descriptionForeground); font-size: 11px; }
    .state-proof-nav { display:grid; gap: 8px; }
    .state-proof-nav span {
      padding: 12px 14px;
      border-radius: 14px;
      color: rgba(242,243,255,.7);
      background: rgba(255,255,255,.035);
    }
    .state-proof-nav span.active {
      color: white;
      background: linear-gradient(135deg, rgba(110,86,255,.32), rgba(66,215,199,.12));
      box-shadow: inset 0 1px 0 rgba(255,255,255,.1);
    }
    .state-proof-main { display: grid; gap: 24px; }
    .state-proof-eyebrow {
      color: #c7bbff;
      font-size: 12px;
      font-weight: 750;
      letter-spacing: .12em;
      text-transform: uppercase;
    }
    .state-proof-title {
      max-width: 860px;
      margin: 10px 0 0;
      font-size: 68px;
      line-height: .94;
      letter-spacing: 0;
    }
    .state-proof-subtitle {
      max-width: 640px;
      margin-top: 18px;
      color: rgba(242,243,255,.74);
      font-size: 18px;
      line-height: 1.55;
    }
    .state-proof-hero {
      position: relative;
      min-height: 384px;
      padding: 34px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 30px;
      background:
        radial-gradient(circle at 78% 42%, ${accent} 0, transparent 32%),
        linear-gradient(145deg, rgba(255,255,255,.1), rgba(255,255,255,.035));
      box-shadow: inset 0 1px 0 rgba(255,255,255,.14), 0 36px 90px rgba(0,0,0,.36);
      backdrop-filter: blur(22px);
    }
    .state-proof-hero::after {
      content: "";
      position: absolute;
      inset: auto -10% -40% 28%;
      height: 260px;
      background: radial-gradient(ellipse, rgba(255,255,255,.18), transparent 68%);
      transform: rotate(-5deg);
    }
    .state-proof-primary {
      position: absolute;
      right: 38px;
      bottom: 38px;
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 16px 22px;
      border-radius: 999px;
      background: rgba(255,255,255,.13);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.18), 0 18px 40px rgba(0,0,0,.24);
      backdrop-filter: blur(18px);
    }
    .state-proof-primary i {
      width: 36px;
      height: 36px;
