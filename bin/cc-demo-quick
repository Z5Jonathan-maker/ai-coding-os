#!/usr/bin/env bash
set -u

DOTFILES="${DOTFILES:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
ROUTER="${AI_INTENT_ROUTER:-$DOTFILES/bin/cc-route}"
tmp="${TMPDIR:-/tmp}/cc-demo-quick.$$"
pass=0
fail=0

cleanup() {
  rm -f "$tmp".*
}
trap cleanup EXIT

run_quiet() {
  local name="$1" expect="$2"
  shift 2
  local log
  log="$tmp.$(printf '%s' "$name" | tr '[:upper:] /' '[:lower:]--')"
  if "$@" >"$log" 2>&1 && { [ -z "$expect" ] || grep -Eq "$expect" "$log"; }; then
    printf 'ok   %s\n' "$name"
    pass=$((pass + 1))
    return 0
  fi
  printf 'fail %s\n' "$name"
  sed 's/^/     /' "$log" | sed -n '1,24p'
  fail=$((fail + 1))
  return 1
}

route_line() {
  local prompt="$1" log="$tmp.route"
  if "$ROUTER" --dry-run "$prompt" >"$log" 2>/dev/null; then
    local selected fallback receipt classifier final platform
    selected="$(sed -n 's/^  Selected:  //p' "$log" | tail -1)"
    fallback="$(sed -n 's/^  Fallback:  //p' "$log" | tail -1)"
    receipt="$(sed -n 's/^  Receipt:   //p' "$log" | tail -1)"
    classifier="$(node -e 'const r=JSON.parse(process.argv[1]); process.stdout.write(r.classifier_output || "")' "$receipt" 2>/dev/null)"
    final="$(node -e 'const r=JSON.parse(process.argv[1]); process.stdout.write(r.final_class || "")' "$receipt" 2>/dev/null)"
    platform="$(node -e 'const r=JSON.parse(process.argv[1]); process.stdout.write(r.platform || "")' "$receipt" 2>/dev/null)"
    printf 'ok   %-18s -> %-22s classifier=%s fallback=%s\n' "$final/$platform" "$selected" "$classifier" "$fallback"
    pass=$((pass + 1))
  else
    printf 'fail route preview: %s\n' "$prompt"
    sed 's/^/     /' "$log" | sed -n '1,24p'
    fail=$((fail + 1))
  fi
}

cd "$DOTFILES" || exit 1

printf '# 90-Second AI Coding OS Demo\n\n'
printf 'Promise: one local cockpit routes coding work to the right AI lane, then proves the run with receipts, gates, and mission state.\n'
printf 'Root: %s\n\n' "$DOTFILES"

printf '## 1. Routing proof\n\n'
if [ ! -x "$ROUTER" ]; then
  printf 'fail route source unavailable: %s\n' "$ROUTER"
  fail=$((fail + 1))
else
  printf 'Source: in-tree route engine (%s)\n\n' "$ROUTER"
fi
route_line 'fix a failing TypeScript unit test and verify the bug is gone'
route_line 'redesign the cockpit hero into the approved cinematic continuation surface'
route_line 'extract this package metadata and return compact JSON'
route_line 'review this auth module for security and trust-boundary risks'

printf '\n## 2. Public workflow proof\n\n'
run_quiet 'Public fixture workflow' '^Fixture:' env CC_WORKFLOW_PROOF_SKIP_READINESS=1 "$DOTFILES/bin/cc-demo-fixture"

printf '\n## 3. Product proof\n\n'
run_quiet '10-scenario benchmarks' '^Status: benchmark-fixtures-ready$' "$DOTFILES/bin/cc-benchmark-fixtures" --check
run_quiet 'Cockpit webview smoke' '^Status: cockpit-webview-ready$' "$DOTFILES/bin/cc-cockpit-webview-smoke"
run_quiet 'Trust gate' '^Status: trust-gate-ready$' "$DOTFILES/bin/cc-trust-gate" --check
run_quiet 'Mission ledger' '^Status: mission-ledger-ready$' "$DOTFILES/bin/cc-mission-ledger" --check

printf '\n## Summary\n\n'
printf 'passed=%s failed=%s\n' "$pass" "$fail"
if [ "$fail" -eq 0 ]; then
  printf 'Status: quick-demo-ready\n'
else
  printf 'Status: quick-demo-blocked\n'
fi

[ "$fail" -eq 0 ]
