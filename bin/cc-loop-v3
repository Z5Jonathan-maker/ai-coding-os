#!/usr/bin/env bash
# cc-loop-v3 — Uses gateway REST API instead of shell subprocess
set -euo pipefail

BOARD="$HOME/.claude/memory/TASK_BOARD.md"
STATE="$HOME/.claude/cc-loop.state"
LOG="$HOME/.claude/cc-loop.log"
GATEWAY="http://127.0.0.1:8747"

[ -f "$HOME/.cc-paused" ] && { echo "[cc-loop-v3] Paused" >> "$LOG"; exit 0; }
[ -f "$BOARD" ] || { echo "[cc-loop-v3] No board" >> "$LOG"; exit 0; }

# Find first active task
active=$(grep "^### \[ \]" "$BOARD" | head -1)
[ -n "$active" ] || { echo "[cc-loop-v3] No active tasks" >> "$LOG"; exit 0; }

# Parse task
task_id=$(echo "$active" | grep -o 'T[0-9]*' | head -1)
task_type=$(sed -n "/^$active/,/^### /p" "$BOARD" | grep "Type:" | sed 's/.*Type: \*\*//' | sed 's/\*\*.*//' | tr -d ' ' | head -1)
desc=$(sed -n "/^$active/,/^### /p" "$BOARD" | grep "Description:" | sed 's/.*Description: \*\*//' | sed 's/\*\*.*//' | head -1)

# Map type to tier
case "$task_type" in
  ui_design|design|visual|layout) tier="design" ;;
  implementation|bug_fix|feature_dev|test_generation|shell_script|cli_tool|code_review|refactor) tier="codex" ;;
  summarize|enrich|compact_memory|codebase_analysis) tier="cheap" ;;
  *) tier="precision" ;;
esac

echo "[cc-loop-v3] $(date '+%H:%M:%S') — $task_id → $tier" >> "$LOG"

# Call gateway API
result=$(curl -s -X POST "$GATEWAY/ask" \
  -H "Content-Type: application/json" \
  -d "{\"prompt\":\"$desc\",\"purpose\":\"$tier\",\"timeoutMs\":120000}" \
  2>&1) || result="{\"error\":\"Gateway unreachable\"}"

# Log result
text=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('text','')[:200])" 2>/dev/null || echo "$result" | head -c 200)
echo "[cc-loop-v3] Result: $text" >> "$LOG"

# Mark complete
sed -i.bak "s|^### \[ \] $task_id|### [x] $task_id — completed $(date '+%Y-%m-%d %H:%M')|" "$BOARD"
rm -f "$BOARD.bak"

# Update state
cat > "$STATE" <<EOF
last_exit=0
last_run=$(date +%s)
consecutive_errors=0
noop_cycles=0
last_event=completed_${task_id}
EOF

echo "[cc-loop-v3] Done" >> "$LOG"
