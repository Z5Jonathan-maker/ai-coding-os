#!/usr/bin/env -S uv run --quiet --with playwright python3
"""Hands-off GitHub re-auth.

Runs the device-code flow against GitHub's API, then drives Playwright's
persistent-profile Chromium to:
  1. Visit https://github.com/login/device
  2. Fill in the user code
  3. Click 'Continue', then 'Authorize'

If you've logged into GitHub in this Playwright profile once before
(see `gh-playwright-login`), no human is needed — the cookies are reused.
1Password browser extension installed in the profile handles 2FA autofill.

Usage:
    gh-auto-auth                      # default scopes
    gh-auto-auth repo,workflow,...    # custom scopes
"""
import json
import os
import subprocess
import sys
import time
import urllib.request
import urllib.parse
from pathlib import Path

GH_CLIENT_ID = "178c6fc778ccc68e1d6a"
DEFAULT_SCOPES = (
    "repo,read:org,workflow,gist,"
    "admin:public_key,admin:ssh_signing_key"
)
PROFILE = str(Path.home() / ".cache" / "playwright-profile")

def post(url: str, data: dict) -> dict:
    body = urllib.parse.urlencode(data).encode()
    req = urllib.request.Request(
        url, data=body, headers={"Accept": "application/json"},
    )
    with urllib.request.urlopen(req, timeout=30) as r:
        return json.loads(r.read())

def request_device_code(scopes: str) -> dict:
    return post(
        "https://github.com/login/device/code",
        {"client_id": GH_CLIENT_ID, "scope": scopes},
    )

def poll_for_token(device_code: str) -> dict:
    return post(
        "https://github.com/login/oauth/access_token",
        {
            "client_id": GH_CLIENT_ID,
            "device_code": device_code,
            "grant_type": "urn:ietf:params:oauth:grant-type:device_code",
        },
    )

def autofill_with_playwright(user_code: str, verify_url: str) -> bool:
    """Drive Chromium via Playwright to enter the code and authorize."""
    try:
        from playwright.sync_api import sync_playwright
    except ImportError:
        print("playwright not installed; falling back to dialog", file=sys.stderr)
        return False

    with sync_playwright() as p:
        ctx = p.chromium.launch_persistent_context(
            PROFILE,
            headless=False,
            args=["--no-default-browser-check"],
        )
        page = ctx.new_page()
        try:
            page.goto(verify_url, wait_until="domcontentloaded")
            # The user-code input on github.com/login/device
            page.locator("input[name='user_code']").fill(user_code)
            page.locator("button:has-text('Continue')").first.click()
            # Authorize button (may take a second to appear after code accepted)
            page.locator("button:has-text('Authorize')").first.click(timeout=60_000)
            page.wait_for_load_state("networkidle", timeout=30_000)
            print("playwright auto-authorized", flush=True)
            return True
        except Exception as e:
            print(f"playwright autofill failed: {e}", file=sys.stderr)
            return False
        finally:
            ctx.close()

def fallback_dialog(user_code: str, verify_url: str) -> None:
    msg = (f"GitHub one-time code:\\n\\n      {user_code}\\n\\n"
           f"Click OK to open {verify_url}.")
    subprocess.run(
        ["osascript", "-e",
         f'display dialog "{msg}" with title "gh auto-auth" '
         f'buttons {{"OK"}} default button "OK"'],
        check=False,
    )
    subprocess.run(["open", verify_url], check=False)

def main() -> int:
    scopes = sys.argv[1] if len(sys.argv) > 1 else DEFAULT_SCOPES
    print(f"requesting device code (scopes: {scopes})...", flush=True)
    dc = request_device_code(scopes)
    user_code = dc["user_code"]
    device_code = dc["device_code"]
    verify_url = dc["verification_uri"]
    interval = int(dc.get("interval", 5))
    expires_in = int(dc.get("expires_in", 900))

    print(f"user code: {user_code}", flush=True)

    autofilled = autofill_with_playwright(user_code, verify_url)
    if not autofilled:
        fallback_dialog(user_code, verify_url)

    deadline = time.time() + expires_in
    while time.time() < deadline:
        time.sleep(interval)
        try:
            resp = poll_for_token(device_code)
        except Exception as e:
            print(f"poll error: {e}", flush=True)
            continue
        if "access_token" in resp:
            token = resp["access_token"]
            print("got token, importing into gh", flush=True)
            r = subprocess.run(
                ["/opt/homebrew/bin/gh", "auth", "login",
                 "--with-token", "--hostname", "github.com"],
                input=token.encode(), capture_output=True,
            )
            if r.returncode != 0:
                print(f"gh failed: {r.stderr.decode()}", flush=True)
                return 1
            subprocess.run(
                ["/opt/homebrew/bin/gh", "config", "set",
                 "git_protocol", "https"], check=False,
            )
            print("authenticated", flush=True)
            return 0
        err = resp.get("error", "")
        if err == "authorization_pending":
            print(".", end="", flush=True)
            continue
        if err == "slow_down":
            interval += 5
            continue
        if err in ("expired_token", "access_denied"):
            print(f"\nfailed: {err}", flush=True)
            return 2
    print("\nexpired", flush=True)
    return 3

if __name__ == "__main__":
    sys.exit(main())
