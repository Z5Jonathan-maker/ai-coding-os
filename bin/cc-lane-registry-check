#!/usr/bin/env node
/**
 * cc-lane-registry-check — structural validation for ai-lanes.json.
 */
'use strict';

const fs = require('fs');
const os = require('os');
const path = require('path');

const root = process.env.DOTFILES || path.resolve(__dirname, '..');
const registryPath = process.argv[2] || path.join(root, 'ai-lanes.json');
const raw = fs.readFileSync(registryPath, 'utf8');
const registry = JSON.parse(raw);
const errors = [];

function err(msg) {
  errors.push(msg);
}

if (registry.version !== 1) err('version must be 1');
if (!Array.isArray(registry.lanes) || registry.lanes.length === 0) err('lanes must be a non-empty array');
if (!registry.capabilities || typeof registry.capabilities !== 'object') err('capabilities must be an object');

const laneIds = new Set();
for (const lane of registry.lanes || []) {
  if (!lane.id) {
    err('lane missing id');
    continue;
  }
  if (laneIds.has(lane.id)) err(`duplicate lane id: ${lane.id}`);
  laneIds.add(lane.id);
  if (!['active', 'optional', 'study', 'retired'].includes(lane.status)) err(`${lane.id}: invalid status`);
  if (!Array.isArray(lane.capabilities) || lane.capabilities.length === 0) err(`${lane.id}: capabilities required`);
  for (const capability of lane.capabilities || []) {
    if ((lane.unsupported || []).includes(capability)) err(`${lane.id}: capability also marked unsupported: ${capability}`);
  }
  if (!lane.health || !lane.health.kind) err(`${lane.id}: health.kind required`);
  if (lane.health?.kind === 'command' && !lane.health.command) err(`${lane.id}: command health requires command`);
  if (lane.health?.kind === 'none' && lane.status === 'active') err(`${lane.id}: active lane cannot have health kind none`);
  for (const fb of lane.fallbacks || []) {
    if (!laneIds.has(fb) && !(registry.lanes || []).some((candidate) => candidate.id === fb)) {
      err(`${lane.id}: fallback references missing lane ${fb}`);
    }
  }
}

for (const [capability, route] of Object.entries(registry.capabilities || {})) {
  if (!route.primary) {
    err(`${capability}: missing primary lane`);
    continue;
  }
  if (!laneIds.has(route.primary)) err(`${capability}: primary lane missing: ${route.primary}`);
  const primary = (registry.lanes || []).find((lane) => lane.id === route.primary);
  if (primary && !(primary.capabilities || []).includes(capability)) {
    err(`${capability}: primary lane ${route.primary} does not declare capability`);
  }
  if (primary && (primary.unsupported || []).includes(capability)) {
    err(`${capability}: primary lane ${route.primary} marks capability unsupported`);
  }
  for (const fb of route.fallbacks || []) {
    if (!laneIds.has(fb)) err(`${capability}: fallback lane missing: ${fb}`);
    const lane = (registry.lanes || []).find((candidate) => candidate.id === fb);
    if (lane && (lane.unsupported || []).includes(capability)) {
      err(`${capability}: fallback lane ${fb} marks capability unsupported`);
    }
  }
  if ((!route.fallbacks || route.fallbacks.length === 0) && !route.noFallbackReason) {
    err(`${capability}: fallback or noFallbackReason required`);
  }
}

if (errors.length) {
  for (const e of errors) console.error(`fail ${e}`);
  process.exit(1);
}

console.log(`ok   lane registry: ${laneIds.size} lanes, ${Object.keys(registry.capabilities || {}).length} capabilities`);
