#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES="${DOTFILES:-$(cd "$SCRIPT_DIR/.." && pwd)}"
prompt="${*:-debug this repo and verify the safest next step}"
route_script="${AI_SYSTEM_ROUTE_SCRIPT:-${AI_SYSTEM_V2:-$HOME/AI-SYSTEM-V2}/scripts/intent-route.sh}"
router_root="${CC_ROUTER_ROOT:-$HOME/code/projects/cc-router}"

route_fixture() {
  local final="codex" platform="codex" selected="codex -> codex" classifier="codex"
  case "$prompt" in
    *design*|*screenshot*|*browser*|*UI*|*hero*) final="design"; platform="kimi"; selected="design -> kimi"; classifier="design" ;;
    *extract*|*summarize*|*JSON*|*metadata*) final="cheap"; platform="deepseek"; selected="cheap -> deepseek"; classifier="cheap" ;;
    *security*|*audit*|*review*|*architecture*|*debug*) final="precision"; platform="claude"; selected="precision -> claude"; classifier="precision" ;;
  esac
  printf 'Source: committed routing contract fixture; live route script unavailable at %s\n' "$route_script"
  printf 'Selected: %s\n' "$selected"
  printf 'Receipt: {"classifier_output":"%s","final_class":"%s","platform":"%s","fallback_chain":["%s","design/kimi","cheap/deepseek"],"fixture":true}\n' "$classifier" "$final" "$platform" "$selected"
}

printf '# Workflow Proof\n\n'

if [ "${CC_WORKFLOW_PROOF_SKIP_READINESS:-0}" = 1 ]; then
  printf "## Product Readiness\n\n\`\`\`text\nskipped by CC_WORKFLOW_PROOF_SKIP_READINESS=1\n\`\`\`\n\n"
elif [ ! -x "$router_root/bin/cc-router-classifier-check" ]; then
  printf '## Product Readiness\n\n```text\n'
  printf 'portable evaluator mode\n'
  printf 'private router and local VS Code readiness skipped\n'
  printf 'public gate: cc-public-ci-check\n'
  printf 'quick proof: cc-demo-quick\n'
  printf '```\n\n'
else
  printf '## Product Readiness\n\n```text\n'
  "$DOTFILES/bin/cc-product-readiness" | sed -n '1,28p' || true
  printf '```\n\n'
fi

printf '## Route Preview\n\n```text\n'
if [ -x "$route_script" ]; then
  "$route_script" --dry-run "$prompt" | sed -n '1,34p' || true
else
  route_fixture
fi
printf '```\n\n'

printf '## Repo Index\n\n'
"$DOTFILES/bin/cc-repo-index" | sed -n '1,54p' || true

printf '\n## Repo Map\n\n```text\n'
"$DOTFILES/bin/cc-repo-map" 18
printf '```\n\n'

printf '\n## Diff Review Surface\n\n```text\n'
if git rev-parse --show-toplevel >/dev/null 2>&1; then
  git diff --stat -- . | sed -n '1,40p' || true
else
  printf 'not inside a git repository\n'
fi
printf '```\n'
printf '\nStatus: workflow-proof-ready\n'
