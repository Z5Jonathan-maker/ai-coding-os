#!/usr/bin/env node
'use strict';

const fs = require('fs');
const os = require('os');
const path = require('path');
const {
  activePhase,
  artifactPath,
  artifactsFor,
  completionStageFor,
  event,
  extractJson,
  nextActionFor,
  now,
  readJson,
  refreshProof,
  relative,
  requestStageFor,
  slug,
  unlockNext,
  writeJson,
} = require('../lib/design-handoff/core');
const { buildActionPacket } = require('../lib/design-handoff/actions');
const { runDesignHandoffCheck } = require('../lib/design-handoff/check');
const { createCli } = require('../lib/design-handoff/cli');
const { createExecuteStage } = require('../lib/design-handoff/execution');
const { initialPhases } = require('../lib/design-handoff/phases');
const { addCheckpointRecord, addMissionGitRecord, createRuntime } = require('../lib/design-handoff/runtime');

const root = process.env.DOTFILES || path.resolve(__dirname, '..');
const { args, has, promptArgs, subcommand, value, values } = createCli(process.argv.slice(2));

const {
  createPhaseCheckpoint,
  recordMissionGit,
  route,
  run,
  summarizeHandoffContext,
  triggeredMicroagents,
  updateContextSummary,
  updateCostLedger,
} = createRuntime({ root, has });

function missionDir() {
  const dir = value('dir', value('out-dir', ''));
  if (!dir) {
    console.error('cc-design-handoff: --dir required');
    process.exit(2);
  }
  return path.resolve(dir);
}

function loadMission(dir) {
  const files = artifactsFor(dir);
  for (const file of [files.handoff, files.timeline, files.proofBundle]) {
    if (!fs.existsSync(file)) {
      console.error(`cc-design-handoff: missing ${path.basename(file)} in ${dir}`);
      process.exit(1);
    }
  }
  return {
    files,
    handoff: readJson(files.handoff),
    timeline: readJson(files.timeline),
    proof: readJson(files.proofBundle),
  };
}

function phaseById(handoff, id) {
  const phase = (handoff.phases || []).find((item) => item.id === id);
  if (!phase) {
    console.error(`cc-design-handoff: unknown phase ${id}`);
    process.exit(2);
  }
  return phase;
}

function appendTimeline(files, timeline, entry) {
  timeline.events.push(entry);
  writeJson(files.timeline, timeline);
  const validate = run(path.join(root, 'bin', 'cc-mission-events'), ['validate', '--file', files.timeline]);
  if (validate.status !== 0) {
    console.error(`${validate.stdout || ''}${validate.stderr || ''}`.trim());
    process.exit(1);
  }
}

function writeTinyPng(file) {
  fs.mkdirSync(path.dirname(file), { recursive: true });
  fs.writeFileSync(file, Buffer.from(
    'iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMB/azl3H0AAAAASUVORK5CYII=',
    'base64'
  ));
}

function actionPacket(handoff, phase) {
  return buildActionPacket(handoff, phase, (prompt) => triggeredMicroagents(handoff, phase, prompt));
}

function markComplete(dir, files, handoff, proof, phase, artifact, note, status = 'completed') {
  phase.status = status;
  if (artifact) phase.completed_artifact = artifact;
  phase.completed_at = now();
  phase.completion_note = note;
  unlockNext(handoff, phase.id);
  refreshProof(handoff, proof);
  writeJson(files.handoff, handoff);
  writeJson(files.proofBundle, proof);
}

function createHandoff() {
  const request = promptArgs();
  if (!request) {
    console.error('Usage: cc-design-handoff "premium landing page brief" [--out-dir DIR] [--title TITLE]');
    process.exit(2);
  }

  const title = value('title', request.slice(0, 96));
  const stamp = new Date().toISOString().replace(/[-:]/g, '').replace(/\..+/, 'Z');
  const dir = path.resolve(value('out-dir', path.join(root, '.ai', 'design-handoffs', `${stamp}-${slug(title)}`)));
  const missionId = path.basename(dir);
  const files = artifactsFor(dir);
  const routeReceipt = route(request, 'creative_direction');

  const phases = initialPhases();

  writeJson(files.creativeBrief, {
    schema: 'ai-coding-os.creative-brief.v1',
    mission_id: missionId,
    title,
    request,
    product_wedge: 'taste-driven frontend generation',
    dominant_user_action: 'describe the desired business outcome',
    success_outcome: 'approved visual direction survives implementation and deploy proof',
    anti_goals: [
      'do not expose provider routing as the main UX',
      'do not let implementation lanes reinvent approved visual direction',
      'do not deploy without explicit approval',
    ],
  });

  writeJson(files.routeReceipt, routeReceipt);
  writeJson(files.handoff, {
    schema: 'ai-coding-os.design-handoff.v1',
    mission_id: missionId,
    title,
    request,
    status: 'awaiting_creative_reference',
    current_gate: 'generate_or_attach_visual.target.png_and_approve_it',
    phases,
    required_artifacts: [
      'creative.brief.json',
      'visual.target.png',
      'creative.asset-kit.json',
      'design.dna.json',
      'implementation.plan.json',
      'implementation.result.json',
      'taste.validation.json',
      'codex.proof.json',
      'deploy.receipt.json',
      'proof.bundle.json',
    ],
    hidden_from_primary_ui: [
      'provider selection',
      'token balancing',
      'fallback mechanics',
      'raw model logs',
    ],
  });

  writeJson(files.timeline, {
    schema: 'ai-coding-os.agent-timeline.v1',
    mission_id: missionId,
    events: [
      event(missionId, 'preflight.started', 'Design handoff mission initialized.', { title }, ['creative.brief.json'], 'codex'),
      event(missionId, 'creative.reference.requested', 'Image 2.0 creative reference is required before implementation.', {
        owner_lane: 'chatgpt-image',
        output: 'visual.target.png',
      }, ['route.receipt.json'], 'chatgpt-image'),
      event(missionId, 'approval.requested', 'Human approval gate is open for the visual reference.', {
        gate: 'approve_visual_target',
      }, ['design-handoff.json'], 'human'),
    ],
  });

  writeJson(files.proofBundle, {
    schema: 'ai-coding-os.design-handoff-proof.v1',
    mission_id: missionId,
    status: 'initialized',
    verdict: 'not_shippable_until_reference_approved_and_implementation_verified',
    files: Object.fromEntries(Object.entries(files).map(([key, file]) => [key, path.relative(dir, file)])),
    next_required_action: 'Generate or attach visual.target.png, then mark the creative_reference phase approved.',
  });

  const validate = run(path.join(root, 'bin', 'cc-mission-events'), ['validate', '--file', files.timeline]);
  if (validate.status !== 0) {
    console.error(`${validate.stdout || ''}${validate.stderr || ''}`.trim());
    process.exit(1);
  }

  if (has('json')) {
    console.log(JSON.stringify({ schema: 'ai-coding-os.design-handoff-result.v1', mission_id: missionId, dir }, null, 2));
  } else {
    console.log('# Design Handoff Mission\n');
    console.log(`Mission: ${missionId}`);
    console.log(`Directory: ${dir}`);
    console.log(`Route: ${routeReceipt.final_class || 'unknown'} -> ${routeReceipt.platform || 'unknown'}`);
    console.log('Status: awaiting creative reference approval');
    console.log('Next: generate or attach visual.target.png, approve it, then pass approved artifacts to Kimi implementation.');
    console.log('\nStatus: design-handoff-ready');
  }
}

function listMissions() {
  const base = path.join(root, '.ai', 'design-handoffs');
  const missions = fs.existsSync(base)
    ? fs.readdirSync(base, { withFileTypes: true })
      .filter((entry) => entry.isDirectory())
      .map((entry) => {
        const dir = path.join(base, entry.name);
        const file = path.join(dir, 'design-handoff.json');
        if (!fs.existsSync(file)) return null;
        const handoff = readJson(file);
        return {
          mission_id: handoff.mission_id || entry.name,
          title: handoff.title || entry.name,
          status: handoff.status || 'unknown',
          current_gate: handoff.current_gate || '',
          dir,
          updated_at: new Date(fs.statSync(file).mtimeMs).toISOString(),
        };
      })
      .filter(Boolean)
      .sort((a, b) => String(b.updated_at).localeCompare(String(a.updated_at)))
    : [];

  if (has('json')) {
    console.log(JSON.stringify({ schema: 'ai-coding-os.design-handoff-list.v1', missions }, null, 2));
    return;
  }
  console.log('# Design Handoff Missions\n');
  for (const mission of missions) {
    console.log(`- ${mission.title} :: ${mission.status}`);
    console.log(`  ${mission.dir}`);
  }
  if (!missions.length) console.log('(none)');
  console.log('\nStatus: design-handoff-list-ready');
}

function showStatus() {
  const dir = missionDir();
  const { handoff, timeline, proof } = loadMission(dir);
  if (has('json')) {
    console.log(JSON.stringify({ handoff, event_count: timeline.events.length, proof }, null, 2));
    return;
  }
  console.log('# Design Handoff Status\n');
  console.log(`Mission: ${handoff.mission_id}`);
  console.log(`Title: ${handoff.title}`);
  console.log(`Status: ${handoff.status}`);
  console.log(`Current gate: ${handoff.current_gate}`);
  console.log('\n## Phases\n');
  for (const phase of handoff.phases || []) {
    console.log(`- ${phase.id}: ${phase.status} (${phase.owner_lane})`);
  }
  console.log(`\nEvents: ${timeline.events.length}`);
  console.log(`Next: ${proof.next_required_action || nextActionFor(handoff)}`);
  console.log('\nStatus: design-handoff-status-ready');
}

function approvePhase() {
  const dir = missionDir();
  const phaseId = value('phase', 'creative_reference');
  const artifact = value('artifact', '');
  const note = value('note', `${phaseId} approved`);
  const { files, handoff, timeline, proof } = loadMission(dir);
  const phase = phaseById(handoff, phaseId);
  phase.status = 'approved';
  if (artifact) phase.approved_artifact = artifact;
  phase.approved_at = now();
  phase.approval_note = note;

  const unlocks = {
    creative_reference: ['asset_decomposition', 'design_dna'],
    asset_decomposition: ['kimi_implementation'],
    design_dna: ['kimi_implementation'],
    kimi_implementation: ['claude_review'],
    claude_review: ['codex_proof'],
    codex_proof: ['tel_deploy'],
  };
  for (const id of unlocks[phaseId] || []) {
    const next = phaseById(handoff, id);
    if (next.status.startsWith('blocked_')) next.status = 'awaiting_work';
  }

  const pending = (handoff.phases || []).find((item) => !['approved', 'completed'].includes(item.status));
  handoff.status = pending ? `awaiting_${pending.id}` : 'complete';
  handoff.current_gate = pending?.approval_gate || nextActionFor(handoff);

  proof.status = handoff.status;
  proof.verdict = handoff.status === 'complete' ? 'ready_for_final_release_review' : 'not_shippable_until_remaining_phases_complete';
  proof.next_required_action = handoff.current_gate;

  writeJson(files.handoff, handoff);
  writeJson(files.proofBundle, proof);
  const stage = {
    creative_reference: 'creative.reference.approved',
    asset_decomposition: 'asset.approved',
    design_dna: 'design.dna.extracted',
    kimi_implementation: 'implementation.completed',
    claude_review: 'taste.validated',
    codex_proof: 'proof.completed',
    tel_deploy: 'deploy.completed',
  }[phaseId] || 'approval.granted';
  appendTimeline(files, timeline, event(handoff.mission_id, stage, note, {
    phase: phaseId,
    artifact: artifact || null,
  }, artifact ? [artifact] : ['design-handoff.json'], phase.owner_lane));

  if (has('json')) {
    console.log(JSON.stringify({ schema: 'ai-coding-os.design-handoff-approval.v1', mission_id: handoff.mission_id, phase: phaseId, status: handoff.status }, null, 2));
  } else {
    console.log(`# Approved ${phaseId}\n`);
    console.log(`Mission: ${handoff.mission_id}`);
    console.log(`Status: ${handoff.status}`);
    console.log(`Next: ${proof.next_required_action}`);
    console.log('\nStatus: design-handoff-approved');
  }
}

function continueMission() {
  const dir = missionDir();
  const { files, handoff, timeline, proof } = loadMission(dir);
  const phase = activePhase(handoff);
  const packet = actionPacket(handoff, phase);
  const packetFile = path.join(dir, 'next-action.json');
  writeJson(packetFile, packet);
  proof.next_action_packet = path.relative(dir, packetFile);
  proof.next_required_action = packet.prompt.split('\n')[0] || nextActionFor(handoff);
  writeJson(files.proofBundle, proof);
  appendTimeline(files, timeline, event(handoff.mission_id, requestStageFor(packet.phase), `Next handoff action prepared for ${packet.phase}.`, {
    phase: packet.phase,
    owner_lane: packet.owner_lane,
    expected_artifact: packet.expected_artifact,
    requires_human_approval: packet.requires_human_approval,
  }, ['next-action.json'], packet.owner_lane));

  if (has('json')) {
    console.log(JSON.stringify(packet, null, 2));
    return;
  }
  console.log('# Design Handoff Continue\n');
  console.log(`Mission: ${handoff.mission_id}`);
  console.log(`Phase: ${packet.phase}`);
  console.log(`Lane: ${packet.owner_lane}`);
  console.log(`Expected artifact: ${packet.expected_artifact || '(none)'}`);
  if (packet.command) console.log(`Command: ${packet.command}`);
  if (packet.requires_human_approval) console.log('Approval: required');
  console.log('\n## Prompt / Action\n');
  console.log(packet.prompt);
  console.log('\nStatus: design-handoff-continue-ready');
}

function writeStageArtifact(dir, handoff, phase) {
  const output = phase.id === 'kimi_implementation' && value('target-repo', '')
    ? 'implementation.result.json'
    : phase.output;
  const file = artifactPath(dir, output);
  const common = {
    mission_id: handoff.mission_id,
    phase: phase.id,
    request: handoff.request,
    generated_at: now(),
    source: 'cc-design-handoff stage executor',
  };
  if (phase.id === 'asset_decomposition') {
    writeJson(file, {
      schema: 'ai-coding-os.creative-asset-kit.v1',
      ...common,
      reference: phase.approved_artifact || 'visual.target.png',
      sequence: [
        { id: 'hero_background', status: 'approved_placeholder', usage: 'hero background implementation asset' },
        { id: 'primary_button', status: 'pending_if_needed', usage: 'exact CTA style primitive' },
        { id: 'section_divider', status: 'pending_if_needed', usage: 'page rhythm primitive' },
      ],
    });
  } else if (phase.id === 'design_dna') {
    const result = runDesignDnaExtraction(dir, handoff);
    if (!result.ok) throw new Error(`design_dna failed: ${result.error}`);
    writeJson(file, { ...common, ...result.dna });
  } else if (phase.id === 'kimi_implementation') {
    const result = runKimiImplementation(dir, handoff);
    if (!result.ok) throw new Error(`kimi_implementation failed: ${result.error}`);
    writeJson(file, { ...common, ...result.plan });
  } else if (phase.id === 'claude_review') {
    const result = runClaudeReview(dir, handoff);
    if (!result.ok) throw new Error(`claude_review failed: ${result.error}`);
    writeJson(file, { ...common, ...result.review });
  } else if (phase.id === 'codex_proof') {
    const result = runCodexProof(dir, handoff);
    if (!result.ok) throw new Error(`codex_proof failed: ${result.error}`);
    writeJson(file, { ...common, ...result.proof });
  } else {
    writeJson(file, { schema: 'ai-coding-os.stage-artifact.v1', ...common });
  }
  return relative(dir, file);
}

function generateCreativeReference(dir, handoff) {
  const out = path.join(dir, 'visual.target.png');
  const prompt = [
    `Create one premium frontend creative-direction reference image for: ${handoff.request}`,
    'This is a visual target for implementation, not a finished website screenshot.',
    'Prioritize cinematic composition, premium spacing, strong hierarchy, native-code-friendly text zones, and one clear continuation/action surface.',
    'Avoid dense dashboards, generic SaaS cards, visible routing/model mechanics, and baked-in body copy that should be native HTML.',
  ].join('\n');

  if (process.env.CC_DESIGN_HANDOFF_IMAGE_OFFLINE === '1') {
    writeTinyPng(out);
    writeJson(path.join(dir, 'visual.reference.manifest.json'), {
      schema: 'ai-coding-os.visual-reference-manifest.v1',
      mission_id: handoff.mission_id,
      generated_at: now(),
      source: 'offline_fixture',
      live_lane_call: false,
      output: 'visual.target.png',
      prompt,
    });
    return 'visual.target.png';
  }

  if (!has('image-api-ok')) {
    const packet = actionPacket(handoff, phaseById(handoff, 'creative_reference'));
    writeJson(path.join(dir, 'visual.reference.request.json'), {
      ...packet,
      source: 'chatgpt_subscription_manual',
      live_lane_call: false,
      billing: 'chatgpt_subscription_or_manual_upload',
      instructions: [
        'Open ChatGPT Desktop or logged-in ChatGPT web.',
        'Paste the prompt below into the existing/new Image 2.0 thread.',
        'Save the approved output as visual.target.png in this mission directory.',
        'Then run cc-design-handoff approve --phase creative_reference --artifact visual.target.png.',
      ],
      prompt,
    });
    return '';
  }

  const res = run(path.join(root, 'bin', 'cc-image'), [
    '--json',
    '--no-open',
    '-p',
    value('image-preset', 'hero_banner'),
    '-s',
    value('image-size', '1536x1024'),
    '-o',
    out,
    prompt,
  ], { timeout: 300000, maxBuffer: 1024 * 1024 * 8 });
  const output = `${res.stdout || ''}${res.stderr || ''}`.trim();
  fs.writeFileSync(path.join(dir, 'visual.reference.raw.json'), `${output}\n`);
  if (res.status !== 0) throw new Error(output || `cc-image exited ${res.status}`);
  const parsed = extractJson(output);
  writeJson(path.join(dir, 'visual.reference.manifest.json'), {
    schema: 'ai-coding-os.visual-reference-manifest.v1',
    mission_id: handoff.mission_id,
    generated_at: now(),
    source: 'cc-image-api',
    billing: 'openai_platform_api',
    live_lane_call: true,
    model: parsed?.model || 'gpt-image-2',
    output: 'visual.target.png',
    run_dir: parsed?.runDir || '',
    manifest_path: parsed?.manifestPath || '',
    prompt,
  });
  return 'visual.target.png';
}

function assetExtractionPrompt(assetId, handoff) {
  const prompts = {
    'hero-background': 'Extract only the hero background from the approved reference. Remove all text, UI labels, buttons, and icons. Preserve lighting, atmosphere, depth, and composition-safe negative space for native HTML overlay.',
    'primary-button-style': 'Extract only the primary button visual primitive from the approved reference. Preserve material, glow, radius, shadow, and interaction feel. No surrounding layout.',
    'section-divider': 'Extract only the section divider or transition texture from the approved reference. Preserve rhythm and atmosphere. No text.',
    'feature-banner-background': 'Extract only the banner background/surface from the approved reference. Preserve premium lighting and hierarchy-safe empty space. No text.',
  };
  return [
    prompts[assetId] || `Extract only the ${assetId} implementation asset from the approved reference. No text. Preserve the approved visual direction.`,
    `Mission request: ${handoff.request}`,
    'Return a clean implementation asset that Kimi can place behind native text and controls.',
  ].join('\n');
}

function upsertAssetKit(dir, handoff, asset) {
  const file = path.join(dir, 'creative.asset-kit.json');
  const kit = fs.existsSync(file) ? readJson(file) : {
    schema: 'ai-coding-os.creative-asset-kit.v1',
    mission_id: handoff.mission_id,
    phase: 'asset_decomposition',
    request: handoff.request,
    generated_at: now(),
    source: 'cc-design-handoff asset extractor',
    mode: 'sequential_approved_extraction',
    owner_lane: 'chatgpt-image',
    canonical_reference: { path: 'visual.target.png', owner_lane: 'chatgpt-image' },
    rules: {
      extract_one_asset_at_a_time: true,
      approval_required_before_next_asset: true,
      use_same_image_thread_after_reference_approval: true,
      implementation_model_must_not_reinvent_visual_direction: true,
      native_text_and_interactions_stay_in_code: true,
      do_not_parallelize_extraction_requests: true,
    },
    assets: [],
    handoff_to_kimi: {
      include: ['canonical_reference', 'approved_assets', 'design.dna.json', 'implementation.plan.json'],
    },
  };
  const assets = Array.isArray(kit.assets) ? kit.assets : [];
  const next = { sequence: assets.find((item) => item.id === asset.id)?.sequence || assets.length + 1, ...asset };
  const index = assets.findIndex((item) => item.id === asset.id);
  if (index >= 0) assets[index] = next;
  else assets.push(next);
  kit.assets = assets.sort((a, b) => Number(a.sequence) - Number(b.sequence));
  kit.updated_at = now();
  writeJson(file, kit);
  return 'creative.asset-kit.json';
}

function extractAsset(dir, handoff) {
  const assetId = slug(value('extract-asset', value('asset', 'hero-background')));
  const assetPath = path.join('assets', `${assetId}.png`);
  const output = path.join(dir, assetPath);
  const prompt = assetExtractionPrompt(assetId, handoff);

  if (process.env.CC_DESIGN_HANDOFF_IMAGE_OFFLINE === '1') {
    writeTinyPng(output);
    return upsertAssetKit(dir, handoff, {
      id: assetId,
      role: assetId.replace(/-/g, ' '),
      asset_type: 'image',
      path: assetPath,
      extraction_prompt: prompt,
      implementation_usage: 'Use as an approved visual primitive in the Kimi implementation pass.',
      approval_gate: 'human_approves_asset_before_next_extraction',
      source: 'offline_fixture',
      live_lane_call: false,
    });
  }

  if (!has('image-api-ok')) {
    writeJson(path.join(dir, 'asset.extraction.request.json'), {
      ...actionPacket(handoff, phaseById(handoff, 'asset_decomposition')),
      source: 'chatgpt_subscription_manual',
      live_lane_call: false,
      billing: 'chatgpt_subscription_or_manual_upload',
      asset_id: assetId,
      prompt,
      instructions: [
        'Use the same ChatGPT/Image 2.0 thread as the approved visual reference.',
        'Paste the extraction prompt below.',
        `Save the approved output as assets/${assetId}.png in this mission directory.`,
        'Then approve creative.asset-kit.json or rerun extraction with --image-api-ok if you intentionally want API billing.',
      ],
      note: 'No API billing used. This is a ChatGPT subscription/manual generation packet.',
    });
    return '';
  }

  const res = run(path.join(root, 'bin', 'cc-image'), [
    '--json',
    '--no-open',
    '-r',
    path.join(dir, 'visual.target.png'),
    '-s',
    value('image-size', '1536x1024'),
    '-o',
    output,
    prompt,
  ], { timeout: 300000, maxBuffer: 1024 * 1024 * 8 });
  const raw = `${res.stdout || ''}${res.stderr || ''}`.trim();
  fs.writeFileSync(path.join(dir, `asset.${assetId}.raw.json`), `${raw}\n`);
  if (res.status !== 0) throw new Error(raw || `cc-image exited ${res.status}`);
  const parsed = extractJson(raw);
  return upsertAssetKit(dir, handoff, {
    id: assetId,
    role: assetId.replace(/-/g, ' '),
    asset_type: 'image',
    path: assetPath,
    extraction_prompt: prompt,
    implementation_usage: 'Use as an approved visual primitive in the Kimi implementation pass.',
    approval_gate: 'human_approves_asset_before_next_extraction',
    source: 'cc-image-api',
    billing: 'openai_platform_api',
    live_lane_call: true,
    raw_output_artifact: `asset.${assetId}.raw.json`,
    run_dir: parsed?.runDir || '',
    manifest_path: parsed?.manifestPath || '',
  });
}

function offlineDesignDna(handoff) {
  return {
    schema: 'ai-coding-os.design-dna.v1',
    mission_id: handoff.mission_id,
    phase: 'design_dna',
    request: handoff.request,
    generated_at: now(),
    source: 'offline_fixture',
    live_lane_call: false,
    visual_density: 'low',
    section_pacing: 'cinematic',
    typography_rhythm: 'editorial-confident',
    surface_language: 'glass-soft with atmospheric depth',
    shadow_language: 'diffused environmental shadows',
    motion_energy: 'subtle-premium',
    emotional_frame: 'calm momentum, premium trust, continuity',
    visual_noise_budget: 'minimal',
    implementation_constraints: [
      'native text and controls remain selectable and accessible',
      'approved reference owns composition; implementation must not reinvent taste',
      'route/provider mechanics stay behind proof mode',
    ],
  };
}

function runDesignDnaExtraction(dir, handoff) {
  if (process.env.CC_DESIGN_HANDOFF_OFFLINE === '1') return { ok: true, dna: offlineDesignDna(handoff) };
  const contextSummary = summarizeHandoffContext(dir, handoff, 'design_dna', [
    'creative.brief.json',
    'visual.reference.manifest.json',
    'creative.asset-kit.json',
  ]);
  const prompt = [
    'You are the design DNA extraction lane for a taste-driven frontend handoff.',
    'Extract implementation-ready design DNA from the mission artifacts. Return only valid JSON.',
    '',
    'Required JSON shape:',
    '{"schema":"ai-coding-os.design-dna.v1","visual_density":"...","section_pacing":"...","typography_rhythm":"...","surface_language":"...","shadow_language":"...","motion_energy":"...","emotional_frame":"...","visual_noise_budget":"...","implementation_constraints":["..."],"risks":["..."]}',
    '',
    `Mission: ${handoff.mission_id}`,
    `Request: ${handoff.request}`,
    '',
    'DeepSeek context summary:',
    JSON.stringify(contextSummary, null, 2),
  ].join('\n');
  const res = run('claude', ['--print', prompt], { timeout: 180000, maxBuffer: 1024 * 1024 * 8 });
  const output = `${res.stdout || ''}${res.stderr || ''}`.trim();
  fs.writeFileSync(path.join(dir, 'design.dna.raw.md'), `${output}\n`);
  if (res.status !== 0) return { ok: false, error: output || `claude exited ${res.status}` };
  const parsed = extractJson(output);
  const dna = parsed || {
    schema: 'ai-coding-os.design-dna.v1',
    visual_density: '',
    section_pacing: '',
    typography_rhythm: '',
    surface_language: '',
    shadow_language: '',
    motion_energy: '',
    emotional_frame: '',
    visual_noise_budget: '',
    implementation_constraints: [],
    raw_output_artifact: 'design.dna.raw.md',
  };
  dna.schema = dna.schema || 'ai-coding-os.design-dna.v1';
  dna.mission_id = handoff.mission_id;
  dna.phase = 'design_dna';
  dna.request = handoff.request;
  dna.generated_at = now();
  dna.source = 'claude-cli';
  dna.live_lane_call = true;
  dna.raw_output_artifact = 'design.dna.raw.md';
  return { ok: true, dna };
}

function writeDeployReceipt(dir, handoff) {
  const deployContext = deployProofContext(dir);
  if (!deployContext.ok && !has('force')) throw new Error(deployContext.error);
  if (has('live-tel')) return writeTelDeployReceipt(dir, handoff);
  const url = value('deploy-url', '');
  if (!url) return '';
  const receipt = {
    schema: 'ai-coding-os.deploy-receipt.v1',
    mission_id: handoff.mission_id,
    ts: now(),
    provider: value('provider', 'vercel'),
    url,
    git_sha: value('git-sha', ''),
    rollback_token: value('rollback-token', ''),
    tel_policy: value('tel-policy', 'vercel.deploy'),
    credential_boundary: 'TEL',
    live_tel_call: false,
    implementation: deployContext.implementation,
    codex_proof: deployContext.codex_proof,
    note: 'Receipt records an approved deploy result. It does not expose credentials or perform a deploy by itself.',
  };
  writeJson(path.join(dir, 'deploy.receipt.json'), receipt);
  return 'deploy.receipt.json';
}

function deployProofContext(dir) {
  const implementationFile = path.join(dir, 'implementation.result.json');
  const codexFile = path.join(dir, 'codex.proof.json');
  const implementation = fs.existsSync(implementationFile) ? readJson(implementationFile) : null;
  const codexProof = fs.existsSync(codexFile) ? readJson(codexFile) : null;
  if (!codexProof) {
    return {
      ok: false,
      error: 'codex.proof.json is required before deploy receipt can be recorded',
      implementation: implementationSummary(implementation),
      codex_proof: null,
    };
  }
  if (String(codexProof.verdict || '').startsWith('blocked_')) {
    return {
      ok: false,
      error: `Codex proof is not deploy-ready: ${codexProof.verdict}`,
      implementation: implementationSummary(implementation),
      codex_proof: codexProofSummary(codexProof),
    };
  }
  return {
    ok: true,
    implementation: implementationSummary(implementation),
    codex_proof: codexProofSummary(codexProof),
  };
}

function implementationSummary(implementation) {
  if (!implementation) return null;
  return {
    artifact: 'implementation.result.json',
    target_repo: implementation.target_repo || '',
    target_head_before: implementation.target_head_before || '',
    target_head_after: implementation.target_head_after || '',
    changed_files: implementation.changed_files || [],
    verdict: implementation.verdict || '',
  };
}

function codexProofSummary(proof) {
  if (!proof) return null;
  return {
    artifact: 'codex.proof.json',
    source: proof.source || '',
    verdict: proof.verdict || '',
    changed_files: proof.changed_files || [],
    commands: (proof.commands || []).map((command) => ({
      command: command.command,
      ok: command.ok,
      exit_code: command.exit_code,
    })),
  };
}

function writeTelDeployReceipt(dir, handoff) {
  const deployContext = deployProofContext(dir);
  if (!deployContext.ok && !has('force')) throw new Error(deployContext.error);
  const provider = value('provider', 'vercel');
  if (provider !== 'vercel') throw new Error(`TEL deploy verification only supports provider=vercel, got ${provider}`);
  const deployment = value('deployment', value('deployment-id', value('deploy-url', '')));
  if (!deployment) return '';
  const dryRun = has('tel-dry-run');
  const argsJson = JSON.stringify({ idOrUrl: deployment });
  const telArgs = [
    ...(dryRun ? ['--dry-run'] : []),
    'vercel',
    'get_deployment',
    argsJson,
  ];
  const client = path.join(os.homedir(), '.Codex', 'tel', 'client', 'tel-call.sh');
  const res = run(client, telArgs, { timeout: 120000, maxBuffer: 1024 * 1024 * 8 });
  const output = `${res.stdout || ''}${res.stderr || ''}`.trim();
  fs.writeFileSync(path.join(dir, 'tel.deploy.raw.json'), `${output}\n`);
  const parsed = extractJson(output);
  if (res.status !== 0 || !parsed?.ok) {
    throw new Error(output || `TEL ${provider}.get_deployment exited ${res.status}`);
  }
  const result = parsed.result || {};
  const receipt = {
    schema: 'ai-coding-os.deploy-receipt.v1',
    mission_id: handoff.mission_id,
    ts: now(),
    provider,
    deployment,
    url: value('deploy-url', result.url || result.inspectorUrl || ''),
    git_sha: value('git-sha', result.meta?.githubCommitSha || result.gitSource?.sha || ''),
    rollback_token: value('rollback-token', parsed.undo_token || ''),
    tel_policy: 'vercel.get_deployment',
    credential_boundary: 'TEL',
    tel_call: true,
    live_tel_call: !dryRun,
    tel_dry_run: dryRun,
    tel_audit_id: parsed.audit_id || '',
    tel_undo_token: parsed.undo_token || null,
    tel_response_artifact: 'tel.deploy.raw.json',
    implementation: deployContext.implementation,
    codex_proof: deployContext.codex_proof,
    verification: {
      ok: true,
      action: 'vercel.get_deployment',
      state: result.state || result.readyState || null,
      dry_run: dryRun,
    },
    note: dryRun
      ? 'TEL dry-run verified policy and request shape without calling Vercel.'
      : 'TEL verified the deployment through the credential boundary.',
  };
  writeJson(path.join(dir, 'deploy.receipt.json'), receipt);
  return 'deploy.receipt.json';
}

function reviewPassed(review) {
  const verdict = String(review.verdict || '').toLowerCase();
  if (/\bfail|blocked|not[_ -]?ready|reject/.test(verdict)) return false;
  const scores = Object.values(review.scores || {}).map(Number).filter(Number.isFinite);
  const threshold = Number(review.threshold || 90);
  return scores.length > 0 && scores.every((score) => score >= threshold);
}

function offlineClaudeReview(handoff) {
  return {
    schema: 'ai-coding-os.taste-validation.v1',
    mission_id: handoff.mission_id,
    phase: 'claude_review',
    request: handoff.request,
    generated_at: now(),
    source: 'offline_fixture',
    live_lane_call: false,
    threshold: 90,
    scores: {
      creative_fidelity: 92,
      hierarchy: 92,
      spacing: 91,
      material_quality: 90,
      responsiveness: 90,
      accessibility: 91,
    },
    verdict: 'fixture_passes_threshold_for_portable_check_only',
  };
}

function runProofCommand(commandLine, timeout = 120000) {
  const res = run('/bin/zsh', ['-lc', commandLine], { timeout, maxBuffer: 1024 * 1024 * 8 });
  return {
    command: commandLine,
    ok: res.status === 0,
    exit_code: res.status || 0,
    output: `${res.stdout || ''}${res.stderr || ''}`.trim().slice(0, 12000),
  };
}

function browserProofUrls(dir) {
  const urls = values('browser-url').flatMap((item) => item.split(',')).map((item) => item.trim()).filter(Boolean);
  const implementationFile = path.join(dir, 'implementation.result.json');
  if (fs.existsSync(implementationFile)) {
    const implementation = readJson(implementationFile);
    for (const item of implementation.browser_proof || []) {
      if (typeof item === 'string' && /^(https?:|data:|file:)/.test(item)) urls.push(item);
      else if (item && typeof item.url === 'string') urls.push(item.url);
    }
  }
  return Array.from(new Set(urls));
}

function runBrowserProofs(dir, handoff) {
  const urls = browserProofUrls(dir);
  if (!urls.length) return [];
  return urls.map((url, index) => {
    const artifact = `browser.proof.${index + 1}.json`;
    if (process.env.CC_DESIGN_HANDOFF_BROWSER_OFFLINE === '1' || process.env.CC_DESIGN_HANDOFF_OFFLINE === '1') {
      const proof = {
        healthy: true,
        mode: 'offline_fixture',
        url,
        session: `${handoff.mission_id}-browser-${index + 1}`,
        proof: {
          nonce: `offline-${index + 1}`,
          origin: url,
          content: 'offline browser proof fixture',
          truncated: false,
        },
      };
      writeJson(path.join(dir, artifact), proof);
      return {
        command: `cc-browser-proof --json --url ${JSON.stringify(url)}`,
        ok: true,
        exit_code: 0,
        artifact,
        output: 'offline browser proof fixture',
      };
    }
    const res = run(path.join(root, 'bin', 'cc-browser-proof'), [
      '--json',
      '--url',
      url,
      '--session',
      `${handoff.mission_id}-browser-${index + 1}`,
      '--max-chars',
      value('browser-max-chars', '8000'),
    ], { timeout: 120000, maxBuffer: 1024 * 1024 * 8 });
    const raw = `${res.stdout || ''}${res.stderr || ''}`.trim();
    fs.writeFileSync(path.join(dir, artifact), `${raw}\n`);
    const parsed = extractJson(raw);
    const healthy = parsed?.healthy === true;
    return {
      command: `cc-browser-proof --json --url ${url}`,
      ok: res.status === 0 && healthy,
      exit_code: res.status || 0,
      artifact,
      mode: parsed?.mode || 'unknown',
      healthy,
      output: raw.slice(0, 12000),
    };
  });
}

function offlineCodexProof(handoff) {
  return {
    schema: 'ai-coding-os.codex-proof.v1',
    mission_id: handoff.mission_id,
    phase: 'codex_proof',
    request: handoff.request,
    generated_at: now(),
    source: 'offline_fixture',
    live_lane_call: false,
    verdict: 'fixture_passes_for_portable_check_only',
    commands: [
      { command: 'git status --short', ok: true, exit_code: 0 },
      { command: 'cc-frontend-wedge-check', ok: true, exit_code: 0 },
      { command: 'cc-taste-benchmark-check', ok: true, exit_code: 0 },
    ],
    changed_files: [],
  };
}

function runCodexProof(dir, handoff) {
  if (process.env.CC_DESIGN_HANDOFF_OFFLINE === '1' && !browserProofUrls(dir).length) return { ok: true, proof: offlineCodexProof(handoff) };
  const commands = [
    'git status --short',
    'git diff --stat',
    'bin/cc-frontend-wedge-check',
    'bin/cc-taste-benchmark-check',
  ].map((cmd) => runProofCommand(cmd));
  const browserProofs = runBrowserProofs(dir, handoff);
  commands.push(...browserProofs);
  const statusOutput = commands.find((item) => item.command === 'git status --short')?.output || '';
  const changedFiles = statusOutput.split('\n').map((line) => line.trim()).filter(Boolean);
  const failed = commands.filter((item) => !item.ok);
  return {
    ok: true,
    proof: {
      schema: 'ai-coding-os.codex-proof.v1',
      mission_id: handoff.mission_id,
      phase: 'codex_proof',
      request: handoff.request,
      generated_at: now(),
      source: 'codex-local',
      live_lane_call: process.env.CC_DESIGN_HANDOFF_OFFLINE === '1' ? false : true,
      verdict: failed.length ? 'blocked_failed_local_proof' : 'ready_for_tel_deploy_gate',
      changed_files: changedFiles,
      commands,
      browser_in_loop: {
        required: browserProofs.length > 0,
        proofs: browserProofs.map((item) => ({
          artifact: item.artifact,
          ok: item.ok,
          mode: item.mode || null,
          healthy: item.healthy ?? null,
        })),
      },
      required_next_gate: failed.length ? 'fix_failed_codex_proof_commands' : 'human_approves_credentialed_deploy',
    },
  };
}

function offlineKimiImplementation(handoff) {
  return {
    schema: 'ai-coding-os.implementation-plan.v1',
    mission_id: handoff.mission_id,
    phase: 'kimi_implementation',
    request: handoff.request,
    generated_at: now(),
    source: 'offline_fixture',
    live_lane_call: false,
    owner_lane: 'kimi-webbridge',
    inputs: ['visual.target.png', 'creative.asset-kit.json', 'design.dna.json'],
    expected_outputs: ['responsive UI code', 'browser screenshot proof', 'accessibility-safe native controls'],
    implementation_steps: [
      'Implement the approved reference as production UI.',
      'Use generated assets only where they preserve visual fidelity.',
      'Keep provider mechanics outside the primary interface.',
    ],
    verification: ['desktop screenshot', 'mobile screenshot', 'accessibility smoke', 'visual fidelity review'],
  };
}

function gitSnapshot(repo) {
  const abs = path.resolve(repo);
  const inside = run('git', ['-C', abs, 'rev-parse', '--is-inside-work-tree'], { timeout: 30000 });
  if (inside.status !== 0) {
    return {
      is_git_repo: false,
      status_short: '',
      changed_files: [],
      head: null,
      error: `${inside.stdout || ''}${inside.stderr || ''}`.trim(),
    };
  }
  const status = run('git', ['-C', abs, 'status', '--short'], { timeout: 30000, maxBuffer: 1024 * 1024 * 4 });
  const head = run('git', ['-C', abs, 'rev-parse', '--short', 'HEAD'], { timeout: 30000 });
  const changedFiles = String(status.stdout || '')
    .split('\n')
    .filter((line) => line.trim())
    .map((line) => line.length > 3 ? line.slice(3).trim() : line.trim())
    .map((file) => file.includes(' -> ') ? file.split(' -> ').pop().trim() : file)
    .filter(Boolean);
  return {
    is_git_repo: true,
    status_short: String(status.stdout || '').trim(),
    changed_files: changedFiles,
    head: head.status === 0 ? head.stdout.trim() : null,
  };
}

function commandAvailable(name) {
  return run('/bin/zsh', ['-lc', `command -v ${name}`], { timeout: 30000 }).status === 0;
}

function writeKimiTargetPrompt(dir, handoff, targetRepo, before) {
  const prompt = [
    'You are the Kimi UI/browser implementation lane for a taste-driven frontend handoff.',
    '',
    'Implement the approved creative direction into the target repository.',
    'Do not redesign from scratch. Preserve the approved visual direction, design DNA, asset kit, native text, accessibility, and responsive behavior.',
    'Keep the change focused. Do not deploy. Run the target repo checks when obvious.',
    '',
    `Mission: ${handoff.mission_id}`,
    `Request: ${handoff.request}`,
    `Target repo: ${targetRepo}`,
    `Target HEAD before: ${before.head || 'unknown'}`,
    '',
    'Mission artifact directory is attached as an additional workspace directory.',
    'Read these inputs first:',
    '- visual.target.png',
    '- visual.reference.manifest.json',
    '- creative.asset-kit.json',
    '- design.dna.json',
    '- implementation.plan.json when present',
    '',
    'When done, reply with JSON only:',
    '{"schema":"ai-coding-os.implementation-result.v1","summary":"...","changed_files":["..."],"checks_run":["..."],"browser_proof":["..."],"risks":["..."]}',
  ].join('\n');
  fs.writeFileSync(path.join(dir, 'kimi.implementation.prompt.md'), `${prompt}\n`);
  return prompt;
}

function offlineKimiTargetImplementation(dir, handoff, targetRepo, before) {
  return {
    schema: 'ai-coding-os.implementation-result.v1',
    mission_id: handoff.mission_id,
    phase: 'kimi_implementation',
    request: handoff.request,
    generated_at: now(),
    source: 'offline_fixture',
    live_lane_call: false,
    owner_lane: 'kimi-webbridge',
    target_repo: targetRepo,
    target_head_before: before.head,
    target_head_after: before.head,
    changed_files: before.changed_files,
    checks_run: [],
    browser_proof: [],
    raw_output_artifact: null,
    verdict: before.changed_files.length ? 'ready_for_claude_review' : 'blocked_no_target_changes',
  };
}

function runKimiTargetImplementation(dir, handoff, targetRepo) {
  const repo = path.resolve(targetRepo);
  if (!fs.existsSync(repo)) return { ok: false, error: `target repo does not exist: ${repo}` };
  const before = gitSnapshot(repo);
  if (!before.is_git_repo) return { ok: false, error: `target repo is not a git repo: ${repo}` };
  const prompt = writeKimiTargetPrompt(dir, handoff, repo, before);
  if (process.env.CC_DESIGN_HANDOFF_OFFLINE === '1') {
    return { ok: true, plan: offlineKimiTargetImplementation(dir, handoff, repo, before) };
  }
  if (!commandAvailable('kimi')) return { ok: false, error: 'kimi CLI not found in PATH' };

  const res = run('kimi', [
    '--work-dir',
    repo,
    '--add-dir',
    dir,
    '--print',
    '--final-message-only',
    '--afk',
    '--yes',
    '--prompt',
    prompt,
  ], { cwd: repo, timeout: 600000, maxBuffer: 1024 * 1024 * 12 });
  const output = `${res.stdout || ''}${res.stderr || ''}`.trim();
  fs.writeFileSync(path.join(dir, 'implementation.raw.md'), `${output}\n`);
  if (res.status !== 0) return { ok: false, error: output || `kimi exited ${res.status}` };

  const after = gitSnapshot(repo);
  const parsed = extractJson(output);
  const result = parsed && typeof parsed === 'object' ? parsed : {
    schema: 'ai-coding-os.implementation-result.v1',
    summary: String(output || '').split('\n').map((line) => line.trim()).filter(Boolean).slice(0, 12).join('\n'),
    raw_output_artifact: 'implementation.raw.md',
  };
  result.schema = result.schema || 'ai-coding-os.implementation-result.v1';
  result.mission_id = handoff.mission_id;
  result.phase = 'kimi_implementation';
  result.request = handoff.request;
  result.generated_at = now();
  result.source = 'kimi-cli';
  result.live_lane_call = true;
  result.owner_lane = 'kimi-webbridge';
  result.target_repo = repo;
  result.target_head_before = before.head;
  result.target_head_after = after.head;
  result.changed_files = after.changed_files;
  result.raw_output_artifact = 'implementation.raw.md';
  result.verdict = after.changed_files.length ? 'ready_for_claude_review' : 'blocked_no_target_changes';
  return { ok: true, plan: result };
}

function runKimiImplementation(dir, handoff) {
  const targetRepo = value('target-repo', '');
  if (targetRepo) return runKimiTargetImplementation(dir, handoff, targetRepo);
  if (process.env.CC_DESIGN_HANDOFF_OFFLINE === '1') return { ok: true, plan: offlineKimiImplementation(handoff) };
  const contextSummary = summarizeHandoffContext(dir, handoff, 'kimi_implementation', [
    'creative.asset-kit.json',
    'design.dna.json',
    'next-action.json',
  ]);
  const prompt = [
    'You are the Kimi design/browser implementation lane for a taste-driven frontend handoff.',
    'Create an implementation plan from the approved artifacts. Return only valid JSON.',
    '',
    'Required JSON shape:',
    '{"schema":"ai-coding-os.implementation-plan.v1","owner_lane":"kimi-webbridge","inputs":["..."],"implementation_steps":["..."],"files_to_touch":["..."],"responsive_checks":["..."],"browser_proof":["..."],"risks":["..."]}',
    '',
    `Mission: ${handoff.mission_id}`,
    `Request: ${handoff.request}`,
    '',
    'DeepSeek context summary:',
    JSON.stringify(contextSummary, null, 2),
  ].join('\n');

  const res = run('router-ask', ['--purpose', 'design', '--json', prompt], { timeout: 180000, maxBuffer: 1024 * 1024 * 8 });
  const output = `${res.stdout || ''}${res.stderr || ''}`.trim();
  fs.writeFileSync(path.join(dir, 'implementation.raw.md'), `${output}\n`);
  if (res.status !== 0) {
    return { ok: false, error: output || `router-ask exited ${res.status}` };
  }
  const parsed = extractJson(output);
  const text = parsed?.text || parsed?.result || parsed?.output || output;
  const inner = typeof text === 'string' ? extractJson(text) : text;
  const plan = inner && typeof inner === 'object' ? inner : {
    schema: 'ai-coding-os.implementation-plan.v1',
    owner_lane: 'kimi-webbridge',
    implementation_steps: String(text || output).split('\n').map((line) => line.trim()).filter(Boolean).slice(0, 20),
    raw_output_artifact: 'implementation.raw.md',
  };
  plan.schema = plan.schema || 'ai-coding-os.implementation-plan.v1';
  plan.mission_id = handoff.mission_id;
  plan.phase = 'kimi_implementation';
  plan.request = handoff.request;
  plan.generated_at = now();
  plan.source = 'router-ask-design';
  plan.live_lane_call = true;
  plan.raw_output_artifact = 'implementation.raw.md';
  return { ok: true, plan };
}

function runClaudeReview(dir, handoff) {
  if (process.env.CC_DESIGN_HANDOFF_OFFLINE === '1') return { ok: true, review: offlineClaudeReview(handoff) };
  const contextSummary = summarizeHandoffContext(dir, handoff, 'claude_review', [
    'design-handoff.json',
    'creative.asset-kit.json',
    'design.dna.json',
    'implementation.plan.json',
    'implementation.result.json',
  ]);
  const prompt = [
    'You are the Claude review lane for a taste-driven frontend handoff.',
    'Review the mission artifacts below and return only valid JSON.',
    '',
    'Required JSON shape:',
    '{"schema":"ai-coding-os.taste-validation.v1","threshold":90,"scores":{"creative_fidelity":0,"hierarchy":0,"spacing":0,"material_quality":0,"responsiveness":0,"accessibility":0},"verdict":"...","risks":["..."],"required_fixes":["..."]}',
    '',
    `Mission: ${handoff.mission_id}`,
    `Request: ${handoff.request}`,
    '',
    'DeepSeek context summary:',
    JSON.stringify(contextSummary, null, 2),
  ].join('\n');

  const res = run('claude', ['--print', prompt], { timeout: 180000, maxBuffer: 1024 * 1024 * 8 });
  const output = `${res.stdout || ''}${res.stderr || ''}`.trim();
  fs.writeFileSync(path.join(dir, 'taste.validation.raw.md'), `${output}\n`);
  if (res.status !== 0) {
    return { ok: false, error: output || `claude exited ${res.status}` };
  }
  const parsed = extractJson(output);
  const review = parsed || {
    schema: 'ai-coding-os.taste-validation.v1',
    threshold: 90,
    scores: {},
    verdict: 'claude_review_returned_unstructured_output',
    raw_output_artifact: 'taste.validation.raw.md',
  };
  review.schema = review.schema || 'ai-coding-os.taste-validation.v1';
  review.mission_id = handoff.mission_id;
  review.phase = 'claude_review';
  review.request = handoff.request;
  review.generated_at = now();
  review.source = 'claude-cli';
  review.live_lane_call = true;
  review.raw_output_artifact = 'taste.validation.raw.md';
  return { ok: true, review };
}

const executeStage = createExecuteStage({
  actionPacket,
  activePhase,
  addCheckpointRecord,
  addMissionGitRecord,
  appendTimeline,
  artifactPath,
  completionStageFor,
  createPhaseCheckpoint,
  event,
  extractAsset,
  generateCreativeReference,
  has,
  loadMission,
  markComplete,
  missionDir,
  nextActionFor,
  now,
  path,
  phaseById,
  readJson,
  recordMissionGit,
  refreshProof,
  requestStageFor,
  reviewPassed,
  root,
  updateContextSummary,
  updateCostLedger,
  value,
  writeDeployReceipt,
  writeJson,
  writeStageArtifact,
});

if (has('check')) runDesignHandoffCheck({ root, run });
else if (subcommand === 'list') listMissions();
else if (subcommand === 'status') showStatus();
else if (subcommand === 'continue') continueMission();
else if (subcommand === 'approve') approvePhase();
else if (subcommand === 'execute') executeStage();
else createHandoff();
