<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>bio.claude.federation-health</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <!-- Quiet by default — only emits when alerts present. --notify pops a
         macOS notification on collapse. Threshold ≥5 collapses in 24h. -->
    <string>$HOME/local/bin/cc-federation-health --hours 24 --threshold 5 --quiet --notify &gt;&gt; $HOME/Library/Logs/federation-health.log 2&gt;&amp;1</string>
  </array>
  <!-- Daily at 09:13 local (offset minute to avoid the :00/:15/:30/:45 cluster
       that other launchd agents converge on). -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>9</integer>
    <key>Minute</key><integer>13</integer>
  </dict>
  <key>StandardOutPath</key><string>/tmp/federation-health.log</string>
  <key>StandardErrorPath</key><string>/tmp/federation-health.err</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>/Users/leonardofibonacci/.local/share/fnm/aliases/default/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
