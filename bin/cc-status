#!/usr/bin/env bash
# Pretty-print cc-loop state from ~/.claude/cc-loop.state and tail the log.
set -u
state="$HOME/.claude/cc-loop.state"
log="$HOME/.claude/cc-loop.log"
flag="$HOME/.cc-paused"

now=$(date +%s)
fmt_age() {
  local ts="$1"
  [ -z "$ts" ] && { echo "(never)"; return; }
  local age=$(( now - ts ))
  if   [ $age -lt 60 ];    then echo "${age}s ago"
  elif [ $age -lt 3600 ];  then echo "$((age/60))m ago"
  elif [ $age -lt 86400 ]; then echo "$((age/3600))h ago"
  else                          echo "$((age/86400))d ago"
  fi
}

field() { grep -E "^${1}=" "$state" 2>/dev/null | tail -1 | cut -d= -f2-; }

if [ -f "$flag" ]; then
  echo "STATUS: paused (touch-flag at $flag)"
else
  echo "STATUS: active (no pause flag)"
fi

if [ ! -f "$state" ]; then
  echo "STATE:  none (cc-loop has never run on this box)"
else
  last_event=$(field last_event); last_event="${last_event:-normal}"
  errs=$(field consecutive_errors); errs="${errs:-0}"
  echo "STATE:"
  printf '  started:             %s\n' "$(fmt_age "$(field started)")"
  printf '  last_run:            %s\n' "$(fmt_age "$(field last_run)")"
  printf '  last_exit:           %s\n' "$(field last_exit)"
  printf '  last_event:          %s\n' "$last_event"
  printf '  consecutive_errors:  %s\n' "$errs"
fi

echo
if [ -f "$log" ]; then
  echo "LOG (last 15 lines from $log):"
  tail -15 "$log" | sed 's/^/  /'
else
  echo "LOG:    none yet at $log"
fi

# launchd state, if loaded
if launchctl list | grep -q com.user.cc-loop; then
  echo
  echo "LAUNCHD: com.user.cc-loop is loaded"
  launchctl list | grep com.user.cc-loop | sed 's/^/  /'
else
  echo
  echo "LAUNCHD: com.user.cc-loop NOT loaded (manual mode or not installed)"
fi
