#!/usr/bin/env bash
set -u

DOTFILES="${DOTFILES:-$HOME/dotfiles}"
prompt="${CC_RELEASE_PROMPT:-debug this repo and verify the safest next step}"
browser_url="${CC_RELEASE_BROWSER_URL:-data:text/html,<title>Release Check</title><body>release check proof</body>}"
max_chars="${CC_RELEASE_BROWSER_MAX_CHARS:-800}"
version="${CC_RELEASE_VERSION:-v0.1.0-rc8}"
log_dir="${CC_RELEASE_LOG_DIR:-$(mktemp -d "${TMPDIR:-/tmp}/cc-release-check.XXXXXX")}"
pass=0
fail=0

usage() {
  printf 'Usage: cc-release-check [--version TAG] [--prompt TEXT] [--browser-url URL] [--max-chars N]\n'
}

while (($#)); do
  case "$1" in
  --prompt)
    shift
    prompt="${1:-$prompt}"
    ;;
  --browser-url)
    shift
    browser_url="${1:-$browser_url}"
    ;;
  --max-chars)
    shift
    max_chars="${1:-$max_chars}"
    ;;
  --version)
    shift
    version="${1:-$version}"
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  *)
    printf 'Unknown argument: %s\n' "$1" >&2
    usage >&2
    exit 2
    ;;
  esac
  shift
done

slug() {
  printf '%s' "$1" | tr '[:upper:] /' '[:lower:]--' | tr -cd 'a-z0-9._-'
}

run_gate() {
  local name="$1" expect="$2" tmp ok
  shift 2
  tmp="$log_dir/$(slug "$name").log"
  ok=0

  printf '\n## %s\n' "$name"
  if "$@" >"$tmp" 2>&1; then
    ok=1
  fi
  if [ -n "$expect" ] && ! grep -Eq "$expect" "$tmp"; then
    ok=0
  fi

  if [ "$ok" = 1 ]; then
    printf 'ok   %s\n' "$name"
    pass=$((pass + 1))
  else
    printf 'fail %s\n' "$name"
    printf 'log  %s\n' "$tmp"
    sed 's/^/     /' "$tmp" | sed -n '1,80p'
    fail=$((fail + 1))
  fi
}

run_shell_gate() {
  local name="$1" expect="$2" command="$3"
  run_gate "$name" "$expect" bash -lc "$command"
}

printf '# Release Check\n\n'
printf 'Generated: %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
printf 'Dotfiles: %s\n' "$DOTFILES"
printf 'Logs: %s\n' "$log_dir"
printf 'Prompt: %s\n' "$prompt"
printf 'Browser URL: %s\n' "$browser_url"
printf 'Version: %s\n' "$version"

cd "$DOTFILES" || exit 1

run_gate "First-run doctor" '^Status: first-run-ready$' "$DOTFILES/install.sh" --dry-run
run_gate "Product readiness" '^Status: product-ready$' "$DOTFILES/bin/cc-product-readiness"
run_gate "Five-minute demo" '^passed=4 failed=0$' "$DOTFILES/bin/cc-demo-five-minute" --prompt "$prompt" --browser-url "$browser_url" --max-chars "$max_chars"
run_gate "Fixture demo" 'Fixture: .*/cc-demo-fixture|Selected:  precision' "$DOTFILES/bin/cc-demo-fixture"
run_gate "Weekly health" 'weekly health: all [0-9]+ green' "$DOTFILES/bin/cc-health-weekly" --verbose
run_gate "Cockpit package" 'Packaged|\.vsix' "$DOTFILES/bin/cc-package-cockpit"
run_gate "Release bundle" 'Bundle: .*/dist/ai-coding-os-.*\.tar\.gz' "$DOTFILES/bin/cc-release-bundle" "$version"
run_gate "Cockpit media capture" 'Media written to .*/docs/media/cockpit' "$DOTFILES/bin/cc-cockpit-capture"
run_shell_gate "Cockpit media files" 'PNG image data|GIF image data' "file '$DOTFILES'/docs/media/cockpit/*"
run_shell_gate "Git tree clean" '^## ' "test -z \"\$(git status --short)\" && git status --short --branch"
run_shell_gate "Git upstream synced" '^synced$' "git fetch --quiet && test \"\$(git rev-parse HEAD)\" = \"\$(git rev-parse @{u})\" && printf 'synced\n'"

printf '\n## Summary\n\n'
printf 'passed=%s failed=%s\n' "$pass" "$fail"
printf 'logs=%s\n' "$log_dir"

[ "$fail" -eq 0 ]
