#!/usr/bin/env bash
# cc-router-smoke — deterministic dry-run checks for the global model router.
set -euo pipefail

ROUTER="${AI_INTENT_ROUTER:-$HOME/AI-SYSTEM-V2/scripts/intent-route.sh}"

[ -x "$ROUTER" ] || {
  echo "cc-router-smoke: missing router at $ROUTER" >&2
  exit 1
}

failures=0

check_route() {
  local expected_class="$1"
  local expected_platform="$2"
  local prompt="$3"
  local receipt
  local actual_class
  local actual_platform

  receipt="$("$ROUTER" --dry-run "$prompt" 2>/dev/null | sed -n 's/^  Receipt:   //p' | tail -1)"
  actual_class="$(node -e 'const r=JSON.parse(process.argv[1]); process.stdout.write(r.final_class || "")' "$receipt")"
  actual_platform="$(node -e 'const r=JSON.parse(process.argv[1]); process.stdout.write(r.platform || "")' "$receipt")"

  if [ "$actual_class/$actual_platform" = "$expected_class/$expected_platform" ]; then
    printf 'ok   %s -> %s/%s\n' "$prompt" "$actual_class" "$actual_platform"
  else
    printf 'fail %s -> expected %s/%s, got %s/%s\n' "$prompt" "$expected_class" "$expected_platform" "$actual_class" "$actual_platform" >&2
    failures=$((failures + 1))
  fi
}

check_route cheap deepseek "summarize this JSON into three fields"
check_route design kimi "design a premium dashboard layout"
check_route precision claude "debug this distributed auth race"
check_route codex codex "implement a small bug fix in this repo"
check_route precision claude "audit and improve the entire AI cockpit/router system for routing correctness, capability coverage, capacity, and interface quality"
check_route precision claude "review the router policy and MCP memory policy"
check_route design kimi "take a screenshot of localhost"
check_route design kimi "open https://example.com and click login"

[ "$failures" -eq 0 ] || exit 1
