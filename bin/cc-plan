#!/usr/bin/env bash
# cc-plan — save a read-only planning artifact for Plan/Act handoff.
set -euo pipefail

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] || [ "$#" -eq 0 ]; then
  printf 'Usage: cc-plan "work request"\n'
  printf 'Writes .ai/plans/<timestamp>-<slug>.md in the current workspace.\n'
  exit 0
fi

prompt="$*"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES="${DOTFILES:-$(cd "$SCRIPT_DIR/.." && pwd)}"
root="${AI_SYSTEM_ROOT:-$HOME/AI-SYSTEM-V2}"
route_script="${AI_SYSTEM_ROUTE_SCRIPT:-$DOTFILES/bin/cc-route}"
plans_dir="${CC_PLAN_DIR:-.ai/plans}"
ts="$(date -u '+%Y%m%dT%H%M%SZ')"
slug="$(printf '%s' "$prompt" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-//; s/-$//' | cut -c1-64)"
[ -n "$slug" ] || slug="plan"
file="$plans_dir/$ts-$slug.md"

mkdir -p "$plans_dir"

{
  printf '# Plan Artifact\n\n'
  printf 'Created: %s\n' "$ts"
  printf 'Workspace: %s\n' "$PWD"
  printf 'Request: %s\n\n' "$prompt"
  printf '## Route Preview\n\n'
  if [ -x "$route_script" ]; then
    "$route_script" --dry-run "$prompt" || true
  elif [ -x "$root/scripts/intent-route.sh" ]; then
    "$root/scripts/intent-route.sh" --dry-run "$prompt" || true
  else
    printf 'Route preview unavailable: %s\n' "$route_script"
  fi
  printf '\n## Plan\n\n'
} >"$file"

plan_prompt="Create a concise implementation plan for this request. Do not edit files. Include scope, ordered steps, verification commands, and stop conditions. Request: $prompt"
plan_tmp="$(mktemp "${TMPDIR:-/tmp}/cc-plan.XXXXXX")"
cleanup() {
  rm -f "$plan_tmp"
}
trap cleanup EXIT

if command -v router-ask >/dev/null 2>&1 && router-ask --purpose precision "$plan_prompt" >"$plan_tmp" 2>&1; then
  cat "$plan_tmp" | tee -a "$file"
else
  {
    printf 'Source: local fallback plan template; router-ask unavailable or failed.\n\n'
    printf '1. Confirm the requested scope and identify touched files.\n'
    printf '2. Inspect existing project patterns before editing.\n'
    printf '3. Make the smallest coherent change that satisfies the request.\n'
    printf '4. Run syntax, unit, integration, or product gates relevant to the touched files.\n'
    printf '5. Stop if a destructive, paid, credentialed, or cross-user action is required.\n'
  } | tee -a "$file"
fi

printf '\nSaved plan: %s\n' "$file"
