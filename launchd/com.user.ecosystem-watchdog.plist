    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/leonardofibonacci/local/bin:/Users/leonardofibonacci/local/opt/node/bin</string>
    <key>HOME</key>
