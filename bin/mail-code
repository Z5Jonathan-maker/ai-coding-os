#!/usr/bin/env bash
# Fetch the latest verification/OTP code from a Mail.app email matching a
# sender filter. Used by any auth flow that emails OTP codes — GitHub, AWS,
# Cloudflare, Stripe, banks, etc. Mail.app must be running and signed in to
# the iCloud account that receives the codes.
#
# Usage:
#   mail-code <sender-substring> [--since-now] [--timeout=N] [--digits=MIN-MAX]
#
# Examples:
#   mail-code noreply@github.com               # latest GH code, immediate
#   mail-code noreply@github.com --since-now   # wait up to 60s for a NEW email
#   mail-code stripe.com --digits=6
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "usage: mail-code <sender-substring> [--since-now] [--timeout=N] [--digits=MIN-MAX]" >&2
  exit 2
fi

SENDER="$1"
shift
SINCE_NOW=0
TIMEOUT=60
DIGITS_MIN=6
DIGITS_MAX=8
SCAN_LIMIT=10
for arg in "$@"; do
  case "$arg" in
    --since-now) SINCE_NOW=1 ;;
    --timeout=*) TIMEOUT="${arg#--timeout=}" ;;
    --digits=*)
      spec="${arg#--digits=}"
      if [[ "$spec" == *-* ]]; then
        DIGITS_MIN="${spec%-*}"
        DIGITS_MAX="${spec#*-}"
      else
        DIGITS_MIN="$spec"
        DIGITS_MAX="$spec"
      fi
      ;;
    --limit=*) SCAN_LIMIT="${arg#--limit=}" ;;
  esac
done

START_TS=$(date +%s)

# Read the i-th most recent matching message: returns "epoch|||body" or empty.
read_msg_at() {
  local sender="$1" idx="$2"
  /usr/bin/osascript <<APPLESCRIPT
tell application "Mail"
  try
    set msgs to (messages of inbox whose sender contains "$sender")
    if (count of msgs) < $idx then return ""
    set m to item $idx of msgs
    return ((date received of m) as string) & "|||" & (content of m)
  on error
    return ""
  end try
end tell
APPLESCRIPT
}

extract_code() {
  /usr/bin/grep -oE "\\b[0-9]{${DIGITS_MIN},${DIGITS_MAX}}\\b" | head -1
}

# Scan up to SCAN_LIMIT recent messages from the sender, return first code.
scan_once() {
  for i in $(seq 1 "$SCAN_LIMIT"); do
    local raw
    raw=$(read_msg_at "$SENDER" "$i")
    [ -z "$raw" ] && return 1
    local ts="${raw%%|||*}" body="${raw#*|||}" epoch
    epoch=$(date -j -f "%A, %B %d, %Y at %l:%M:%S %p" "$ts" +%s 2>/dev/null || echo 0)
    if [ "$SINCE_NOW" -eq 1 ] && [ "$epoch" -lt "$START_TS" ]; then
      continue
    fi
    local code
    code=$(printf '%s\n' "$body" | extract_code)
    if [ -n "$code" ]; then
      printf '%s\n' "$code"
      return 0
    fi
  done
  return 1
}

# Fast path: non-poll mode
if [ "$SINCE_NOW" -eq 0 ]; then
  if scan_once; then exit 0; fi
  echo "no code found in last $SCAN_LIMIT emails from '$SENDER'" >&2
  exit 1
fi

# Poll path: wait for a fresh email
elapsed=0
while [ "$elapsed" -lt "$TIMEOUT" ]; do
  if scan_once; then exit 0; fi
  sleep 3
  elapsed=$((elapsed + 3))
done

echo "timeout: no fresh code from sender '$SENDER' in ${TIMEOUT}s" >&2
exit 1
