#!/usr/bin/env node
'use strict';

const fs = require('fs');
const path = require('path');

const root = process.env.DOTFILES || path.resolve(__dirname, '..');
const args = process.argv.slice(2);
const command = args[0] && !args[0].startsWith('--') ? args[0] : has('check') ? 'check' : 'status';
const defaultPath = path.join(root, 'fixtures', 'frontend-wedge', 'premium-landing', 'competitive.benchmark.json');
const tools = ['ai-coding-os', 'v0', 'lovable', 'bolt'];
const dimensions = [
  'creative_fidelity',
  'visual_hierarchy',
  'brand_coherence',
  'implementation_realism',
  'responsive_resilience',
  'proof_quality',
  'cost_control',
];

function has(name) {
  return args.includes(`--${name}`);
}

function value(name, fallback = '') {
  const i = args.indexOf(`--${name}`);
  return i >= 0 && args[i + 1] && !args[i + 1].startsWith('--') ? args[i + 1] : fallback;
}

function restText(start = 1) {
  const skip = new Set([
    '--benchmark',
    '--brief-id',
    '--tool',
    '--prompt',
    '--prompt-text',
    '--screenshot',
    '--source',
    '--code',
    '--review',
    '--handoff-dir',
    '--artifact',
    '--score',
    '--capture-dir',
  ]);
  const out = [];
  for (let i = start; i < args.length; i += 1) {
    if (skip.has(args[i])) i += 1;
    else if (!args[i].startsWith('--')) out.push(args[i]);
  }
  return out.join(' ').trim();
}

function benchmarkPath() {
  return path.resolve(value('benchmark', defaultPath));
}

function readJson(file) {
  return JSON.parse(fs.readFileSync(file, 'utf8'));
}

function writeJson(file, data) {
  fs.mkdirSync(path.dirname(file), { recursive: true });
  fs.writeFileSync(file, `${JSON.stringify(data, null, 2)}\n`);
}

function rel(file) {
  const absolute = path.resolve(file);
  return path.relative(root, absolute).replaceAll(path.sep, '/');
}

function slug(text) {
  return String(text || 'benchmark')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '')
    .slice(0, 72) || 'benchmark';
}

function copyEvidence(src, destDir) {
  if (!src) return null;
  const absolute = path.resolve(src);
  if (!fs.existsSync(absolute)) throw new Error(`missing evidence file: ${absolute}`);
  fs.mkdirSync(destDir, { recursive: true });
  const dest = path.join(destDir, path.basename(absolute));
  fs.copyFileSync(absolute, dest);
  return rel(dest);
}

function loadBenchmark(file = benchmarkPath()) {
  if (!fs.existsSync(file)) throw new Error(`missing benchmark: ${file}`);
  return readJson(file);
}

function entryFor(benchmark, tool, create = false) {
  let entry = (benchmark.entries || []).find((item) => item.tool === tool);
  if (!entry && create) {
    entry = {
      tool,
      artifact: '',
      capture_dir: `fixtures/frontend-wedge/premium-landing/competitor-artifacts/${tool}`,
      capture_status: tool === 'ai-coding-os' ? 'captured_current_run' : 'pending_external_capture',
      score: null,
      evidence: [],
    };
    benchmark.entries = [...(benchmark.entries || []), entry];
  }
  return entry;
}

function newBenchmark(brief, outFile) {
  const briefId = value('brief-id', slug(brief));
  const base = {
    schema: 'ai-coding-os.competitive-frontend-benchmark.v1',
    brief_id: briefId,
    brief,
    same_brief_required: true,
    method: 'same-brief artifact review using saved prompt, screenshot/source, code/export, and review JSON for every scored tool',
    benchmark_status: 'artifact_contract_only',
    threshold_to_claim_win: 90,
    dimensions,
    entries: tools.map((tool) => ({
      tool,
      artifact: tool === 'ai-coding-os' ? 'fixtures/frontend-wedge/premium-landing/workflow.json' : '',
      capture_dir: `fixtures/frontend-wedge/premium-landing/competitor-artifacts/${tool}`,
      capture_status: tool === 'ai-coding-os' ? 'captured_current_run' : 'pending_external_capture',
      score: tool === 'ai-coding-os' ? null : null,
      evidence: tool === 'ai-coding-os'
        ? ['workflow artifact exists; attach handoff proof before scoring']
        : ['numeric score blocked until current-run evidence is attached'],
    })),
    honesty_constraints: [
      'Scores are not a live SaaS benchmark unless competitor artifacts are regenerated and attached for the current date.',
      'Claims must say this benchmark is a same-brief artifact review, not a universal product ranking.',
      'A win requires preserved taste plus shippable implementation proof, not layout aesthetics alone.',
      'External tools cannot carry numeric scores without prompt, screenshot/source, and review JSON evidence.',
    ],
  };
  writeJson(outFile, base);
  return base;
}

function create() {
  const outFile = benchmarkPath();
  const brief = restText(1);
  if (!brief) throw new Error('create requires a brief');
  const benchmark = newBenchmark(brief, outFile);
  console.log(JSON.stringify({ path: rel(outFile), brief_id: benchmark.brief_id, status: 'created' }, null, 2));
}

function attach() {
  const file = benchmarkPath();
  const benchmark = loadBenchmark(file);
  const tool = value('tool', '').toLowerCase();
  if (!tools.includes(tool)) throw new Error(`--tool must be one of: ${tools.join(', ')}`);
  const entry = entryFor(benchmark, tool, true);
  const captureDir = path.resolve(value('capture-dir', entry.capture_dir || path.join(path.dirname(file), 'competitor-artifacts', tool)));
  const evidenceArtifacts = [];
  const promptFile = value('prompt', '');
  const promptText = value('prompt-text', '') || restText(1);
  if (promptFile) evidenceArtifacts.push(copyEvidence(promptFile, captureDir));
  else if (promptText) {
    fs.mkdirSync(captureDir, { recursive: true });
    const out = path.join(captureDir, 'prompt.md');
    fs.writeFileSync(out, `${promptText}\n`);
    evidenceArtifacts.push(rel(out));
  }
  for (const flag of ['screenshot', 'source', 'code', 'artifact', 'review']) {
    const copied = copyEvidence(value(flag, ''), captureDir);
    if (copied) evidenceArtifacts.push(copied);
  }
  const handoffDir = value('handoff-dir', '');
  if (handoffDir) {
    const absolute = path.resolve(handoffDir);
    for (const name of ['design-handoff.json', 'implementation.result.json', 'taste.validation.json', 'codex.proof.json', 'deploy.receipt.json']) {
      const source = path.join(absolute, name);
      if (fs.existsSync(source)) evidenceArtifacts.push(copyEvidence(source, captureDir));
    }
  }
  if (!evidenceArtifacts.length) throw new Error('attach requires --prompt/--prompt-text plus screenshot/source/code/review/handoff evidence');
  entry.capture_dir = rel(captureDir);
  entry.capture_status = 'captured_current_run';
  entry.evidence_artifacts = Array.from(new Set([...(entry.evidence_artifacts || []), ...evidenceArtifacts]));
  if (!entry.artifact) entry.artifact = entry.evidence_artifacts[0];
  entry.evidence = [
    'current-run evidence attached',
    ...entry.evidence_artifacts,
  ].slice(0, 8);
  benchmark.benchmark_status = benchmark.entries
    .filter((item) => item.tool !== 'ai-coding-os')
    .every((item) => item.capture_status === 'captured_current_run')
    ? 'captured_current_run'
    : 'artifact_contract_only';
  writeJson(file, benchmark);
  console.log(JSON.stringify({ path: rel(file), tool, captured: entry.evidence_artifacts }, null, 2));
}

function reviewScore(review) {
  if (!review) return null;
  if (Number.isFinite(Number(review.score))) return Number(review.score);
  const scores = Object.values(review.scores || {}).map(Number).filter(Number.isFinite);
  if (!scores.length) return null;
  return Math.round((scores.reduce((sum, score) => sum + score, 0) / scores.length) * 10) / 10;
}

function score() {
  const file = benchmarkPath();
  const benchmark = loadBenchmark(file);
  const tool = value('tool', '').toLowerCase();
  const selected = tool ? [tool] : tools;
  for (const name of selected) {
    const entry = entryFor(benchmark, name);
    if (!entry) throw new Error(`missing entry: ${name}`);
    const explicit = value('score', '');
    if (explicit && selected.length > 1) throw new Error('--score requires a single --tool');
    const reviewPath = value('review', '');
    const review = reviewPath ? readJson(path.resolve(reviewPath)) : findReview(entry);
    const nextScore = explicit ? Number(explicit) : reviewScore(review);
    if (!Number.isFinite(nextScore) || nextScore < 0 || nextScore > 100) {
      if (name !== 'ai-coding-os') entry.score = null;
      continue;
    }
    if (name !== 'ai-coding-os' && entry.capture_status !== 'captured_current_run') {
      throw new Error(`${name} cannot be scored until current-run evidence is attached`);
    }
    entry.score = nextScore;
    entry.scored_at = new Date().toISOString();
    if (reviewPath) {
      entry.review_artifact = rel(reviewPath);
      if (!entry.evidence_artifacts?.includes(entry.review_artifact)) {
        entry.evidence_artifacts = [...(entry.evidence_artifacts || []), entry.review_artifact];
      }
    }
  }
  writeJson(file, benchmark);
  console.log(JSON.stringify({ path: rel(file), status: 'scored' }, null, 2));
}

function findReview(entry) {
  const candidates = [];
  if (entry.review_artifact) candidates.push(path.join(root, entry.review_artifact));
  if (entry.capture_dir) candidates.push(path.join(root, entry.capture_dir, 'review.json'));
  for (const file of candidates) {
    if (fs.existsSync(file)) return readJson(file);
  }
  return null;
}

function hasCapturedArtifact(dir) {
  if (!dir || !fs.existsSync(dir) || !fs.statSync(dir).isDirectory()) return false;
  return fs.readdirSync(dir).some((file) => /\.(png|jpe?g|webp|html|tsx?|jsx?|zip)$/i.test(file));
}

function validateEntry(entry, benchmark, errors) {
  if (!entry.artifact || !fs.existsSync(path.join(root, entry.artifact))) errors.push(`${entry.tool}: missing artifact`);
  if (!Array.isArray(entry.evidence) || entry.evidence.length < 2) errors.push(`${entry.tool}: insufficient evidence text`);
  if (!entry.capture_status) errors.push(`${entry.tool}: missing capture_status`);
  const requiresCaptureEvidence = entry.tool !== 'ai-coding-os' && entry.capture_status === 'captured_current_run';
  const requiresOwnCaptureEvidence = entry.tool === 'ai-coding-os' && benchmark.benchmark_status === 'captured_current_run';
  if (requiresCaptureEvidence || requiresOwnCaptureEvidence) {
    const dir = path.join(root, entry.capture_dir || '');
    if (!fs.existsSync(path.join(dir, 'prompt.md'))) errors.push(`${entry.tool}: missing prompt.md`);
    if (!fs.existsSync(path.join(dir, 'review.json'))) errors.push(`${entry.tool}: missing review.json`);
    if (!hasCapturedArtifact(dir)) errors.push(`${entry.tool}: missing screenshot/source/code artifact`);
    if (!Number.isFinite(entry.score) || entry.score < 0 || entry.score > 100) errors.push(`${entry.tool}: captured run missing valid numeric score`);
  } else if (entry.tool !== 'ai-coding-os' && entry.score !== null) {
    errors.push(`${entry.tool}: pending competitor cannot have numeric score`);
  }
}

function check() {
  const file = benchmarkPath();
  const benchmark = loadBenchmark(file);
  const errors = [];
  if (benchmark.schema !== 'ai-coding-os.competitive-frontend-benchmark.v1') errors.push('schema mismatch');
  if (benchmark.same_brief_required !== true) errors.push('same_brief_required must be true');
  if (!['artifact_contract_only', 'captured_current_run'].includes(benchmark.benchmark_status)) errors.push('invalid benchmark_status');
  for (const tool of tools) {
    const entry = entryFor(benchmark, tool);
    if (!entry) errors.push(`missing entry: ${tool}`);
    else validateEntry(entry, benchmark, errors);
  }
  if (!(benchmark.honesty_constraints || []).some((item) => /not a live SaaS benchmark/i.test(item))) errors.push('missing live benchmark honesty constraint');
  if (has('json')) {
    console.log(JSON.stringify({ schema: 'ai-coding-os.competitive-benchmark-check.v1', path: rel(file), ok: !errors.length, errors }, null, 2));
  } else {
    console.log('# Competitive Benchmark Check\n');
    console.log(`Benchmark: ${rel(file)}`);
    for (const error of errors) console.log(`fail ${error}`);
    console.log(`\nStatus: ${errors.length ? 'competitive-benchmark-blocked' : 'competitive-benchmark-ready'}`);
  }
  process.exit(errors.length ? 1 : 0);
}

function status() {
  const file = benchmarkPath();
  const benchmark = loadBenchmark(file);
  console.log(JSON.stringify({
    schema: 'ai-coding-os.competitive-benchmark-status.v1',
    path: rel(file),
    brief_id: benchmark.brief_id,
    benchmark_status: benchmark.benchmark_status,
    entries: (benchmark.entries || []).map((entry) => ({
      tool: entry.tool,
      capture_status: entry.capture_status,
      score: entry.score,
      capture_dir: entry.capture_dir || null,
    })),
  }, null, 2));
}

function selfCheck() {
  const temp = fs.mkdtempSync(path.join(require('os').tmpdir(), 'cc-competitive-benchmark.'));
  const benchmark = path.join(temp, 'competitive.benchmark.json');
  const prompt = path.join(temp, 'prompt.md');
  const screenshot = path.join(temp, 'screenshot.html');
  const review = path.join(temp, 'review.json');
  fs.writeFileSync(prompt, 'Build the same premium frontend brief.\n');
  fs.writeFileSync(screenshot, '<main>Captured competitor output</main>\n');
  writeJson(review, { score: 81, scores: { creative_fidelity: 80, proof_quality: 82 } });
  try {
    newBenchmark('Premium benchmark self-check', benchmark);
    args.length = 0;
    args.push('attach', '--benchmark', benchmark, '--tool', 'v0', '--capture-dir', path.join(temp, 'captures', 'v0'), '--prompt', prompt, '--screenshot', screenshot, '--review', review);
    attach();
    args.length = 0;
    args.push('score', '--benchmark', benchmark, '--tool', 'v0');
    score();
    const checked = loadBenchmark(benchmark);
    const entry = entryFor(checked, 'v0');
    if (entry.score !== 81 || entry.capture_status !== 'captured_current_run') throw new Error('self-check score/capture mismatch');
    const errors = [];
    validateEntry(entry, checked, errors);
    if (errors.length) throw new Error(errors.join('; '));
  } finally {
    fs.rmSync(temp, { recursive: true, force: true });
  }
  console.log('Status: competitive-benchmark-self-check-ready');
}

try {
  if (command === 'create') create();
  else if (command === 'attach') attach();
  else if (command === 'score') score();
  else if (command === 'check') check();
  else if (command === 'self-check') selfCheck();
  else if (command === 'status') status();
  else throw new Error(`unknown command: ${command}`);
} catch (err) {
  console.error(`cc-competitive-benchmark: ${err.message}`);
  process.exit(1);
}
