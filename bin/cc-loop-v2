#!/usr/bin/env bash
# cc-loop-v2 — Model-Aware Autonomous Loop
#
# Reads ~/.claude/memory/TASK_BOARD.md, picks active tasks,
# routes each task to the correct model tier via router-ask,
# executes, logs, marks complete.
#
# Designed to be called by launchd every 5 minutes.
# Should NOT run if ~/.cc-paused exists (task board is empty
# or user has paused the loop).

set -euo pipefail

BOARD="$HOME/.claude/memory/TASK_BOARD.md"
STATE="$HOME/.claude/cc-loop.state"
LOG="$HOME/.claude/cc-loop.log"
ERR="$HOME/.claude/cc-loop.stderr"
ROUTER="$HOME/code/projects/cc-router/bin/router-ask"

# ── Pause check ─────────────────────────────────────────────────
if [ -f "$HOME/.cc-paused" ]; then
  echo "[cc-loop] Paused (found ~/.cc-paused)" >> "$LOG"
  exit 0
fi

# ── Task board check ────────────────────────────────────────────
if [ ! -f "$BOARD" ]; then
  echo "[cc-loop] No task board found at $BOARD" >> "$LOG"
  # Update state
  cat > "$STATE" <<EOF
last_exit=0
last_run=$(date +%s)
consecutive_errors=0
noop_cycles=$(( $(cat "$STATE" 2>/dev/null | grep noop_cycles | cut -d= -f2 || echo 0) + 1 ))
started=$(cat "$STATE" 2>/dev/null | grep started | cut -d= -f2 || echo $(date +%s))
last_event=noop_no_board
EOF
  exit 0
fi

# ── Extract active tasks ────────────────────────────────────────
# Parse the markdown task board: lines starting with "### [ ]"
active_tasks=$(grep "^### \[ \]" "$BOARD" 2>/dev/null | head -5)

if [ -z "$active_tasks" ]; then
  echo "[cc-loop] $(date '+%H:%M:%S') — No active tasks" >> "$LOG"
  cat > "$STATE" <<EOF
last_exit=0
last_run=$(date +%s)
consecutive_errors=0
noop_cycles=$(( $(cat "$STATE" 2>/dev/null | grep noop_cycles | cut -d= -f2 || echo 0) + 1 ))
started=$(cat "$STATE" 2>/dev/null | grep started | cut -d= -f2 || echo $(date +%s))
last_event=noop_empty_board
EOF
  exit 0
fi

# ── Process one task ────────────────────────────────────────────
# Pick the first active task
task_line=$(echo "$active_tasks" | head -1)

# Parse task ID, type, priority
task_id=$(echo "$task_line" | grep -o 'T[0-9]*' | head -1)
task_type=$(grep -A5 "^$task_line" "$BOARD" | grep "^\- \*\*Type:\*\*" | sed 's/.*Type: \*\*//' | sed 's/\*\*.*//' | tr -d ' ')
priority=$(grep -A5 "^$task_line" "$BOARD" | grep "^\- \*\*Priority:\*\*" | sed 's/.*Priority: \*\*//' | sed 's/\*\*.*//' | tr -d ' ')
description=$(grep -A5 "^$task_line" "$BOARD" | grep "^\- \*\*Description:\*\*" | sed 's/.*Description: \*\*//' | sed 's/\*\*.*//')

echo "[cc-loop] $(date '+%H:%M:%S') — Processing $task_id (type=$task_type, priority=$priority)" >> "$LOG"

# ── Route to correct model tier ─────────────────────────────────
case "$task_type" in
  ui_design|design|visual|layout)
    tier="design"
    ;;
  system_architecture|backend|api|infra|ci_cd|deploy)
    tier="precision"
    ;;
  implementation|bug_fix|feature_dev|test_generation|shell_script|cli_tool|code_review|refactor)
    tier="codex"
    ;;
  summarize|enrich|compact_memory|codebase_analysis)
    tier="cheap"
    ;;
  research|long_context_analysis|phenomenology)
    tier="precision"
    ;;
  automation|script|hook|agent|workflow)
    tier="precision"
    ;;
  token_optimization|system_optimization|audit)
    tier="precision"
    ;;
  *)
    tier="chat"
    ;;
esac

echo "[cc-loop] $(date '+%H:%M:%S') — Routing $task_id to tier: $tier" >> "$LOG"

# ── Execute via router-ask ──────────────────────────────────────
if [ -x "$ROUTER" ]; then
  result=$("$ROUTER" -p "$tier" "$description" 2>&1) || {
    echo "[cc-loop] $(date '+%H:%M:%S') — ✗ $task_id failed: $result" >> "$LOG"
    cat > "$STATE" <<EOF
last_exit=1
last_run=$(date +%s)
consecutive_errors=$(( $(cat "$STATE" 2>/dev/null | grep consecutive_errors | cut -d= -f2 || echo 0) + 1 ))
noop_cycles=0
started=$(cat "$STATE" 2>/dev/null | grep started | cut -d= -f2 || echo $(date +%s))
last_event=error_$task_id
EOF
    exit 1
  }
  echo "[cc-loop] $(date '+%H:%M:%S') — ✓ $task_id completed (tier=$tier)" >> "$LOG"
  # Log first 200 chars of result
  echo "[cc-loop] Result: $(echo "$result" | head -c 200)" >> "$LOG"
else
  echo "[cc-loop] $(date '+%H:%M:%S') — ⚠ router-ask not found, falling back to local execution" >> "$LOG"
  result="[FALLBACK] Task $task_id queued for manual execution. Tier: $tier"
fi

# ── Mark task complete in board ───────────────────────────────────
# Replace "### [ ] T#" with "### [x] T#" and add completion timestamp
sed -i.bak "s|^### \[ \] $task_id|### [x] $task_id — completed $(date '+%Y-%m-%d %H:%M')|" "$BOARD"
rm -f "$BOARD.bak"

# Also add to Completed section
# (The task stays in Active with [x], user can clean up manually)

# ── Update state ────────────────────────────────────────────────
cat > "$STATE" <<EOF
last_exit=0
last_run=$(date +%s)
consecutive_errors=0
noop_cycles=0
started=$(cat "$STATE" 2>/dev/null | grep started | cut -d= -f2 || echo $(date +%s))
last_event=completed_$task_id
EOF

echo "[cc-loop] $(date '+%H:%M:%S') — Cycle complete. Next check in 5 minutes." >> "$LOG"
exit 0
