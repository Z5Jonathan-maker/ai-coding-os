#!/usr/bin/env bash
# cc-self-update — automated monthly update sweep across the entire
# platform. Runs via LaunchAgent on the 1st of each month, 06:00.
# ntfy-pushes summary of: what got updated, what failed, what's stale.
#
# Updates (each is safe-fail; one failure doesn't abort the rest):
#   - brew update + upgrade
#   - All cloned skill/tool repos (git pull --ff-only)
#   - npx-cached MCP servers (clear cache, re-resolve on next call)
#   - uv tool upgrade (mempalace, browser-use, gdown, etc.)
#   - npm globals listed in ~/dotfiles/npm-global-packages.txt
#   - VS Code extensions listed in ~/dotfiles/vscode/extensions.txt
#
# Manual invocation: cc-self-update [--dry-run]
set -u

DRY_RUN=0
[ "${1:-}" = "--dry-run" ] && DRY_RUN=1

LOG="$HOME/.claude/cc-self-update.log"
mkdir -p "$(dirname "$LOG")"
ts=$(date '+%Y-%m-%d %H:%M:%S')

log() { echo "$1" | tee -a "$LOG"; }

log ""
log "=== $ts cc-self-update start (dry_run=$DRY_RUN) ==="

updated=()
failed=()

npm_cmd() {
  if command -v npm >/dev/null 2>&1; then
    command -v npm
  elif [ -x "$HOME/local/opt/node/bin/npm" ]; then
    echo "$HOME/local/opt/node/bin/npm"
  elif [ -x "$HOME/.local/share/fnm/node-versions/v22.22.2/installation/bin/npm" ]; then
    echo "$HOME/.local/share/fnm/node-versions/v22.22.2/installation/bin/npm"
  fi
}

# 1. brew
log ""
log "── brew update + upgrade ──"
if command -v /opt/homebrew/bin/brew >/dev/null; then
  if [ "$DRY_RUN" = "0" ]; then
    /opt/homebrew/bin/brew update >>"$LOG" 2>&1 || failed+=("brew update")
    /opt/homebrew/bin/brew upgrade >>"$LOG" 2>&1 || failed+=("brew upgrade")
    updated+=("brew")
  else
    log "[DRY-RUN] brew update + upgrade"
  fi
fi

# 2. Cloned skill/tool repos
log ""
log "── cloned repos (git pull --ff-only) ──"
for repo in \
  "$HOME/code/research/huashu-design" \
  "$HOME/code/research/browser-harness" \
  "$HOME/code/research/mercury-agent" \
  "$HOME/code/research/ui-ux-pro-max-skill" \
  "$HOME/code/research/wassim-drive/andrej-karpathy-skills-main"; do
  [ -d "$repo/.git" ] || continue
  log "  → $repo"
  if [ "$DRY_RUN" = "0" ]; then
    if (cd "$repo" && git pull --ff-only 2>&1); then
      updated+=("$(basename "$repo")")
    else
      failed+=("$(basename "$repo")")
    fi
  fi
done

# 3. uv tools
log ""
log "── uv tool upgrade --all ──"
if [ -x /opt/homebrew/bin/uv ]; then
  if [ "$DRY_RUN" = "0" ]; then
    /opt/homebrew/bin/uv tool upgrade --all >>"$LOG" 2>&1 \
      && updated+=("uv tools") \
      || failed+=("uv tool upgrade")
  fi
fi

# 4. npm globals
log ""
log "── npm global packages ──"
npm_bin="$(npm_cmd || true)"
if [ -n "${npm_bin:-}" ] && [ -f "$HOME/dotfiles/npm-global-packages.txt" ]; then
  while read -r pkg cmd _rest; do
    case "$pkg" in
      ""|\#*) continue ;;
    esac
    if [ "$DRY_RUN" = "0" ]; then
      if "$npm_bin" list -g --depth=0 "$pkg" >/dev/null 2>&1; then
        updated+=("npm:$pkg")
      elif "$npm_bin" install -g "$pkg" >>"$LOG" 2>&1; then
        updated+=("npm:$pkg")
      else
        failed+=("npm:$pkg")
        continue
      fi
      [ -z "${cmd:-}" ] || command -v "$cmd" >/dev/null 2>&1 || failed+=("npm-cmd:$cmd")
    else
      log "[DRY-RUN] npm install -g $pkg"
    fi
  done <"$HOME/dotfiles/npm-global-packages.txt"
elif [ -f "$HOME/dotfiles/npm-global-packages.txt" ]; then
  failed+=("npm unavailable")
fi

# 6. VS Code extensions
log ""
log "── VS Code extensions ──"
if command -v code >/dev/null 2>&1 && [ -f "$HOME/dotfiles/vscode/extensions.txt" ]; then
  vscode_ext_list=$(mktemp)
  code --list-extensions >"$vscode_ext_list"
  while IFS= read -r ext; do
    case "$ext" in
      ""|\#*) continue ;;
    esac
    if grep -Fxqi "$ext" "$vscode_ext_list"; then
      updated+=("vscode:$ext")
    elif [ "$DRY_RUN" = "0" ]; then
      if code --install-extension "$ext" >>"$LOG" 2>&1; then
        updated+=("vscode:$ext")
        code --list-extensions >"$vscode_ext_list"
      else
        failed+=("vscode:$ext")
      fi
    else
      log "[DRY-RUN] code --install-extension $ext"
    fi
  done <"$HOME/dotfiles/vscode/extensions.txt"
  rm -f "$vscode_ext_list"
elif [ -f "$HOME/dotfiles/vscode/extensions.txt" ]; then
  failed+=("vscode cli unavailable")
fi

# 7. npx cache clear (forces re-resolve of MCP servers on next call)
log ""
log "── npm cache verify ──"
if [ -n "${npm_bin:-}" ]; then
  [ "$DRY_RUN" = "0" ] && "$npm_bin" cache verify >>"$LOG" 2>&1 || true
  updated+=("npm cache")
fi

# Summary
log ""
log "=== $ts cc-self-update done ==="
log "updated: ${#updated[@]}  failed: ${#failed[@]}"

# Build ntfy message
if [ ${#failed[@]} -eq 0 ]; then
  msg="✓ cc-self-update: ${#updated[@]} components updated cleanly"
else
  detail=$(printf '\n  • %s' "${failed[@]}")
  msg="⚠ cc-self-update: ${#failed[@]} failures — investigate${detail}"
fi

if [ -n "${NTFY_TOPIC:-}" ]; then
  curl -fsSL --max-time 5 \
    -H "Title: cc-self-update" \
    -H "Priority: $([ ${#failed[@]} -gt 0 ] && echo 4 || echo 2)" \
    -H "Tags: arrows_counterclockwise" \
    -d "$msg" \
    "https://ntfy.sh/${NTFY_TOPIC}" >/dev/null 2>&1 &
fi
