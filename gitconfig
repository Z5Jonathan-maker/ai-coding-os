[user]
	name = Jonathan Cimadevilla
	email = z5jonathan@icloud.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIKG544Vmb701NXqpXZXqlWAs0jmTYcLy1poo6kyhoiGj z5jonathan@icloud.com
[init]
	defaultBranch = main
[pull]
	rebase = true
[push]
	autoSetupRemote = true
	default = simple
[core]
	editor = code --wait
	excludesfile = /Users/leonardofibonacci/.gitignore_global
	pager = delta
[rebase]
	autosquash = true
	autostash = true
[fetch]
	prune = true
[diff]
	algorithm = histogram
	tool = difftastic
[merge]
	conflictstyle = zdiff3
	tool = delta
[rerere]
	enabled = true
[color]
	ui = auto
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
	syntax-theme = Monokai Extended
[difftool "difftastic"]
	cmd = difft \"$LOCAL\" \"$REMOTE\"
[difftool]
	prompt = false
[alias]
	dft = difftool
	lg = log --oneline --graph --decorate -20
	lga = log --oneline --graph --decorate --all -30
	st = status
	co = checkout
	br = branch
	ci = commit
	amend = commit --amend --no-edit
	wip = !git add -A && git commit -m \"wip\" --no-verify
	undo = reset --soft HEAD~1
	unstage = reset HEAD --
	last = log -1 HEAD
	aliases = config --get-regexp alias
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
