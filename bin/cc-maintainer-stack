#!/usr/bin/env bash
set -euo pipefail

ROOT="${DOTFILES_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
ROUTER="${CC_ROUTER_ROOT:-${ROUTER_ROOT:-$HOME/code/projects/cc-router}}"
strict=0
json=0

for arg in "$@"; do
  case "$arg" in
  --strict) strict=1 ;;
  --json) json=1 ;;
  -h | --help)
    cat <<'EOF'
Usage: cc-maintainer-stack [--strict] [--json]

Reports the live maintainer-only tools behind the portable repo contracts.
Default mode is informational. --strict exits non-zero when a live dependency
is missing or degraded.
EOF
    exit 0
    ;;
  *)
    echo "cc-maintainer-stack: unknown option $arg" >&2
    exit 2
    ;;
  esac
done

items=()
missing=0

add_item() {
  local name="$1" status="$2" detail="$3" mode="${4:-maintainer}"
  items+=("$name	$status	$detail	$mode")
  [ "$status" = "ok" ] || missing=$((missing + 1))
}

check_cmd() {
  local name="$1" cmd="$2" mode="${3:-maintainer}"
  if command -v "$cmd" >/dev/null 2>&1; then
    add_item "$name" ok "$(command -v "$cmd")" "$mode"
  else
    add_item "$name" missing "$cmd not found in PATH" "$mode"
  fi
}

check_file() {
  local name="$1" path="$2" mode="${3:-maintainer}"
  if [ -x "$path" ]; then
    add_item "$name" ok "$path" "$mode"
  elif [ -e "$path" ]; then
    add_item "$name" degraded "$path exists but is not executable" "$mode"
  else
    add_item "$name" missing "$path not found" "$mode"
  fi
}

check_dir() {
  local name="$1" path="$2" mode="${3:-maintainer}"
  if [ -d "$path" ]; then
    add_item "$name" ok "$path" "$mode"
  else
    add_item "$name" missing "$path not found" "$mode"
  fi
}

check_cmd "Codex CLI" codex
check_cmd "Claude CLI" claude
check_cmd "Kimi CLI" kimi
check_cmd "DeepSeek CLI" deepseek
check_cmd "router-ask" router-ask
check_file "cc-image wrapper" "$ROOT/bin/cc-image"
check_dir "cc-router checkout" "$ROUTER"
check_file "TEL client" "$HOME/.Codex/tel/client/tel-call.sh"

bridge="$HOME/.kimi-webbridge/bin/kimi-webbridge"
[ -x "$bridge" ] || bridge="/Applications/Kimi.app/Contents/Resources/resources/kimi-webbridge"
if [ -x "$bridge" ]; then
  if out="$("$bridge" status 2>&1 | head -n 20)"; then
    if printf '%s\n' "$out" | grep -Eq 'extension_connected.*true|mode=official-extension|running.*true'; then
      add_item "Kimi WebBridge" ok "$bridge status reports ready"
    else
      add_item "Kimi WebBridge" degraded "$(printf '%s' "$out" | tr '\n' ' ' | cut -c1-220)"
    fi
  else
    add_item "Kimi WebBridge" degraded "$bridge status failed"
  fi
else
  add_item "Kimi WebBridge" missing "official extension bridge not found"
fi

if [ "$json" -eq 1 ]; then
  printf '{"schema":"ai-coding-os.maintainer-stack.v1","missing_or_degraded":%s,"items":[' "$missing"
  first=1
  for item in "${items[@]}"; do
    IFS=$'\t' read -r name status detail mode <<<"$item"
    [ "$first" -eq 1 ] || printf ','
    first=0
    node -e 'const [name,status,detail,mode]=process.argv.slice(1); process.stdout.write(JSON.stringify({name,status,detail,mode}))' "$name" "$status" "$detail" "$mode"
  done
  printf ']}\n'
else
  printf '# Maintainer Stack\n\n'
  printf 'Portable repo: %s\n' "$ROOT"
  printf 'Router root:   %s\n\n' "$ROUTER"
  for item in "${items[@]}"; do
    IFS=$'\t' read -r name status detail mode <<<"$item"
    printf '%-18s %-8s %s\n' "$name" "$status" "$detail"
  done
  printf '\nSummary: missing_or_degraded=%s\n' "$missing"
  if [ "$missing" -eq 0 ]; then
    printf 'Status: maintainer-stack-ready\n'
  else
    printf 'Status: maintainer-stack-incomplete\n'
  fi
fi

if [ "$strict" -eq 1 ] && [ "$missing" -gt 0 ]; then
  exit 1
fi
