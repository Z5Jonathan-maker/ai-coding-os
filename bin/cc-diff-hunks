#!/usr/bin/env bash
set -euo pipefail

json=0
while (($#)); do
  case "$1" in
    --json) json=1 ;;
    -h|--help)
      printf 'Usage: cc-diff-hunks [--json]\n'
      exit 0
      ;;
    *) echo "cc-diff-hunks: unknown argument: $1" >&2; exit 2 ;;
  esac
  shift
done

if ! git rev-parse --show-toplevel >/dev/null 2>&1; then
  echo "cc-diff-hunks: not inside a git repository" >&2
  exit 2
fi

root="$(git rev-parse --show-toplevel)"
cd "$root"

if [ "$json" = 1 ]; then
  node <<'NODE'
const cp = require('child_process');

function git(args) {
  try {
    return cp.execFileSync('git', args, { encoding: 'utf8', maxBuffer: 1024 * 1024 * 8 });
  } catch (_) {
    return '';
  }
}

function parseNumstat(scope, text) {
  return text.trim().split('\n').filter(Boolean).map((line) => {
    const parts = line.split('\t');
    const added = parts[0] === '-' ? 0 : Number(parts[0] || 0);
    const removed = parts[1] === '-' ? 0 : Number(parts[1] || 0);
    return { scope, added, removed, path: parts.slice(2).join('\t') };
  });
}

function parseHunks(scope, text) {
  const hunks = [];
  let file = '';
  for (const line of text.split('\n')) {
    if (line.startsWith('diff --git ')) {
      const match = line.match(/ b\/(.+)$/);
      file = match ? match[1] : '';
    } else if (line.startsWith('@@ ')) {
      hunks.push({ scope, path: file, header: line });
    }
  }
  return hunks;
}

const worktreeFiles = parseNumstat('worktree', git(['diff', '--numstat', '--']));
const stagedFiles = parseNumstat('staged', git(['diff', '--cached', '--numstat', '--']));
const files = [...worktreeFiles, ...stagedFiles];
const hunks = [
  ...parseHunks('worktree', git(['diff', '--no-ext-diff', '--unified=0', '--'])),
  ...parseHunks('staged', git(['diff', '--cached', '--no-ext-diff', '--unified=0', '--'])),
];
const patch = `${git(['diff', '--no-ext-diff', '--'])}${git(['diff', '--cached', '--no-ext-diff', '--'])}`;
const payload = {
  repo: git(['rev-parse', '--show-toplevel']).trim(),
  branch: git(['branch', '--show-current']).trim() || 'unknown',
  clean: files.length === 0,
  fileCount: new Set(files.map((f) => f.path)).size,
  hunkCount: hunks.length,
  totalAdded: files.reduce((sum, f) => sum + f.added, 0),
  totalRemoved: files.reduce((sum, f) => sum + f.removed, 0),
  files,
  hunks,
  patchPreview: patch.split('\n').slice(0, 180).join('\n'),
};
process.stdout.write(`${JSON.stringify(payload)}\n`);
NODE
  exit 0
fi

printf '# Diff Hunks\n\n'
printf 'Repo: %s\n' "$root"
printf 'Branch: %s\n\n' "$(git branch --show-current 2>/dev/null || printf unknown)"

if git diff --quiet -- . && git diff --cached --quiet -- .; then
  printf 'No working-tree or staged diff.\n'
  exit 0
fi

printf '## Stat\n\n```text\n'
git diff --stat -- .
git diff --cached --stat -- .
printf '```\n\n'

printf '## Files\n\n```text\n'
{ git diff --numstat -- . | awk '{print "worktree\t"$0}'; git diff --cached --numstat -- . | awk '{print "staged\t"$0}'; } \
  | awk -F '\t' '
      NF >= 4 {
        key=$1 "\t" $4
        add[key]+=$2 == "-" ? 0 : $2
        del[key]+=$3 == "-" ? 0 : $3
      }
      END {
        printf "%-10s %7s %7s  %s\n", "scope", "added", "removed", "file"
        for (key in add) {
          split(key, parts, "\t")
          printf "%-10s %7d %7d  %s\n", parts[1], add[key], del[key], parts[2]
        }
      }'
printf '```\n\n'

printf '## Hunks\n\n```text\n'
git diff --no-ext-diff --unified=0 -- . \
  | awk '
      /^diff --git / {
        file=$4
        sub(/^b\//, "", file)
      }
      /^@@ / {
        print file "\t" $0
      }'
git diff --cached --no-ext-diff --unified=0 -- . \
  | awk '
      /^diff --git / {
        file=$4
        sub(/^b\//, "", file)
      }
      /^@@ / {
        print "[staged] " file "\t" $0
      }'
printf '```\n\n'

printf '## Patch Preview\n\n```diff\n'
git diff --no-ext-diff -- . | sed -n '1,220p'
git diff --cached --no-ext-diff -- . | sed -n '1,220p'
printf '```\n'
