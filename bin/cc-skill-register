#!/usr/bin/env bash
# cc-skill-register — register a new skill/CLI/agent into the routing tables.
# Closes the drift loop that bit us 4× during the 2026-05-14 audit (cc-reflect,
# cc-health, cc-deploy-watch, swarm-bundle removals all required manual
# routing-table edits that the drift checker then flagged).
#
# Modes:
#   cc-skill-register skill <name>     — read ~/.claude/skills/<name>/SKILL.md
#                                         frontmatter, insert row into the
#                                         SKILL ROUTING TABLE in CLAUDE.md
#   cc-skill-register cli <name> "<intent>" "<description>"
#                                       — register a CLI (in dotfiles/bin/) into
#                                         routing table + drift-checker allowlist
#   cc-skill-register check             — dry-run: scan ~/.claude/skills/ and
#                                         ~/dotfiles/bin/ for unrouted entries,
#                                         emit proposed patches without applying
#
# Exit codes: 0 (registered or nothing to do), 1 (drift found in check mode),
#             2 (error reading skill frontmatter)

set -u

CLAUDE_MD="${HOME}/dotfiles/claude/CLAUDE.md"
DRIFT_CHECK="${HOME}/.claude/scripts/routing-drift-check.sh"
SKILLS_DIR="${HOME}/.claude/skills"

usage() {
  cat <<'EOF'
Usage:
  cc-skill-register skill <name>
  cc-skill-register cli <name> "<intent-phrase>" "<description>"
  cc-skill-register check
EOF
  exit 64
}

[ $# -ge 1 ] || usage
MODE="$1"
shift

# Insert a routing-table row right BEFORE the "**Built-in Anthropic skills**"
# closing line of the SKILL ROUTING TABLE.
insert_skill_row() {
  local row="$1"
  python3 - "$CLAUDE_MD" "$row" <<'PY'
import sys
path, row = sys.argv[1:3]
src = open(path).read()
# Find the marker line that follows the routing table
marker = "\n**Built-in Anthropic skills**"
idx = src.find(marker)
if idx < 0:
    print("cc-skill-register: marker not found in CLAUDE.md — aborting", file=sys.stderr)
    sys.exit(2)
# Insert row + newline right before that marker
new = src[:idx] + "\n" + row + src[idx:]
# Idempotency: if the exact row is already in the file, no-op
if row.strip() in src:
    print("cc-skill-register: row already present, no-op", file=sys.stderr)
    sys.exit(0)
open(path, "w").write(new)
print(f"cc-skill-register: inserted row before built-ins marker")
PY
}

add_cli_to_allowlist() {
  local name="$1"
  if grep -q "^${name}\$" "$DRIFT_CHECK" 2>/dev/null; then
    echo "cc-skill-register: $name already in drift allowlist"
    return 0
  fi
  # Insert before the CLIS heredoc terminator
  python3 - "$DRIFT_CHECK" "$name" <<'PY'
import sys
path, name = sys.argv[1:3]
src = open(path).read()
# Find the second 'CLIS' (closing terminator of the heredoc)
first = src.find("'CLIS'")
if first < 0:
    print("cc-skill-register: CLIS heredoc not found — aborting", file=sys.stderr)
    sys.exit(2)
closing = src.find("\nCLIS\n", first)
if closing < 0:
    print("cc-skill-register: closing CLIS not found", file=sys.stderr)
    sys.exit(2)
new = src[:closing] + "\n" + name + src[closing:]
open(path, "w").write(new)
print(f"cc-skill-register: added '{name}' to drift CLI allowlist")
PY
}

case "$MODE" in
  skill)
    NAME="${1:-}"
    [ -z "$NAME" ] && usage
    SKILL_FILE="$SKILLS_DIR/$NAME/SKILL.md"
    if [ ! -f "$SKILL_FILE" ]; then
      echo "cc-skill-register: $SKILL_FILE not found" >&2
      exit 2
    fi
    DESC=$(awk '/^description:/{sub(/^description: */,""); print; exit}' "$SKILL_FILE")
    if [ -z "$DESC" ]; then
      echo "cc-skill-register: no 'description:' in frontmatter of $SKILL_FILE" >&2
      exit 2
    fi
    # Truncate long description; keep intent short
    SHORT="${DESC:0:160}"
    ROW="| \"$SHORT\" | \`$NAME\` | Auto-registered $(date +%Y-%m-%d) by cc-skill-register. Edit this row to refine intent. |"
    insert_skill_row "$ROW"
    bash "$DRIFT_CHECK" 2>&1 | tail -3
    ;;
  cli)
    NAME="${1:-}"
    INTENT="${2:-}"
    DESC="${3:-}"
    [ -z "$NAME" ] || [ -z "$INTENT" ] || [ -z "$DESC" ] && usage
    ROW="| \"$INTENT\" | \`$NAME\` (CLI, not a skill) | $DESC |"
    insert_skill_row "$ROW"
    add_cli_to_allowlist "$NAME"
    bash "$DRIFT_CHECK" 2>&1 | tail -3
    ;;
  check)
    bash "$DRIFT_CHECK" 2>&1 | head -25
    EXIT=${PIPESTATUS[0]}
    if [ "$EXIT" -ne 0 ]; then
      echo
      echo "To fix:"
      echo "  cc-skill-register skill <name>     # for ~/.claude/skills/<name>/"
      echo "  cc-skill-register cli <name> ... # for ~/dotfiles/bin/<name>"
      exit 1
    fi
    ;;
  *) usage ;;
esac
