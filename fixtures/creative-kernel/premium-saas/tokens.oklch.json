{
  "schema": "ai-coding-os.brand-tokens.oklch.v1",
  "color_space": "oklch",
  "tailwind_version": 4,
  "snapping_target": "shadcn/ui",
  "tokens": {
    "color": {
      "background": "oklch(0.14 0.02 270)",
      "foreground": "oklch(0.98 0.01 270)",
      "primary": "oklch(0.62 0.18 260)",
      "primary-foreground": "oklch(0.99 0.005 270)",
      "muted": "oklch(0.22 0.02 270)",
      "muted-foreground": "oklch(0.72 0.02 270)",
      "accent": "oklch(0.72 0.16 200)",
      "border": "oklch(0.26 0.02 270)",
      "ring": "oklch(0.62 0.18 260)"
    },
    "radius": {
      "sm": "0.375rem",
      "md": "0.5rem",
      "lg": "0.75rem"
    },
    "shadow": {
      "elevated": "0 1px 0 oklch(1 0 0 / 0.06) inset, 0 10px 30px oklch(0 0 0 / 0.35)"
    }
  },
  "shadcn_primitives_in_scope": [
    "button",
    "card",
    "input",
    "label",
    "separator",
    "badge",
    "dialog",
    "navigation-menu"
  ],
  "round_trip": {
    "figma_variables": true,
    "tailwind_v4_css_vars": true,
    "exposed_as": "@theme inline"
  }
}
