{
  "name": "ai-system-cockpit",
  "displayName": "AI System Cockpit",
  "description": "Native VS Code cockpit for AI-SYSTEM-V2 routing, readiness, checkpoints, permissions, and lane execution.",
  "version": "0.1.0",
  "publisher": "z5jonathan",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Z5Jonathan-maker/dotfiles.git",
    "directory": "vscode/ai-cockpit"
  },
  "homepage": "https://github.com/Z5Jonathan-maker/dotfiles/tree/main/vscode/ai-cockpit",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:aiSystemCockpit.open",
    "onCommand:aiSystemCockpit.status",
    "onView:aiSystemCockpit.dashboard"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "aiSystemCockpit.open", "title": "AI Cockpit: Open" },
      { "command": "aiSystemCockpit.refresh", "title": "AI Cockpit: Refresh" },
      { "command": "aiSystemCockpit.status", "title": "AI Cockpit: Status" },
      { "command": "aiSystemCockpit.systemDemo", "title": "AI Cockpit: System Demo" },
      { "command": "aiSystemCockpit.explainRoute", "title": "AI Cockpit: Explain Route" },
      { "command": "aiSystemCockpit.autoRun", "title": "AI Cockpit: Auto Run" },
      { "command": "aiSystemCockpit.buildFix", "title": "AI Cockpit: Code" },
      { "command": "aiSystemCockpit.designBrowser", "title": "AI Cockpit: Design / Browser" },
      { "command": "aiSystemCockpit.researchExtract", "title": "AI Cockpit: Research / Extract" },
      { "command": "aiSystemCockpit.savePlan", "title": "AI Cockpit: Save Plan" },
      { "command": "aiSystemCockpit.reviewDiff", "title": "AI Cockpit: Review Diff" },
      { "command": "aiSystemCockpit.inlineEdit", "title": "AI Cockpit: Inline Edit" },
      { "command": "aiSystemCockpit.routeReceipt", "title": "AI Cockpit: Route Receipt" },
      { "command": "aiSystemCockpit.routerMetrics", "title": "AI Cockpit: Router Metrics" },
      { "command": "aiSystemCockpit.providerCapacity", "title": "AI Cockpit: Provider Capacity" },
      { "command": "aiSystemCockpit.permissionMatrix", "title": "AI Cockpit: Permission Matrix" },
      { "command": "aiSystemCockpit.checkpoints", "title": "AI Cockpit: Checkpoints" },
      { "command": "aiSystemCockpit.loopQuality", "title": "AI Cockpit: Loop Quality" },
      { "command": "aiSystemCockpit.diskReadiness", "title": "AI Cockpit: Disk Readiness" },
      { "command": "aiSystemCockpit.productReadiness", "title": "AI Cockpit: Product Readiness" },
      { "command": "aiSystemCockpit.firstRun", "title": "AI Cockpit: First Run Doctor" },
      { "command": "aiSystemCockpit.contextMeter", "title": "AI Cockpit: Context Meter" },
      { "command": "aiSystemCockpit.contextSnapshot", "title": "AI Cockpit: Context Snapshot" },
      { "command": "aiSystemCockpit.sessionLedger", "title": "AI Cockpit: Session Ledger" },
      { "command": "aiSystemCockpit.pulseStatus", "title": "AI Cockpit: Pulse Status" },
      { "command": "aiSystemCockpit.nativeAppStatus", "title": "AI Cockpit: Native App Status" },
      { "command": "aiSystemCockpit.kimiStatus", "title": "AI Cockpit: Kimi Status" },
      { "command": "aiSystemCockpit.repoMap", "title": "AI Cockpit: Repo Map" },
      { "command": "aiSystemCockpit.repoIndex", "title": "AI Cockpit: Repo Index" },
      { "command": "aiSystemCockpit.semanticIndex", "title": "AI Cockpit: Semantic Index" },
      { "command": "aiSystemCockpit.diffHunks", "title": "AI Cockpit: Diff Hunks" },
      { "command": "aiSystemCockpit.workflowProof", "title": "AI Cockpit: Workflow Proof" },
      { "command": "aiSystemCockpit.browserProof", "title": "AI Cockpit: Browser Proof" },
      { "command": "aiSystemCockpit.fiveMinuteDemo", "title": "AI Cockpit: Five-Minute Demo" },
      { "command": "aiSystemCockpit.openSettings", "title": "AI Cockpit: Open Settings" },
      { "command": "aiSystemCockpit.jobs", "title": "AI Cockpit: Jobs" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiSystemCockpit",
          "title": "AI Cockpit",
          "icon": "media/cockpit.svg"
        }
      ]
    },
    "views": {
      "aiSystemCockpit": [
        {
          "type": "webview",
          "id": "aiSystemCockpit.dashboard",
          "name": "Cockpit"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "aiSystemCockpit.refresh",
          "when": "view == aiSystemCockpit.dashboard",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        { "command": "aiSystemCockpit.open" },
        { "command": "aiSystemCockpit.refresh" },
        { "command": "aiSystemCockpit.status" },
        { "command": "aiSystemCockpit.systemDemo" },
        { "command": "aiSystemCockpit.explainRoute" },
        { "command": "aiSystemCockpit.autoRun" },
        { "command": "aiSystemCockpit.buildFix" },
        { "command": "aiSystemCockpit.designBrowser" },
        { "command": "aiSystemCockpit.researchExtract" },
        { "command": "aiSystemCockpit.savePlan" },
        { "command": "aiSystemCockpit.reviewDiff" },
        { "command": "aiSystemCockpit.inlineEdit" },
        { "command": "aiSystemCockpit.routeReceipt" },
        { "command": "aiSystemCockpit.routerMetrics" },
        { "command": "aiSystemCockpit.permissionMatrix" },
        { "command": "aiSystemCockpit.checkpoints" },
        { "command": "aiSystemCockpit.loopQuality" },
        { "command": "aiSystemCockpit.diskReadiness" },
        { "command": "aiSystemCockpit.productReadiness" },
        { "command": "aiSystemCockpit.firstRun" },
        { "command": "aiSystemCockpit.contextMeter" },
        { "command": "aiSystemCockpit.contextSnapshot" },
        { "command": "aiSystemCockpit.sessionLedger" },
        { "command": "aiSystemCockpit.pulseStatus" },
        { "command": "aiSystemCockpit.nativeAppStatus" },
        { "command": "aiSystemCockpit.kimiStatus" },
        { "command": "aiSystemCockpit.repoMap" },
        { "command": "aiSystemCockpit.repoIndex" },
        { "command": "aiSystemCockpit.semanticIndex" },
        { "command": "aiSystemCockpit.diffHunks" },
        { "command": "aiSystemCockpit.workflowProof" },
        { "command": "aiSystemCockpit.browserProof" },
        { "command": "aiSystemCockpit.fiveMinuteDemo" },
        { "command": "aiSystemCockpit.openSettings" },
        { "command": "aiSystemCockpit.jobs" }
      ]
    },
    "configuration": {
      "title": "AI System Cockpit",
      "properties": {
        "aiSystemCockpit.openOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Open the AI cockpit view on VS Code startup. Disabled by default so the extension stays startup-safe."
        },
        "aiSystemCockpit.showStatusBarButton": {
          "type": "boolean",
          "default": true,
          "description": "Show AI cockpit readiness in the status bar."
        }
      }
    }
  }
}
