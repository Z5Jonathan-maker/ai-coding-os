{
  "permissions": {
    "allow": [
      "Bash(*:curl *,wget *,git *,npm *,node *,pip *,uv *,pytest *,make *,cargo *,go *)",
      "Read(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Agent(*)",
      "WebSearch(*)",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(*:rm -rf *,sudo *,mkfs.*,dd *,> ~/.ssh/*,chmod *,chown *)"
    ],
    "defaultMode": "askForPermission"
  },
  "agentPushNotifEnabled": true
}
