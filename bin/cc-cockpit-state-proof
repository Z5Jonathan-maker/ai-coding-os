    }
    .state-proof-badge {
      display: inline-flex;
      width: fit-content;
      margin-top: 22px;
      padding: 8px 12px;
      border-radius: 999px;
      color: white;
      background: rgba(255,255,255,.11);
    }
  </style>
</head>
<body class="panel-mode state-${state}">
  <main class="state-proof-shell">
    <aside class="state-proof-rail">
      <div class="state-proof-brand"><div class="state-proof-logo"></div><div><strong>cc-cockpit</strong><span>Local mode</span></div></div>
      <nav class="state-proof-nav"><span class="active">Home</span><span>Missions</span><span>Browser</span><span>Code</span><span>Assets</span><span>Knowledge</span></nav>
    </aside>
    <section class="state-proof-main">
      <div>
        <div class="state-proof-eyebrow">${state}</div>
        <h1 class="state-proof-title">${title}</h1>
        <p class="state-proof-subtitle">${subtitle}</p>
      </div>
      <section class="state-proof-hero" aria-label="${state} proof hero">
        <span class="state-proof-badge">${primary}</span>
        <div class="state-proof-primary"><i></i><strong>${primary}</strong></div>
      </section>
      <section class="state-proof-grid">
        <article class="state-proof-panel"><h2>Visible state</h2><p>${detail}</p><div class="state-proof-proof"><span><b>State</b><em>${state}</em></span><span><b>Proof</b><em>deterministic screenshot</em></span></div></article>
        <article class="state-proof-panel"><h2>Hidden complexity</h2><p>Routing, permissions, provider state, and proof artifacts stay available without becoming the main interface.</p><div class="state-proof-proof"><span><b>Noise</b><em>collapsed</em></span><span><b>Momentum</b><em>primary</em></span></div></article>
      </section>
    </section>
  </main>
</body>
</html>
HTML
  } >"$file"
