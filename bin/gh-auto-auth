#!/usr/bin/env -S uv run --quiet --with playwright python3
"""Hands-off GitHub re-auth.

Hits GitHub's device-code API, then navigates Chromium's persistent profile
to the verification URL with the user code already embedded — skipping
the code-entry form entirely. Clicks Authorize. Polls for the token.

If anything blocks (no logged-in session, 2FA needed and 1Password not
unlocked, GitHub UI changed), falls back to an osascript dialog so you
can finish manually.

Usage:
    gh-auto-auth                      # default scopes
    gh-auto-auth repo,workflow,...    # custom scopes
"""
import json
import os
import subprocess
import sys
import time
import urllib.request
import urllib.parse
from pathlib import Path

GH_CLIENT_ID = "178c6fc778ccc68e1d6a"
DEFAULT_SCOPES = (
    "repo,read:org,workflow,gist,"
    "admin:public_key,admin:ssh_signing_key"
)
PROFILE = str(Path.home() / ".cache" / "playwright-profile")

def post(url: str, data: dict) -> dict:
    body = urllib.parse.urlencode(data).encode()
    req = urllib.request.Request(
        url, data=body, headers={"Accept": "application/json"},
    )
    with urllib.request.urlopen(req, timeout=30) as r:
        return json.loads(r.read())

def request_device_code(scopes: str) -> dict:
    return post(
        "https://github.com/login/device/code",
        {"client_id": GH_CLIENT_ID, "scope": scopes},
    )

def poll_for_token(device_code: str) -> dict:
    return post(
        "https://github.com/login/oauth/access_token",
        {
            "client_id": GH_CLIENT_ID,
            "device_code": device_code,
            "grant_type": "urn:ietf:params:oauth:grant-type:device_code",
        },
    )

def clear_singleton_locks() -> None:
    for lock in ("SingletonLock", "SingletonCookie", "SingletonSocket"):
        p_lock = Path(PROFILE) / lock
        try:
            p_lock.unlink()
        except (FileNotFoundError, IsADirectoryError):
            pass

def autofill_with_playwright(user_code: str, verify_url: str,
                             verify_url_complete: str | None) -> bool:
    """Walk the device-flow approve path. Multiple Continue clicks
    (select-account, code-entry) may be required before the Authorize button
    appears. Loops until Authorize is found and clicked, or gives up."""
    try:
        from playwright.sync_api import sync_playwright
    except ImportError:
        print("playwright not installed; falling back to dialog", file=sys.stderr)
        return False

    clear_singleton_locks()

    target_url = verify_url_complete or f"{verify_url}?user_code={user_code}"

    with sync_playwright() as p:
        ctx = p.chromium.launch_persistent_context(
            PROFILE, headless=False,
            args=["--no-default-browser-check"],
        )
        page = ctx.new_page()
        try:
            page.goto(target_url, wait_until="domcontentloaded")
            page.wait_for_timeout(1500)

            for step in range(6):
                # GitHub's device page uses 9 segmented inputs:
                # #user-code-0..3 (chars), -4 (hidden dash), -5..8 (chars).
                # Fill each char individually if the segmented form is present.
                try:
                    if page.locator("#user-code-0").count():
                        first, second = (user_code.split("-") + [""])[:2]
                        chars = list(first) + list(second)
                        for i, ch in enumerate(chars):
                            idx = i if i < 4 else i + 1  # skip the dash slot
                            inp = page.locator(f"#user-code-{idx}")
                            if inp.count():
                                inp.fill(ch, timeout=2000)
                        page.wait_for_timeout(500)
                except Exception:
                    pass

                # Older / single-input variant
                try:
                    code_input = page.locator(
                        "input[name='user_code'], input#user_code, input[autocomplete='one-time-code']"
                    ).first
                    if code_input.count() and code_input.is_visible() and not code_input.input_value():
                        code_input.fill(user_code, timeout=3000)
                        page.wait_for_timeout(500)
                except Exception:
                    pass

                # Look for the Authorize button — that's the goal.
                # CAUTION: there are two buttons with name='authorize' (Cancel
                # has value='0' and is listed first). Target value='1' explicitly.
                # The button is disabled for ~5-10s as anti-clickjacking; wait it out.
                authorize = None
                for sel in [
                    "button[name='authorize'][value='1']",
                    "button.js-oauth-authorize-btn",
                    "button:has-text('Authorize')",
                ]:
                    try:
                        loc = page.locator(sel).first
                        if loc.count() and loc.is_visible():
                            authorize = loc
                            break
                    except Exception:
                        continue
                if authorize:
                    # Wait for the button to become enabled (countdown ends)
                    for _ in range(40):  # up to ~20s
                        try:
                            if authorize.is_enabled():
                                break
                        except Exception:
                            pass
                        page.wait_for_timeout(500)
                    authorize.click(force=False)
                    # Don't insist on networkidle — GitHub keeps polling.
                    # Just wait briefly for the navigation to start, then trust the polling loop.
                    try:
                        page.wait_for_load_state("load", timeout=15_000)
                    except Exception:
                        pass
                    page.wait_for_timeout(2000)
                    print("playwright auto-authorized", flush=True)
                    return True

                # No Authorize yet — click any visible Continue button and loop
                clicked = False
                for sel in [
                    "input[type=submit][value='Continue']",
                    "button:has-text('Continue')",
                    "form[action*='device'] input[type=submit]",
                    "form[action*='device'] button[type=submit]",
                ]:
                    try:
                        loc = page.locator(sel).first
                        if loc.count() and loc.is_visible():
                            loc.click(timeout=3000)
                            clicked = True
                            break
                    except Exception:
                        continue
                if not clicked:
                    print(f"step {step}: nothing clickable at {page.url}",
                          file=sys.stderr)
                    return False
                try:
                    page.wait_for_load_state("domcontentloaded", timeout=10_000)
                    page.wait_for_timeout(1200)
                except Exception:
                    pass

            print("Authorize button not reached after 6 steps", file=sys.stderr)
            return False
        except Exception as e:
            print(f"playwright autofill failed: {e}", file=sys.stderr)
            return False
        finally:
            ctx.close()

def fallback_dialog(user_code: str, verify_url: str) -> None:
    msg = (f"GitHub one-time code:\\n\\n      {user_code}\\n\\n"
           f"Click OK to open {verify_url}.")
    subprocess.run(
        ["osascript", "-e",
         f'display dialog "{msg}" with title "gh auto-auth" '
         f'buttons {{"OK"}} default button "OK"'],
        check=False,
    )
    subprocess.run(["open", verify_url], check=False)

def main() -> int:
    scopes = sys.argv[1] if len(sys.argv) > 1 else DEFAULT_SCOPES
    print(f"requesting device code (scopes: {scopes})...", flush=True)
    dc = request_device_code(scopes)
    user_code = dc["user_code"]
    device_code = dc["device_code"]
    verify_url = dc["verification_uri"]
    verify_url_complete = dc.get("verification_uri_complete")
    interval = int(dc.get("interval", 5))
    expires_in = int(dc.get("expires_in", 900))

    print(f"user code: {user_code}", flush=True)

    autofilled = autofill_with_playwright(user_code, verify_url, verify_url_complete)
    if not autofilled:
        fallback_dialog(user_code, verify_url)

    deadline = time.time() + expires_in
    while time.time() < deadline:
        time.sleep(interval)
        try:
            resp = poll_for_token(device_code)
        except Exception as e:
            print(f"poll error: {e}", flush=True)
            continue
        if "access_token" in resp:
            token = resp["access_token"]
            print("got token, importing into gh", flush=True)
            r = subprocess.run(
                ["/opt/homebrew/bin/gh", "auth", "login",
                 "--with-token", "--hostname", "github.com"],
                input=token.encode(), capture_output=True,
            )
            if r.returncode != 0:
                print(f"gh failed: {r.stderr.decode()}", flush=True)
                return 1
            subprocess.run(
                ["/opt/homebrew/bin/gh", "config", "set",
                 "git_protocol", "https"], check=False,
            )
            print("authenticated", flush=True)
            return 0
        err = resp.get("error", "")
        if err == "authorization_pending":
            print(".", end="", flush=True)
            continue
        if err == "slow_down":
            interval += 5
            continue
        if err in ("expired_token", "access_denied"):
            print(f"\nfailed: {err}", flush=True)
            return 2
    print("\nexpired", flush=True)
    return 3

if __name__ == "__main__":
    sys.exit(main())
